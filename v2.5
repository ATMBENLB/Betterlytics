def run_kmeans_scan(
    df: pd.DataFrame,
    config: WorkbenchConfig,
    exclude: list[str] | None = None,
    auto_k: bool = True,
    selected_k: int = 3,
) -> dict[str, Any] | None:
    exclude = exclude or []
    numeric_cols = [c for c in choose_numeric_columns_by_variance(df.drop(columns=exclude, errors="ignore"), config.max_unsupervised_numeric_cols) if c not in exclude]
    if len(numeric_cols) < 2 or len(df) < 20:
        return None

    sample = safe_sample_df(df[numeric_cols], config.max_cluster_rows)
    sample = sample.replace([np.inf, -np.inf], np.nan)
    sample = sample.fillna(sample.median(numeric_only=True))
    sample = sample.dropna(axis=1, how="all")
    if sample.shape[1] < 2:
        return None

    scaler = StandardScaler()
    X = scaler.fit_transform(sample)

    best: dict[str, Any] | None = None
    k_values = range(2, min(config.kmeans_max_k, len(sample) - 1) + 1) if auto_k else [min(max(2, selected_k), max(2, len(sample) - 1))]

    for k in k_values:
        if len(sample) > 10000:
            model = MiniBatchKMeans(n_clusters=k, n_init=config.kmeans_n_init, random_state=42, batch_size=2048)
        else:
            model = KMeans(n_clusters=k, n_init=config.kmeans_n_init, random_state=42)
        labels = model.fit_predict(X)
        if len(set(labels)) < 2:
            continue
        score = silhouette_score(X, labels, sample_size=min(config.silhouette_rows, len(X)), random_state=42)
        if best is None or score > best["silhouette"]:
            best = {"k": k, "silhouette": float(score), "labels": labels, "model": model}

    if best is None:
        return None

    pca = PCA(n_components=2, random_state=42)
    coords = pca.fit_transform(X)
    pca_df = pd.DataFrame({"pc1": coords[:, 0], "pc2": coords[:, 1], "cluster": best["labels"]}, index=sample.index)

    clustered_df = df.loc[sample.index].copy()
    clustered_df["cluster"] = best["labels"]

    return {
        "k": best["k"],
        "silhouette": best["silhouette"],
        "pca_df": pca_df.reset_index(drop=True),
        "clustered_df": clustered_df.reset_index(drop=True),
        "numeric_columns_used": sample.columns.tolist(),
        "sampled_rows": len(sample),
        "sampled": len(sample) < len(df),
    }


def build_cluster_profiles(clustering: dict[str, Any] | None, top_n_numeric: int = 6) -> pd.DataFrame:
    if not clustering or "clustered_df" not in clustering:
        return pd.DataFrame()
    df = clustering["clustered_df"].copy()
    if "cluster" not in df.columns:
        return pd.DataFrame()
    numeric_cols = [c for c in df.select_dtypes(include=[np.number]).columns if c != "cluster"]
    if not numeric_cols:
        return pd.DataFrame()
    overall_means = df[numeric_cols].mean(numeric_only=True)
    rows: list[dict[str, Any]] = []
    for cluster_id, subset in df.groupby("cluster"):
        cluster_means = subset[numeric_cols].mean(numeric_only=True)
        deltas = (cluster_means - overall_means).sort_values(key=lambda s: s.abs(), ascending=False)
        defining = deltas.head(top_n_numeric)
        rows.append({
            "cluster": cluster_id,
            "size": len(subset),
            "share_pct": round(len(subset) / len(df) * 100, 2),
            "defining_numeric_differences": ", ".join([f"{idx} ({val:+.2f})" for idx, val in defining.items()]),
        })
    return pd.DataFrame(rows).sort_values("share_pct", ascending=False).reset_index(drop=True)


def cluster_balance_metrics(labels: np.ndarray | list[Any]) -> dict[str, float]:
    label_series = pd.Series(labels)
    if label_series.empty:
        return {
            "smallest_cluster_share_pct": np.nan,
            "largest_cluster_share_pct": np.nan,
            "balance_score": np.nan,
            "noise_pct": np.nan,
        }
    noise_pct = float((label_series == -1).mean() * 100) if (label_series == -1).any() else 0.0
    usable = label_series[label_series != -1]
    if usable.empty:
        return {
            "smallest_cluster_share_pct": np.nan,
            "largest_cluster_share_pct": np.nan,
            "balance_score": np.nan,
            "noise_pct": round(noise_pct, 2),
        }
    counts = usable.value_counts()
    smallest = float(counts.min() / len(label_series) * 100)
    largest = float(counts.max() / len(label_series) * 100)
    balance = float(counts.min() / counts.max()) if counts.max() else np.nan
    return {
        "smallest_cluster_share_pct": round(smallest, 2),
        "largest_cluster_share_pct": round(largest, 2),
        "balance_score": round(balance, 4),
        "noise_pct": round(noise_pct, 2),
    }


def build_cluster_connection_tables(
    clustered_df: pd.DataFrame,
    schema: Schema,
    config: WorkbenchConfig,
    numeric_cols: list[str] | None = None,
    target: str | None = None,
) -> dict[str, pd.DataFrame]:
    if clustered_df.empty or "cluster" not in clustered_df.columns:
        return {
            "cluster_sizes": pd.DataFrame(),
            "numeric_connections": pd.DataFrame(),
            "categorical_connections": pd.DataFrame(),
            "target_by_cluster": pd.DataFrame(),
        }

    cluster_sizes = (
        clustered_df["cluster"]
        .value_counts(dropna=False)
        .rename_axis("cluster")
        .reset_index(name="rows")
    )
    cluster_sizes["share_pct"] = (cluster_sizes["rows"] / max(1, len(clustered_df)) * 100).round(2)
    cluster_sizes = cluster_sizes.sort_values("rows", ascending=False).reset_index(drop=True)

    numeric_candidates = numeric_cols or [c for c in clustered_df.select_dtypes(include=[np.number]).columns if c != "cluster"]
    numeric_candidates = [c for c in numeric_candidates if c in clustered_df.columns and c != "cluster"]
    numeric_rows: list[dict[str, Any]] = []

    for col in numeric_candidates:
        vals = pd.to_numeric(clustered_df[col], errors="coerce")
        temp = pd.DataFrame({"cluster": clustered_df["cluster"], col: vals}).dropna()
        if temp[col].nunique(dropna=True) < 2 or temp["cluster"].nunique(dropna=True) < 2:
            continue
        overall_mean = float(temp[col].mean())
        grouped = temp.groupby("cluster")[col].agg(["count", "mean", "median", "std"]).reset_index()
        total_ss = float(((temp[col] - overall_mean) ** 2).sum())
        between_ss = float((grouped["count"] * ((grouped["mean"] - overall_mean) ** 2)).sum())
        eta_squared = between_ss / total_ss if total_ss else np.nan
        grouped["difference_from_overall"] = grouped["mean"] - overall_mean
        top = grouped.iloc[grouped["difference_from_overall"].abs().argmax()]
        pct_diff = float(top["difference_from_overall"] / overall_mean * 100) if overall_mean else np.nan
        numeric_rows.append({
            "feature": col,
            "eta_squared_cluster_effect": round(float(eta_squared), 4) if pd.notna(eta_squared) else np.nan,
            "strongest_cluster": top["cluster"],
            "overall_mean": round(overall_mean, 4),
            "cluster_mean": round(float(top["mean"]), 4),
            "difference_from_overall": round(float(top["difference_from_overall"]), 4),
            "pct_difference_from_overall": round(pct_diff, 2) if pd.notna(pct_diff) else np.nan,
            "rows_in_strongest_cluster": int(top["count"]),
        })

    numeric_connections = pd.DataFrame(numeric_rows)
    if not numeric_connections.empty:
        numeric_connections = numeric_connections.sort_values("eta_squared_cluster_effect", ascending=False).reset_index(drop=True)

    categorical_candidates = [c for c in list(dict.fromkeys(schema.categorical + schema.boolean)) if c in clustered_df.columns and c != target]
    categorical_rows: list[dict[str, Any]] = []
    for col in categorical_candidates:
        s = clustered_df[col].dropna()
        nunique = int(s.nunique(dropna=True)) if not s.empty else 0
        if nunique < 2 or nunique > config.grouped_max_categories:
            continue
        base_share = s.value_counts(normalize=True)
        temp = clustered_df[["cluster", col]].dropna()
        if temp.empty:
            continue
        for cluster_id, subset in temp.groupby("cluster"):
            shares = subset[col].value_counts(normalize=True)
            if shares.empty:
                continue
            top_value = shares.index[0]
            cluster_share = float(shares.iloc[0])
            overall_share = float(base_share.get(top_value, np.nan))
            lift = cluster_share / overall_share if overall_share else np.nan
            categorical_rows.append({
                "feature": col,
                "cluster": cluster_id,
                "top_value_in_cluster": top_value,
                "cluster_share_pct": round(cluster_share * 100, 2),
                "overall_share_pct": round(overall_share * 100, 2) if pd.notna(overall_share) else np.nan,
                "lift_vs_overall": round(float(lift), 3) if pd.notna(lift) else np.nan,
                "cluster_rows": int(len(subset)),
            })

    categorical_connections = pd.DataFrame(categorical_rows)
    if not categorical_connections.empty:
        categorical_connections = categorical_connections.sort_values("lift_vs_overall", ascending=False).reset_index(drop=True)

    target_by_cluster = pd.DataFrame()
    if target and target in clustered_df.columns:
        if pd.api.types.is_numeric_dtype(clustered_df[target]):
            target_by_cluster = (
                clustered_df.groupby("cluster")[target]
                .agg(["count", "mean", "median", "min", "max"])
                .reset_index()
            )
            overall = float(pd.to_numeric(clustered_df[target], errors="coerce").mean())
            target_by_cluster["difference_from_overall_mean"] = target_by_cluster["mean"] - overall
            target_by_cluster = target_by_cluster.sort_values("difference_from_overall_mean", key=lambda s: s.abs(), ascending=False).reset_index(drop=True)
        else:
            temp = clustered_df[["cluster", target]].dropna()
            rows: list[dict[str, Any]] = []
            overall_share = temp[target].value_counts(normalize=True)
            for cluster_id, subset in temp.groupby("cluster"):
                shares = subset[target].value_counts(normalize=True)
                for value, share in shares.head(5).items():
                    base = float(overall_share.get(value, np.nan))
                    rows.append({
                        "cluster": cluster_id,
                        "target_value": value,
                        "cluster_share_pct": round(float(share) * 100, 2),
                        "overall_share_pct": round(base * 100, 2) if pd.notna(base) else np.nan,
                        "lift_vs_overall": round(float(share / base), 3) if base else np.nan,
                        "cluster_rows": int(len(subset)),
                    })
            target_by_cluster = pd.DataFrame(rows)
            if not target_by_cluster.empty:
                target_by_cluster = target_by_cluster.sort_values("lift_vs_overall", ascending=False).reset_index(drop=True)

    return {
        "cluster_sizes": cluster_sizes,
        "numeric_connections": numeric_connections,
        "categorical_connections": categorical_connections,
        "target_by_cluster": target_by_cluster,
    }


def run_clustering_comparison(
    df: pd.DataFrame,
    schema: Schema,
    config: WorkbenchConfig,
    exclude: list[str] | None = None,
    target: str | None = None,
    methods: list[str] | None = None,
    min_k: int = 2,
    max_k: int = 6,
) -> dict[str, Any] | None:
    exclude = exclude or []
    methods = methods or ["KMeans", "MiniBatch KMeans", "Gaussian Mixture"]
    numeric_cols = [
        c for c in choose_numeric_columns_by_variance(
            df.drop(columns=exclude, errors="ignore"),
            min(config.max_unsupervised_numeric_cols, 60),
        )
        if c not in exclude
    ]
    if len(numeric_cols) < 2 or len(df) < 20:
        return None

    row_cap = min(config.max_cluster_rows, config.max_cluster_compare_rows)
    if "Agglomerative" in methods:
        row_cap = min(row_cap, 5000)
    sample = safe_sample_df(df[numeric_cols], row_cap)
    display_df = df.loc[sample.index].copy()
    sample = sample.replace([np.inf, -np.inf], np.nan)
    sample = sample.fillna(sample.median(numeric_only=True)).dropna(axis=1, how="all")
    numeric_cols = sample.columns.tolist()
    if sample.shape[1] < 2 or len(sample) < 20:
        return None

    scaler = StandardScaler()
    X = scaler.fit_transform(sample)
    coords = PCA(n_components=2, random_state=42).fit_transform(X)
    min_k = max(2, int(min_k))
    max_k = min(max(min_k, int(max_k)), config.kmeans_max_k, len(sample) - 1)

    candidates: list[tuple[str, str, Callable[[], np.ndarray]]] = []
    for method in methods:
        if method in {"KMeans", "MiniBatch KMeans", "Gaussian Mixture", "Agglomerative"}:
            for k in range(min_k, max_k + 1):
                if method == "KMeans":
                    candidates.append((method, f"k={k}", lambda k=k: KMeans(n_clusters=k, n_init=config.kmeans_n_init, random_state=42).fit_predict(X)))
                elif method == "MiniBatch KMeans":
                    candidates.append((method, f"k={k}", lambda k=k: MiniBatchKMeans(n_clusters=k, n_init=config.kmeans_n_init, random_state=42, batch_size=2048).fit_predict(X)))
                elif method == "Gaussian Mixture":
                    candidates.append((method, f"k={k}", lambda k=k: GaussianMixture(n_components=k, random_state=42, covariance_type="diag").fit_predict(X)))
                elif method == "Agglomerative" and len(sample) <= 5000:
                    candidates.append((method, f"k={k}", lambda k=k: AgglomerativeClustering(n_clusters=k).fit_predict(X)))
        elif method == "DBSCAN" and len(sample) <= 10000:
            for eps in [0.6, 0.8, 1.0, 1.2]:
                candidates.append((method, f"eps={eps}, min_samples=8", lambda eps=eps: DBSCAN(eps=eps, min_samples=8).fit_predict(X)))

    results: list[dict[str, Any]] = []
    summary_rows: list[dict[str, Any]] = []

    for method, parameter, runner in candidates:
        start = time.perf_counter()
        result_id = f"{method} | {parameter}"
        try:
            labels = np.asarray(runner())
        except Exception as exc:
            summary_rows.append({
                "result_id": result_id,
                "method": method,
                "parameter": parameter,
                "status": "Failed",
                "clusters": np.nan,
                "silhouette": np.nan,
                "balance_score": np.nan,
                "noise_pct": np.nan,
                "seconds": round(time.perf_counter() - start, 2),
                "note": str(exc)[:180],
            })
            continue

        unique_labels = set(labels.tolist())
        clusters = int(len(unique_labels) - (1 if -1 in unique_labels else 0))
        if clusters < 2:
            summary_rows.append({
                "result_id": result_id,
                "method": method,
                "parameter": parameter,
                "status": "Skipped",
                "clusters": clusters,
                "silhouette": np.nan,
                "balance_score": np.nan,
                "noise_pct": 100.0 if clusters == 0 else 0.0,
                "seconds": round(time.perf_counter() - start, 2),
                "note": "Fewer than two usable clusters were found.",
            })
            continue

        try:
            sil = silhouette_score(X, labels, sample_size=min(config.silhouette_rows, len(X)), random_state=42)
        except Exception:
            sil = np.nan

        balance = cluster_balance_metrics(labels)
        pca_df = pd.DataFrame({"pc1": coords[:, 0], "pc2": coords[:, 1], "cluster": labels})
        clustered_df = display_df.copy()
        clustered_df["cluster"] = labels
        profiles = build_cluster_profiles({"clustered_df": clustered_df})
        connections = build_cluster_connection_tables(clustered_df, schema, config, numeric_cols=numeric_cols, target=target)
        fingerprints = build_cluster_fingerprints(clustered_df, schema, config, numeric_cols=numeric_cols)
        ranking_score = float(sil) if pd.notna(sil) else -999.0
        if balance.get("largest_cluster_share_pct") and pd.notna(balance["largest_cluster_share_pct"]):
            if balance["largest_cluster_share_pct"] > 90:
                ranking_score -= 0.15
        if balance.get("noise_pct") and pd.notna(balance["noise_pct"]):
            ranking_score -= min(0.25, balance["noise_pct"] / 400)

        results.append({
            "result_id": result_id,
            "method": method,
            "parameter": parameter,
            "clusters": clusters,
            "silhouette": float(sil) if pd.notna(sil) else np.nan,
            "balance": balance,
            "ranking_score": ranking_score,
            "labels": labels,
            "pca_df": pca_df,
            "profiles": profiles,
            "connections": connections,
            "fingerprints": fingerprints,
            "seconds": round(time.perf_counter() - start, 2),
        })
        summary_rows.append({
            "result_id": result_id,
            "method": method,
            "parameter": parameter,
            "status": "Completed",
            "clusters": clusters,
            "silhouette": round(float(sil), 4) if pd.notna(sil) else np.nan,
            "balance_score": balance.get("balance_score"),
            "smallest_cluster_share_pct": balance.get("smallest_cluster_share_pct"),
            "largest_cluster_share_pct": balance.get("largest_cluster_share_pct"),
            "noise_pct": balance.get("noise_pct"),
            "ranking_score": round(ranking_score, 4),
            "seconds": round(time.perf_counter() - start, 2),
            "note": "",
        })

    if not results:
        return None

    summary = pd.DataFrame(summary_rows)
    if not summary.empty and "ranking_score" in summary.columns:
        summary = summary.sort_values(["status", "ranking_score"], ascending=[True, False], na_position="last").reset_index(drop=True)

    labels_by_id = {r["result_id"]: np.asarray(r["labels"]) for r in results}
    ordered_ids = [r["result_id"] for r in sorted(results, key=lambda r: r.get("ranking_score", -999), reverse=True)]
    similarity = pd.DataFrame(index=ordered_ids, columns=ordered_ids, dtype=float)
    for left_id in ordered_ids:
        for right_id in ordered_ids:
            try:
                similarity.loc[left_id, right_id] = adjusted_rand_score(labels_by_id[left_id], labels_by_id[right_id])
            except Exception:
                similarity.loc[left_id, right_id] = np.nan

    best_result = sorted(results, key=lambda r: r.get("ranking_score", -999), reverse=True)[0]
    return {
        "summary": summary,
        "results": results,
        "pairwise_similarity": similarity,
        "best_result_id": best_result["result_id"],
        "sample_df": display_df.reset_index(drop=True),
        "numeric_columns_used": numeric_cols,
        "sampled_rows": len(display_df),
        "sampled": len(display_df) < len(df),
    }


def get_cluster_comparison_result(comparison: dict[str, Any] | None, result_id: str | None = None) -> dict[str, Any] | None:
    if not comparison:
        return None
    results = comparison.get("results", [])
    if not results:
        return None
    if result_id is None:
        result_id = comparison.get("best_result_id")
    for result in results:
        if result.get("result_id") == result_id:
            return result
    return results[0]


def clustered_sample_for_result(comparison: dict[str, Any], result: dict[str, Any]) -> pd.DataFrame:
    sample = comparison.get("sample_df")
    labels = result.get("labels")
    if not isinstance(sample, pd.DataFrame) or labels is None:
        return pd.DataFrame()
    out = sample.copy()
    out["cluster"] = np.asarray(labels)
    return out


