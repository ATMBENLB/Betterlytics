def _compact_value(value: Any, max_len: int = 42) -> str:
    text = str(value)
    text = re.sub(r"\s+", " ", text).strip()
    if len(text) > max_len:
        return text[: max_len - 3] + "..."
    return text


def _pct_delta(part: float, whole: float) -> float:
    if whole == 0 or pd.isna(whole):
        return np.nan
    return float((part - whole) / abs(whole) * 100)


def _persona_phrase(feature: str, direction: str) -> str:
    low = feature.lower()
    pretty = prettify_feature_name(feature)
    if any(k in low for k in ["price", "revenue", "sales", "value", "income", "gmv"]):
        return "premium" if direction == "high" else "value-oriented"
    if any(k in low for k in ["cost", "expense", "spend", "fee"]):
        return "high-cost" if direction == "high" else "low-cost"
    if any(k in low for k in ["margin", "profit"]):
        return "high-margin" if direction == "high" else "low-margin"
    if any(k in low for k in ["range", "mileage", "miles", "distance"]):
        return "long-range" if direction == "high" else "short-range"
    if any(k in low for k in ["horsepower", "power", "speed", "acceleration", "torque", "performance"]):
        return "performance-heavy" if direction == "high" else "efficiency-focused"
    if any(k in low for k in ["seat", "capacity", "cargo", "volume", "weight", "size"]):
        return "large utility" if direction == "high" else "compact"
    if any(k in low for k in ["churn", "risk", "default", "fraud", "defect", "failure"]):
        return "high-risk" if direction == "high" else "low-risk"
    if any(k in low for k in ["delay", "late", "duration", "lead_time", "wait", "sla"]):
        return "delay-prone" if direction == "high" else "fast-moving"
    if any(k in low for k in ["rating", "score", "quality", "satisfaction", "nps"]):
        return "high-quality" if direction == "high" else "low-rated"
    if any(k in low for k in ["age", "tenure", "years"]):
        return "mature" if direction == "high" else "newer"
    return f"{direction} {pretty}"


def _cluster_persona_from_tables(
    cluster_id: Any,
    above: pd.DataFrame,
    below: pd.DataFrame,
    categories: pd.DataFrame,
) -> str:
    phrase_rows: list[tuple[float, str]] = []
    for direction, table in [("high", above), ("low", below)]:
        if isinstance(table, pd.DataFrame) and not table.empty:
            for _, row in table.head(3).iterrows():
                phrase_rows.append((abs(safe_float(row.get("z_delta"))), _persona_phrase(str(row.get("feature")), direction)))
    phrases: list[str] = []
    for _, phrase in sorted(phrase_rows, reverse=True):
        if phrase not in phrases:
            phrases.append(phrase)
        if len(phrases) >= 2:
            break

    category_hint = ""
    if isinstance(categories, pd.DataFrame) and not categories.empty:
        cat = categories.iloc[0]
        if safe_float(cat.get("share_pct")) >= 35 or safe_float(cat.get("lift_vs_overall"), 1.0) >= 1.4:
            category_hint = _compact_value(cat.get("top_value"), 28)

    if not phrases and category_hint:
        return f"{category_hint} segment"
    if not phrases:
        return f"Cluster {cluster_id} segment"
    label = " ".join(phrases)
    if category_hint and category_hint.lower() not in label.lower():
        label = f"{category_hint} {label}"
    return f"{label} segment"


def _cluster_difference_table(
    cluster_means: pd.Series,
    overall_means: pd.Series,
    z_deltas: pd.Series,
    features: list[str],
) -> pd.DataFrame:
    rows: list[dict[str, Any]] = []
    for feature in features:
        cmean = safe_float(cluster_means.get(feature), np.nan)
        omean = safe_float(overall_means.get(feature), np.nan)
        rows.append({
            "feature": feature,
            "cluster_mean": cmean,
            "overall_mean": omean,
            "difference": cmean - omean if pd.notna(cmean) and pd.notna(omean) else np.nan,
            "pct_difference": _pct_delta(cmean, omean) if pd.notna(cmean) and pd.notna(omean) else np.nan,
            "z_delta": safe_float(z_deltas.get(feature), np.nan),
        })
    return pd.DataFrame(rows)


def build_cluster_fingerprints(
    clustered_df: pd.DataFrame,
    schema: Schema,
    config: WorkbenchConfig,
    numeric_cols: list[str] | None = None,
    top_n: int = 5,
    row_n: int = 8,
) -> dict[str, Any]:
    if not isinstance(clustered_df, pd.DataFrame) or clustered_df.empty or "cluster" not in clustered_df.columns:
        return {"summary": pd.DataFrame(), "details": {}, "label_map": {}}

    numeric_candidates = numeric_cols or [c for c in clustered_df.select_dtypes(include=[np.number]).columns if c != "cluster"]
    numeric_candidates = [c for c in numeric_candidates if c in clustered_df.columns and c != "cluster"]
    categorical_candidates = [
        c for c in list(dict.fromkeys(schema.categorical + schema.boolean))
        if c in clustered_df.columns and c != "cluster" and clustered_df[c].nunique(dropna=True) <= config.grouped_max_categories
    ]

    numeric_data = clustered_df[numeric_candidates].apply(pd.to_numeric, errors="coerce") if numeric_candidates else pd.DataFrame(index=clustered_df.index)
    overall_means = numeric_data.mean(numeric_only=True)
    overall_stds = numeric_data.std(numeric_only=True).replace(0, np.nan)
    standardized = ((numeric_data - overall_means) / overall_stds).replace([np.inf, -np.inf], np.nan)

    summary_rows: list[dict[str, Any]] = []
    details: dict[str, Any] = {}
    label_map: dict[str, str] = {}
    total_rows = max(1, len(clustered_df))

    for cluster_id, subset in clustered_df.groupby("cluster", dropna=False):
        subset_idx = subset.index
        subset_numeric = numeric_data.loc[subset_idx] if not numeric_data.empty else pd.DataFrame(index=subset_idx)
        cluster_means = subset_numeric.mean(numeric_only=True)
        z_deltas = ((cluster_means - overall_means) / overall_stds).replace([np.inf, -np.inf], np.nan).dropna()

        above_features = z_deltas[z_deltas > 0].sort_values(ascending=False).head(top_n).index.tolist()
        below_features = z_deltas[z_deltas < 0].sort_values(ascending=True).head(top_n).index.tolist()
        above = _cluster_difference_table(cluster_means, overall_means, z_deltas, above_features)
        below = _cluster_difference_table(cluster_means, overall_means, z_deltas, below_features)

        cat_rows: list[dict[str, Any]] = []
        for col in categorical_candidates:
            col_subset = subset[col].dropna().astype(str)
            col_all = clustered_df[col].dropna().astype(str)
            if col_subset.empty or col_all.empty:
                continue
            top_value = col_subset.value_counts().index[0]
            cluster_share = float((col_subset == top_value).mean())
            overall_share = float((col_all == top_value).mean())
            cat_rows.append({
                "feature": col,
                "top_value": top_value,
                "share_pct": round(cluster_share * 100, 2),
                "overall_share_pct": round(overall_share * 100, 2),
                "lift_vs_overall": round(cluster_share / overall_share, 3) if overall_share else np.nan,
                "non_missing_rows": int(len(col_subset)),
            })
        categories = pd.DataFrame(cat_rows)
        if not categories.empty:
            categories = categories.sort_values(["lift_vs_overall", "share_pct"], ascending=False).head(top_n).reset_index(drop=True)

        if not standardized.empty and subset_idx.size:
            z_subset = standardized.loc[subset_idx].fillna(0.0)
            centroid = z_subset.mean(axis=0)
            distances = ((z_subset - centroid) ** 2).sum(axis=1).pow(0.5)
            representative_idx = distances.sort_values(ascending=True).head(row_n).index
            outlier_idx = distances.sort_values(ascending=False).head(row_n).index
            representative_rows = clustered_df.loc[representative_idx].copy()
            representative_rows.insert(0, "cluster_distance", distances.loc[representative_idx].round(4).values)
            outlier_rows = clustered_df.loc[outlier_idx].copy()
            outlier_rows.insert(0, "cluster_distance", distances.loc[outlier_idx].round(4).values)
        else:
            representative_rows = subset.head(row_n).copy()
            outlier_rows = subset.tail(row_n).copy()

        persona = _cluster_persona_from_tables(cluster_id, above, below, categories)
        label_map[str(cluster_id)] = persona
        summary_rows.append({
            "cluster": cluster_id,
            "persona": persona,
            "size": int(len(subset)),
            "share_pct": round(float(len(subset) / total_rows * 100), 2),
            "top_5_above_average": "; ".join([f"{r.feature} ({safe_float(r.pct_difference, np.nan):+.1f}%)" for r in above.itertuples(index=False)]),
            "top_5_below_average": "; ".join([f"{r.feature} ({safe_float(r.pct_difference, np.nan):+.1f}%)" for r in below.itertuples(index=False)]),
            "most_common_values": "; ".join([f"{r.feature}={_compact_value(r.top_value)} ({safe_float(r.share_pct):.0f}%)" for r in categories.itertuples(index=False)]) if not categories.empty else "",
        })
        details[str(cluster_id)] = {
            "persona": persona,
            "above_average": above,
            "below_average": below,
            "common_categories": categories,
            "representative_rows": representative_rows,
            "outlier_rows": outlier_rows,
            "numeric_profile": z_deltas,
        }

    summary = pd.DataFrame(summary_rows)
    if not summary.empty:
        summary = summary.sort_values("share_pct", ascending=False).reset_index(drop=True)
    return {"summary": summary, "details": details, "label_map": label_map}


def cluster_similarity_score(fingerprints: dict[str, Any], left: Any, right: Any) -> float:
    details = fingerprints.get("details", {}) if isinstance(fingerprints, dict) else {}
    left_vec = details.get(str(left), {}).get("numeric_profile")
    right_vec = details.get(str(right), {}).get("numeric_profile")
    if not isinstance(left_vec, pd.Series) or not isinstance(right_vec, pd.Series):
        return np.nan
    common = left_vec.index.intersection(right_vec.index)
    if len(common) == 0:
        return np.nan
    a = left_vec.loc[common].fillna(0).to_numpy(dtype=float)
    b = right_vec.loc[common].fillna(0).to_numpy(dtype=float)
    denom = float(np.linalg.norm(a) * np.linalg.norm(b))
    if denom == 0:
        return np.nan
    cosine = float(np.dot(a, b) / denom)
    return round((cosine + 1) / 2 * 100, 1)


def render_cluster_fingerprint_cards(fingerprints: dict[str, Any], key_prefix: str, max_rows: int = 8) -> None:
    summary = fingerprints.get("summary") if isinstance(fingerprints, dict) else pd.DataFrame()
    details = fingerprints.get("details", {}) if isinstance(fingerprints, dict) else {}
    if not isinstance(summary, pd.DataFrame) or summary.empty:
        st.info("Cluster fingerprints need clustered rows with numeric signal.")
        return

    st.write("**Cluster fingerprint cards**")
    st.dataframe(summary, use_container_width=True)

    cluster_options = summary["cluster"].tolist()
    selected = st.selectbox(
        "Open fingerprint card",
        cluster_options,
        format_func=lambda c: f"{c}: {details.get(str(c), {}).get('persona', 'segment')}",
        key=f"{key_prefix}_fingerprint_cluster",
    )
    detail = details.get(str(selected), {})
    size = int(summary.loc[summary["cluster"] == selected, "size"].iloc[0])
    share = safe_float(summary.loc[summary["cluster"] == selected, "share_pct"].iloc[0])
    c1, c2, c3 = st.columns(3)
    c1.metric("Persona", detail.get("persona", f"Cluster {selected}"))
    c2.metric("Rows", f"{size:,}")
    c3.metric("Dataset share", f"{share:.1f}%")

    card_tabs = st.tabs(["Above average", "Below average", "Common values", "Representative rows", "In-cluster outliers", "Compare clusters"])
    with card_tabs[0]:
        st.dataframe(detail.get("above_average", pd.DataFrame()), use_container_width=True)
    with card_tabs[1]:
        st.dataframe(detail.get("below_average", pd.DataFrame()), use_container_width=True)
    with card_tabs[2]:
        st.dataframe(detail.get("common_categories", pd.DataFrame()), use_container_width=True)
    with card_tabs[3]:
        st.dataframe(detail.get("representative_rows", pd.DataFrame()).head(max_rows), use_container_width=True)
    with card_tabs[4]:
        st.dataframe(detail.get("outlier_rows", pd.DataFrame()).head(max_rows), use_container_width=True)
    with card_tabs[5]:
        if len(cluster_options) < 2:
            st.info("Need at least two clusters to compare.")
        else:
            left, right = st.columns(2)
            with left:
                a = st.selectbox("First cluster", cluster_options, key=f"{key_prefix}_cluster_compare_a")
            with right:
                b_default = 1 if len(cluster_options) > 1 else 0
                b = st.selectbox("Second cluster", cluster_options, index=b_default, key=f"{key_prefix}_cluster_compare_b")
            score = cluster_similarity_score(fingerprints, a, b)
            st.metric("Similarity score", f"{score:.1f} / 100" if pd.notna(score) else "N/A")
            compare_rows = summary[summary["cluster"].isin([a, b])].set_index("cluster").T
            st.dataframe(compare_rows, use_container_width=True)


def suggest_cluster_labels(clustered_df: pd.DataFrame, top_n: int = 3) -> pd.DataFrame:
    if not isinstance(clustered_df, pd.DataFrame) or clustered_df.empty or "cluster" not in clustered_df.columns:
        return pd.DataFrame(columns=["cluster", "suggested_label", "size", "share_pct", "label_drivers"])

    inferred = infer_schema(clustered_df.drop(columns=["cluster"], errors="ignore"))
    fingerprints = build_cluster_fingerprints(clustered_df, inferred, WorkbenchConfig(), top_n=top_n)
    summary = fingerprints.get("summary")
    if not isinstance(summary, pd.DataFrame) or summary.empty:
        return pd.DataFrame(columns=["cluster", "suggested_label", "size", "share_pct", "label_drivers"])
    out = summary.rename(columns={"persona": "suggested_label"}).copy()
    out["label_drivers"] = (
        out["top_5_above_average"].fillna("").astype(str)
        + " | "
        + out["top_5_below_average"].fillna("").astype(str)
        + " | "
        + out["most_common_values"].fillna("").astype(str)
    )
    return out[["cluster", "suggested_label", "size", "share_pct", "label_drivers"]].sort_values("cluster", key=lambda s: s.astype(str)).reset_index(drop=True)


def render_cluster_explorer(
    pca_df: pd.DataFrame,
    clustered_df: pd.DataFrame,
    title: str,
    key_prefix: str,
    max_rows: int = 250,
) -> None:
    if not isinstance(clustered_df, pd.DataFrame) or clustered_df.empty:
        show_fig(make_cluster_plot(pca_df, title=title))
        st.info("No clustered sample rows are available for interactive inspection.")
        return

    label_table = suggest_cluster_labels(clustered_df)
    label_map = {}
    if isinstance(label_table, pd.DataFrame) and not label_table.empty:
        label_map = dict(zip(label_table["cluster"].astype(str), label_table["suggested_label"].astype(str)))

    pca_plot_df = pca_df.copy()
    if label_map and "cluster" in pca_plot_df.columns:
        pca_plot_df["cluster_label"] = pca_plot_df["cluster"].astype(str).map(lambda x: f"{x}: {label_map.get(x, 'unlabeled')}")
        plot_clustered_df = clustered_df.copy()
        plot_clustered_df["cluster_label"] = plot_clustered_df["cluster"].astype(str).map(lambda x: f"{x}: {label_map.get(x, 'unlabeled')}")
        pca_plot_df = pca_plot_df.rename(columns={"cluster": "cluster_id", "cluster_label": "cluster"})
    else:
        plot_clustered_df = clustered_df

    interactive_fig = make_interactive_cluster_plot(pca_plot_df, plot_clustered_df, title=title)
    if interactive_fig is not None:
        st.plotly_chart(interactive_fig, use_container_width=True, key=f"{key_prefix}_interactive_cluster_plot")
        st.caption("Hover any point to see the source row fields. Use the legend to isolate or hide clusters.")
    else:
        show_fig(make_cluster_plot(pca_df, title=title))
        st.caption("Install plotly to enable hoverable cluster maps: pip install plotly")

    if isinstance(label_table, pd.DataFrame) and not label_table.empty:
        st.write("**Suggested cluster labels**")
        st.dataframe(label_table, use_container_width=True)

    cluster_values = sorted(clustered_df["cluster"].dropna().unique().tolist(), key=lambda x: str(x))
    if not cluster_values:
        st.info("No cluster IDs are available for inspection.")
        return

    selected_cluster_value = st.selectbox(
        "Inspect rows in cluster",
        cluster_values,
        format_func=lambda x: f"{x}: {label_map.get(str(x), 'unlabeled')}",
        key=f"{key_prefix}_cluster_row_inspector",
    )
    cluster_rows = clustered_df[clustered_df["cluster"] == selected_cluster_value]

    st.write(f"**Rows in cluster {selected_cluster_value}**")
    st.dataframe(cluster_rows.head(max_rows), use_container_width=True)

    numeric_cols = [c for c in cluster_rows.select_dtypes(include=[np.number]).columns if c != "cluster"]
    if numeric_cols:
        st.write("**Selected-cluster numeric summary**")
        st.dataframe(cluster_rows[numeric_cols].describe().T, use_container_width=True)


def run_anomaly_scan(df: pd.DataFrame, config: WorkbenchConfig, exclude: list[str] | None = None) -> dict[str, Any] | None:
    exclude = exclude or []
    numeric_cols = [c for c in choose_numeric_columns_by_variance(df.drop(columns=exclude, errors="ignore"), config.max_unsupervised_numeric_cols) if c not in exclude]
    if len(numeric_cols) < 2 or len(df) < 20:
        return None
    sample = safe_sample_df(df[numeric_cols], config.max_anomaly_rows)
    display_df = df.loc[sample.index].copy()
    sample = sample.replace([np.inf, -np.inf], np.nan).fillna(sample.median(numeric_only=True))
    sample = sample.dropna(axis=1, how="all")
    if sample.shape[1] < 2:
        return None
    scaler = StandardScaler()
    X = scaler.fit_transform(sample)
    model = IsolationForest(contamination=0.05, random_state=42, n_estimators=100, n_jobs=-1)
    preds = model.fit_predict(X)
    scores = model.decision_function(X)
    pca = PCA(n_components=2, random_state=42)
    coords = pca.fit_transform(X)
    out = display_df.copy()
    out["anomaly_flag"] = np.where(preds == -1, "Likely anomaly", "Normal")
    out["anomaly_score"] = scores
    pca_df = pd.DataFrame({"pc1": coords[:, 0], "pc2": coords[:, 1], "cluster": out["anomaly_flag"].values})
    return {
        "anomaly_count": int((preds == -1).sum()),
        "anomaly_rate_pct": round(float((preds == -1).mean() * 100), 2),
        "scored_df": out.sort_values("anomaly_score").reset_index(drop=True),
        "pca_df": pca_df,
        "numeric_columns_used": sample.columns.tolist(),
        "sampled_rows": len(sample),
        "sampled": len(sample) < len(df),
    }


