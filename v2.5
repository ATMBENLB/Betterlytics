def recommend_date_value_columns(schema: Schema) -> tuple[str | None, str | None]:
    date_col = schema.datetime[0] if schema.datetime else None
    value_col = schema.numeric[0] if schema.numeric else None
    return date_col, value_col


def run_time_series_forecast(
    df: pd.DataFrame,
    date_col: str,
    value_col: str,
    config: WorkbenchConfig,
    frequency: str = "Auto",
    aggregation: str = "mean",
) -> dict[str, Any] | None:
    if date_col not in df.columns or value_col not in df.columns:
        return None
    temp = df[[date_col, value_col]].dropna().copy()
    if temp.empty:
        return None
    temp[date_col] = pd.to_datetime(temp[date_col], errors="coerce")
    temp[value_col] = pd.to_numeric(temp[value_col], errors="coerce")
    temp = temp.dropna().sort_values(date_col)
    if len(temp) < 10:
        return None

    if frequency == "Auto":
        date_range_days = max(1, (temp[date_col].max() - temp[date_col].min()).days)
        if date_range_days > 900:
            freq = "M"
        elif date_range_days > 120:
            freq = "W"
        else:
            freq = "D"
    else:
        freq = {"Daily": "D", "Weekly": "W", "Monthly": "M"}.get(frequency, "D")

    temp = temp.set_index(date_col)
    if aggregation == "sum":
        ts = temp[value_col].resample(freq).sum().dropna().reset_index()
    elif aggregation == "count":
        ts = temp[value_col].resample(freq).count().dropna().reset_index()
        ts = ts.rename(columns={value_col: "count"})
        value_col = "count"
    else:
        ts = temp[value_col].resample(freq).mean().dropna().reset_index()

    if len(ts) < 8:
        return None

    ts = ts.sort_values(date_col).reset_index(drop=True)
    ts["t"] = np.arange(len(ts))
    window = min(7, max(2, len(ts) // 5))
    ts["rolling_mean"] = ts[value_col].rolling(window=window, min_periods=1).mean()

    train_size = max(4, int(len(ts) * 0.8))
    train = ts.iloc[:train_size]
    test = ts.iloc[train_size:]

    def linear_fit_predict(train_df: pd.DataFrame, horizon: int) -> tuple[np.ndarray, Any]:
        model = LinearRegression()
        model.fit(train_df[["t"]], train_df[value_col])
        future_idx = np.arange(len(train_df), len(train_df) + horizon).reshape(-1, 1)
        return model.predict(future_idx), model

    candidates: list[dict[str, Any]] = []
    horizon = len(test)
    if horizon > 0:
        try:
            pred, _ = linear_fit_predict(train, horizon)
            candidates.append({"model": "Linear trend", "test_pred": pred, "MAE": float(mean_absolute_error(test[value_col], pred))})
        except Exception:
            pass
        try:
            window_ma = min(7, max(2, len(train) // 4))
            ma_value = float(train[value_col].tail(window_ma).mean())
            pred = np.repeat(ma_value, horizon)
            candidates.append({"model": f"Moving average ({window_ma})", "test_pred": pred, "MAE": float(mean_absolute_error(test[value_col], pred))})
        except Exception:
            pass
        if SimpleExpSmoothing is not None:
            try:
                fit = SimpleExpSmoothing(train[value_col].astype(float), initialization_method="estimated").fit(optimized=True)
                pred = np.asarray(fit.forecast(horizon))
                candidates.append({"model": "Simple exponential smoothing", "test_pred": pred, "MAE": float(mean_absolute_error(test[value_col], pred))})
            except Exception:
                pass
        seasonal_periods = {"D": 7, "W": 52, "M": 12}.get(freq, None)
        seasonality = "none"
        if seasonal_periods and ExponentialSmoothing is not None and len(train) >= seasonal_periods * 2 + 2:
            try:
                fit = ExponentialSmoothing(train[value_col].astype(float), trend="add", seasonal="add", seasonal_periods=seasonal_periods, initialization_method="estimated").fit(optimized=True)
                pred = np.asarray(fit.forecast(horizon))
                candidates.append({"model": f"ETS additive seasonality ({seasonal_periods})", "test_pred": pred, "MAE": float(mean_absolute_error(test[value_col], pred))})
                seasonality = f"period_{seasonal_periods}"
            except Exception:
                pass
    else:
        seasonality = "not enough holdout"

    if candidates:
        best_candidate = sorted(candidates, key=lambda x: x["MAE"])[0]
        model_used = best_candidate["model"]
        test_preds = best_candidate["test_pred"]
        backtest_metrics = {
            "model_used": model_used,
            "MAE": float(mean_absolute_error(test[value_col], test_preds)),
            "RMSE": float(math.sqrt(mean_squared_error(test[value_col], test_preds))),
            "R2": float(r2_score(test[value_col], test_preds)) if len(test) >= 2 else np.nan,
            "candidates": [{"model": c["model"], "MAE": c["MAE"]} for c in candidates],
        }
        residual_std = float(np.std(test[value_col].to_numpy() - np.asarray(test_preds))) if len(test) else float(ts[value_col].std())
    else:
        model_used = "Linear trend"
        backtest_metrics = {}
        residual_std = float(ts[value_col].std())

    horizon_future = config.forecast_periods
    if model_used.startswith("Moving average"):
        window_ma = min(7, max(2, len(ts) // 4))
        future_pred = np.repeat(float(ts[value_col].tail(window_ma).mean()), horizon_future)
    elif model_used.startswith("Simple exponential") and SimpleExpSmoothing is not None:
        try:
            fit = SimpleExpSmoothing(ts[value_col].astype(float), initialization_method="estimated").fit(optimized=True)
            future_pred = np.asarray(fit.forecast(horizon_future))
        except Exception:
            future_pred, _ = linear_fit_predict(ts, horizon_future)
            model_used = "Linear trend fallback"
    elif model_used.startswith("ETS") and ExponentialSmoothing is not None:
        seasonal_periods = {"D": 7, "W": 52, "M": 12}.get(freq, None)
        try:
            fit = ExponentialSmoothing(ts[value_col].astype(float), trend="add", seasonal="add", seasonal_periods=seasonal_periods, initialization_method="estimated").fit(optimized=True)
            future_pred = np.asarray(fit.forecast(horizon_future))
        except Exception:
            future_pred, _ = linear_fit_predict(ts, horizon_future)
            model_used = "Linear trend fallback"
    else:
        future_pred, _ = linear_fit_predict(ts, horizon_future)

    last_date = ts[date_col].iloc[-1]
    future_dates = pd.date_range(last_date, periods=config.forecast_periods + 1, freq=freq)[1:]
    forecast = pd.DataFrame({date_col: future_dates, "forecast": future_pred})
    if pd.notna(residual_std) and residual_std > 0:
        forecast["forecast_lower"] = forecast["forecast"] - 1.96 * residual_std
        forecast["forecast_upper"] = forecast["forecast"] + 1.96 * residual_std
    else:
        forecast["forecast_lower"] = np.nan
        forecast["forecast_upper"] = np.nan

    latest = float(ts[value_col].iloc[-1])
    prior = float(ts[value_col].iloc[max(0, len(ts) - 4):-1].mean()) if len(ts) > 3 else float(ts[value_col].mean())
    trend = "up" if latest > prior else "down" if latest < prior else "flat"

    return {
        "series": ts.drop(columns=["t"]),
        "forecast": forecast,
        "frequency": freq,
        "aggregation": aggregation,
        "trend": trend,
        "latest": latest,
        "reference": prior,
        "backtest_metrics": backtest_metrics,
        "model_used": model_used,
        "seasonality": seasonality,
        "date_col": date_col,
        "value_col": value_col,
    }


def make_time_forecast_plot(ts_result: dict[str, Any]):
    ts = ts_result["series"]
    forecast = ts_result["forecast"]
    date_col = ts_result["date_col"]
    value_col = ts_result["value_col"]
    fig, ax = plt.subplots(figsize=(9, 4.8))
    ax.plot(ts[date_col], ts[value_col], label="Actual")
    ax.plot(ts[date_col], ts["rolling_mean"], label="Smoothed trend")
    ax.plot(forecast[date_col], forecast["forecast"], label="Forecast")
    if "forecast_lower" in forecast.columns and "forecast_upper" in forecast.columns:
        try:
            ax.fill_between(forecast[date_col], forecast["forecast_lower"], forecast["forecast_upper"], alpha=0.15, label="Approx. uncertainty band")
        except Exception:
            pass
    ax.set_title(f"Time trend and forecast ({ts_result.get('model_used', 'model')})")
    ax.set_xlabel(date_col)
    ax.set_ylabel(value_col)
    ax.legend()
    fig.autofmt_xdate()
    fig.tight_layout()
    return fig


