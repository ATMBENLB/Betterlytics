def auto_parse_datetimes(df: pd.DataFrame) -> pd.DataFrame:
    out = df.copy()
    for col in out.columns:
        if out[col].dtype != object:
            continue
        series = out[col].dropna().astype(str)
        if len(series) < 5:
            continue
        sample = series.head(200)
        parsed_sample = pd.to_datetime(sample, errors="coerce")
        if parsed_sample.notna().mean() >= 0.8:
            parsed_full = pd.to_datetime(out[col], errors="coerce")
            if parsed_full.notna().mean() >= 0.7:
                out[col] = parsed_full
    return out


def infer_schema(df: pd.DataFrame) -> Schema:
    numeric: list[str] = []
    categorical: list[str] = []
    text: list[str] = []
    datetime_cols: list[str] = []
    boolean: list[str] = []
    id_like: list[str] = []

    n_rows = max(1, len(df))

    for col in df.columns:
        s = df[col]
        if is_probably_id(col, s):
            id_like.append(col)

        if pd.api.types.is_bool_dtype(s):
            boolean.append(col)
        elif pd.api.types.is_datetime64_any_dtype(s):
            datetime_cols.append(col)
        elif pd.api.types.is_numeric_dtype(s):
            numeric.append(col)
        else:
            non_null = s.dropna().astype(str)
            nunique = int(non_null.nunique(dropna=True))
            avg_len = float(non_null.str.len().mean()) if len(non_null) else 0.0
            unique_ratio = nunique / max(1, len(non_null)) if len(non_null) else 0.0
            looks_long = avg_len > 35
            looks_high_cardinality = nunique > max(30, min(250, int(n_rows * 0.3))) or unique_ratio > 0.5
            if looks_long or looks_high_cardinality:
                text.append(col)
            else:
                categorical.append(col)

    target_candidates: list[str] = []
    for col in numeric:
        if col in id_like:
            continue
        nunique = int(df[col].nunique(dropna=True))
        if nunique >= 5:
            target_candidates.append(col)
    for col in categorical + boolean:
        if col in id_like:
            continue
        nunique = int(df[col].nunique(dropna=True))
        if 2 <= nunique <= min(30, max(2, int(n_rows * 0.3))):
            target_candidates.append(col)

    return Schema(
        numeric=numeric,
        categorical=categorical,
        text=text,
        datetime=datetime_cols,
        boolean=boolean,
        id_like=id_like,
        target_candidates=target_candidates,
    )


def basic_profile(df: pd.DataFrame) -> dict[str, Any]:
    numeric_cols = df.select_dtypes(include=[np.number]).columns.tolist()
    categorical_cols = [
        c for c in df.columns
        if not pd.api.types.is_numeric_dtype(df[c]) and not pd.api.types.is_datetime64_any_dtype(df[c])
    ]

    cat_summary = pd.DataFrame()
    if categorical_cols:
        rows: list[dict[str, Any]] = []
        for c in categorical_cols:
            mode = df[c].mode(dropna=True)
            rows.append({
                "column": c,
                "unique_values": int(df[c].nunique(dropna=True)),
                "top_example": mode.iloc[0] if not mode.empty else np.nan,
                "top_count": int((df[c] == mode.iloc[0]).sum()) if not mode.empty else 0,
            })
        cat_summary = pd.DataFrame(rows).sort_values("unique_values", ascending=False)

    return {
        "shape": df.shape,
        "duplicate_rows": int(df.duplicated().sum()),
        "memory_mb": float(df.memory_usage(deep=True).sum() / 1_000_000),
        "missing": df.isna().sum().sort_values(ascending=False),
        "missing_pct": (df.isna().mean() * 100).sort_values(ascending=False),
        "numeric_summary": df[numeric_cols].describe().T if numeric_cols else pd.DataFrame(),
        "categorical_summary": cat_summary,
    }


def dataset_health_report(df: pd.DataFrame, schema: Schema) -> pd.DataFrame:
    rows: list[dict[str, Any]] = []
    role_map = {c: "numeric" for c in schema.numeric}
    role_map.update({c: "categorical" for c in schema.categorical})
    role_map.update({c: "text" for c in schema.text})
    role_map.update({c: "datetime" for c in schema.datetime})
    role_map.update({c: "boolean" for c in schema.boolean})

    for col in df.columns:
        non_null = df[col].dropna()
        nunique = int(df[col].nunique(dropna=True))
        rows.append({
            "column": col,
            "detected_role": role_map.get(col, "unknown"),
            "dtype": str(df[col].dtype),
            "missing_pct": round(float(df[col].isna().mean() * 100), 2),
            "unique_values": nunique,
            "unique_pct": round(float(nunique / max(1, len(non_null)) * 100), 2) if len(non_null) else 0.0,
            "id_like": col in schema.id_like,
            "sample": None if non_null.empty else str(non_null.iloc[0])[:80],
        })
    return pd.DataFrame(rows).sort_values(["missing_pct", "unique_values"], ascending=[False, False])


def health_flags(df: pd.DataFrame, schema: Schema) -> list[str]:
    flags: list[str] = []
    duplicate_rows = int(df.duplicated().sum())
    if duplicate_rows > 0:
        flags.append(f"{duplicate_rows:,} duplicate rows found")
    if float(df.isna().mean().mean()) > 0.15:
        flags.append("overall missingness is elevated")
    constant_cols = [c for c in df.columns if df[c].nunique(dropna=True) <= 1]
    if constant_cols:
        flags.append(f"{len(constant_cols)} constant or near-empty columns found")
    if len(schema.numeric) < 2:
        flags.append("very limited numeric signal")
    if len(df) < 50:
        flags.append("small sample size")
    if schema.id_like:
        flags.append(f"{len(schema.id_like)} ID-like columns detected; these are usually poor modeling features")
    return flags


def target_recommendations(df: pd.DataFrame, schema: Schema) -> pd.DataFrame:
    rows: list[dict[str, Any]] = []
    keywords = [
        "target", "label", "outcome", "response", "sales", "revenue", "conversion",
        "profit", "price", "score", "churn", "delay", "cost", "demand", "rating",
        "win", "loss", "status", "risk", "fraud", "forecast",
    ]
    for col in schema.target_candidates:
        score = 0.0
        reasons: list[str] = []
        low = col.lower()
        if any(k in low for k in keywords):
            score += 2.5
            reasons.append("name looks outcome-like")
        missing = float(df[col].isna().mean())
        if missing < 0.05:
            score += 1.5
            reasons.append("very low missingness")
        elif missing < 0.15:
            score += 0.8
            reasons.append("usable missingness")
        nunique = int(df[col].nunique(dropna=True))
        if col in schema.numeric and nunique >= 10:
            score += 1.5
            reasons.append("good numeric spread")
        elif col not in schema.numeric and 2 <= nunique <= 10:
            score += 1.5
            reasons.append("good class count")
        if col in schema.id_like:
            score -= 3.0
            reasons.append("ID-like column")
        rows.append({"column": col, "score": round(score, 2), "unique_values": nunique, "missing_pct": round(missing * 100, 2), "why": ", ".join(reasons)})
    out = pd.DataFrame(rows)
    if out.empty:
        return out
    return out.sort_values(["score", "column"], ascending=[False, True]).reset_index(drop=True)


