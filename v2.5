def timed_step(run_log: list[dict[str, Any]], step: str, func: Callable[[], Any], **meta: Any) -> Any:
    start = time.perf_counter()
    status = "Completed"
    reason = ""
    try:
        return func()
    except Exception as exc:
        status = "Failed"
        reason = str(exc)
        raise
    finally:
        run_log.append({
            "step": step,
            "status": status,
            "seconds": round(time.perf_counter() - start, 2),
            **meta,
            "reason": reason,
        })


def run_selected_scan(
    df: pd.DataFrame,
    schema: Schema,
    profile: dict[str, Any],
    flags: list[str],
    config: WorkbenchConfig,
    selected_modules: dict[str, bool],
    target: str | None,
    selected_models: list[str],
    problem_override: str,
    test_size: float,
    include_text_feature: bool,
    model_text_col: str | None,
    text_col: str | None,
    date_col: str | None,
    value_col: str | None,
    time_frequency: str,
    time_aggregation: str,
    kmeans_auto_k: bool,
    kmeans_k: int,
    clustering_method: str,
    cluster_compare_methods: list[str],
    cluster_compare_min_k: int,
    cluster_compare_max_k: int,
    grouped_metric: str | None,
    pivot_row: str | None,
    pivot_col: str | None,
    pivot_value: str | None,
    pivot_agg: str,
    stat_metric: str | None,
    stat_group: str | None,
    lat_col: str | None,
    lon_col: str | None,
    reference_lat: float | None = None,
    reference_lon: float | None = None,
    clean_remove_duplicates: bool = True,
    clean_drop_empty_cols: bool = True,
    clean_convert_numeric_text: bool = True,
    clean_normalize_categories: bool = True,
    clean_impute_missing: bool = False,
    clean_winsorize_outliers: bool = False,
) -> dict[str, Any]:
    run_log: list[dict[str, Any]] = []
    scan: dict[str, Any] = {
        "profile": profile,
        "health_flags": flags,
        "schema": asdict(schema),
        "config": asdict(config),
        "selected_modules": selected_modules,
    }

    active_steps = [k for k, v in selected_modules.items() if v]
    total_steps = max(1, len(active_steps))
    progress = st.progress(0, text="Starting selected betterlytics modules...")
    step_idx = 0

    def bump(label: str) -> None:
        nonlocal step_idx
        step_idx += 1
        pct = min(98, int(step_idx / total_steps * 100))
        progress.progress(pct, text=label)

    if selected_modules.get("data_quality"):
        bump("Scoring data quality...")
        scan["data_quality"] = timed_step(run_log, "Data quality score", lambda: data_quality_score(df, schema))

    if selected_modules.get("cleaning"):
        bump("Preparing cleaned data version...")
        scan["cleaning"] = timed_step(
            run_log,
            "Clean My Data",
            lambda: clean_dataset(
                df,
                schema,
                config,
                remove_duplicates=clean_remove_duplicates,
                drop_empty_cols=clean_drop_empty_cols,
                convert_numeric_text=clean_convert_numeric_text,
                normalize_categories=clean_normalize_categories,
                impute_missing=clean_impute_missing,
                winsorize_outliers=clean_winsorize_outliers,
            ),
        )

    if selected_modules.get("feature_engineering"):
        bump("Creating engineered feature preview...")
        scan["feature_engineering"] = timed_step(run_log, "Feature engineering", lambda: create_engineered_features(df, schema, config))

    if selected_modules.get("eda"):
        bump("Building EDA summary...")
        scan["eda"] = timed_step(run_log, "EDA summary", lambda: build_eda_summary(df, schema, profile, flags))

    if selected_modules.get("missingness"):
        bump("Calculating missingness report...")
        scan["missingness"] = timed_step(run_log, "Missingness report", lambda: missingness_report(df))

    if selected_modules.get("correlation"):
        bump("Finding correlations and building heatmap data...")
        scan["correlations"] = timed_step(run_log, "Correlations", lambda: strongest_correlations(df, config))

    if selected_modules.get("distribution"):
        bump("Analyzing numeric distributions and outliers...")
        scan["distribution"] = timed_step(run_log, "Distribution analysis", lambda: run_distribution_analysis(df, schema, config))

    if selected_modules.get("pivot"):
        bump("Building pivot table...")
        scan["pivot"] = timed_step(run_log, "Pivot builder", lambda: build_pivot_table(df, pivot_row, pivot_col, pivot_value, pivot_agg, config))

    if selected_modules.get("stat_tests"):
        bump("Running statistical tests...")
        scan["stat_tests"] = timed_step(run_log, "Statistical tests", lambda: run_statistical_tests(df, schema, stat_metric, stat_group, target, config))

    if selected_modules.get("leakage_checks"):
        bump("Checking target leakage risks...")
        scan["leakage_checks"] = timed_step(run_log, "Leakage checks", lambda: run_leakage_checks(df, schema, target))

    if selected_modules.get("kpi_detection"):
        bump("Detecting KPI-like fields...")
        scan["kpis"] = timed_step(run_log, "KPI detector", lambda: detect_kpis(df, schema))

    if selected_modules.get("module_recommender"):
        bump("Recommending useful modules...")
        scan["module_recommendations"] = timed_step(run_log, "Module recommender", lambda: recommend_modules_for_dataset(df, schema))

    if selected_modules.get("modeling"):
        if target and selected_models:
            bump(f"Training supervised models for {target}...")
            try:
                scan["modeling"] = timed_step(
                    run_log,
                    "Supervised modeling",
                    lambda: train_supervised_models(
                        df,
                        target,
                        selected_models,
                        config,
                        test_size=test_size,
                        include_text_feature=include_text_feature,
                        text_feature=model_text_col,
                        problem_override=problem_override,
                    ),
                    target=target,
                    models=", ".join(selected_models),
                )
            except Exception:
                scan["modeling"] = None
        else:
            scan["modeling"] = None
            run_log.append({"step": "Supervised modeling", "status": "Skipped", "seconds": 0.0, "reason": "No target or no models selected"})

    if selected_modules.get("classification_diagnostics"):
        modeling_obj = scan.get("modeling")
        if modeling_obj and modeling_obj.get("problem_type") == "classification":
            run_log.append({"step": "Classification diagnostics", "status": "Completed", "seconds": 0.0, "reason": "Report and confusion matrix are produced with classifier metrics"})
        else:
            run_log.append({"step": "Classification diagnostics", "status": "Skipped", "seconds": 0.0, "reason": "Requires a completed classification model"})

    if selected_modules.get("feature_importance"):
        bump("Extracting model drivers where supported...")
        scan["feature_importance"] = timed_step(run_log, "Feature importance", lambda: extract_model_drivers(scan.get("modeling"), top_n=20))

    if selected_modules.get("model_diagnostics"):
        bump("Building model validation diagnostics...")
        scan["model_diagnostics"] = timed_step(run_log, "Model diagnostics", lambda: run_model_diagnostics(scan.get("modeling"), df, schema, group_col=stat_group))

    if selected_modules.get("permutation_importance"):
        bump("Calculating permutation importance...")
        scan["permutation_importance"] = timed_step(run_log, "Permutation importance", lambda: run_permutation_importance_scan(scan.get("modeling"), config))

    if selected_modules.get("partial_dependence"):
        bump("Building what-if response curves...")
        scan["partial_dependence"] = timed_step(run_log, "What-if response curves", lambda: run_partial_dependence_lite(scan.get("modeling"), df, config))

    if selected_modules.get("clustering"):
        bump(f"Running {clustering_method} clustering and PCA map...")
        exclude = [target] if target else []
        try:
            scan["clustering"] = timed_step(run_log, f"{clustering_method} clustering", lambda: run_cluster_scan(df, config, method=clustering_method, exclude=exclude, auto_k=kmeans_auto_k, selected_k=kmeans_k))
            scan["cluster_profiles"] = build_cluster_profiles(scan.get("clustering"))
            if scan.get("clustering") and isinstance(scan["clustering"].get("clustered_df"), pd.DataFrame):
                scan["cluster_fingerprints"] = build_cluster_fingerprints(
                    scan["clustering"]["clustered_df"],
                    schema,
                    config,
                    numeric_cols=scan["clustering"].get("numeric_columns_used"),
                )
            else:
                scan["cluster_fingerprints"] = {"summary": pd.DataFrame(), "details": {}, "label_map": {}}
        except Exception:
            scan["clustering"] = None
            scan["cluster_profiles"] = pd.DataFrame()
            scan["cluster_fingerprints"] = {"summary": pd.DataFrame(), "details": {}, "label_map": {}}

    if selected_modules.get("clustering_comparison"):
        bump("Comparing clustering solutions...")
        exclude = [target] if target else []
        try:
            scan["clustering_comparison"] = timed_step(
                run_log,
                "Clustering comparison",
                lambda: run_clustering_comparison(
                    df,
                    schema,
                    config,
                    exclude=exclude,
                    target=target,
                    methods=cluster_compare_methods,
                    min_k=cluster_compare_min_k,
                    max_k=cluster_compare_max_k,
                ),
                methods=", ".join(cluster_compare_methods),
                k_range=f"{cluster_compare_min_k}-{cluster_compare_max_k}",
            )
        except Exception:
            scan["clustering_comparison"] = None

    if selected_modules.get("anomaly"):
        bump("Running anomaly detection...")
        exclude = [target] if target else []
        try:
            scan["anomaly"] = timed_step(run_log, "Anomaly detection", lambda: run_anomaly_scan(df, config, exclude=exclude))
        except Exception:
            scan["anomaly"] = None

    if selected_modules.get("anomaly_explanations"):
        bump("Explaining anomaly drivers...")
        scan["anomaly_explanations"] = timed_step(run_log, "Anomaly explanations", lambda: explain_anomalies(scan.get("anomaly")))

    if selected_modules.get("text"):
        if text_col:
            bump(f"Scanning text patterns in {text_col}...")
            try:
                scan["text"] = timed_step(run_log, "Text analytics", lambda: run_text_scan(df, text_col, config), text_col=text_col)
                scan["text_col"] = text_col
            except Exception:
                scan["text"] = None
        else:
            scan["text"] = None
            run_log.append({"step": "Text analytics", "status": "Skipped", "seconds": 0.0, "reason": "No text column selected"})

    if selected_modules.get("nlp_topics"):
        if text_col:
            bump("Extracting NLP topics and complaint signals...")
            scan["nlp_topics"] = timed_step(run_log, "NLP topics", lambda: run_nlp_topics(df, text_col, config), text_col=text_col)
        else:
            scan["nlp_topics"] = None
            run_log.append({"step": "NLP topics", "status": "Skipped", "seconds": 0.0, "reason": "No text column selected"})

    if selected_modules.get("time_series"):
        if date_col and value_col:
            bump(f"Forecasting {value_col} over {date_col}...")
            try:
                scan["time_series"] = timed_step(
                    run_log,
                    "Time-series forecast",
                    lambda: run_time_series_forecast(df, date_col, value_col, config, frequency=time_frequency, aggregation=time_aggregation),
                    date_col=date_col,
                    value_col=value_col,
                )
            except Exception:
                scan["time_series"] = None
        else:
            scan["time_series"] = None
            run_log.append({"step": "Time-series forecast", "status": "Skipped", "seconds": 0.0, "reason": "No date/value pair selected"})

    if selected_modules.get("time_anomalies"):
        bump("Checking time-series anomalies...")
        scan["time_anomalies"] = timed_step(run_log, "Time-series anomalies", lambda: run_time_series_anomaly_scan(scan.get("time_series")))

    if selected_modules.get("grouped_insights"):
        bump("Finding grouped standout differences...")
        scan["grouped_insights"] = timed_step(run_log, "Grouped insights", lambda: run_grouped_insights(df, schema, grouped_metric, config))

    if selected_modules.get("geospatial"):
        if lat_col and lon_col:
            bump("Preparing map data...")
            scan["map_data"] = timed_step(run_log, "Geospatial map", lambda: build_map_data(df, lat_col, lon_col, config), lat_col=lat_col, lon_col=lon_col)
            scan["lat_col"] = lat_col
            scan["lon_col"] = lon_col
        else:
            scan["map_data"] = pd.DataFrame()
            run_log.append({"step": "Geospatial map", "status": "Skipped", "seconds": 0.0, "reason": "No latitude/longitude pair selected"})

    if selected_modules.get("geospatial_summary"):
        bump("Summarizing geographic spread...")
        scan["geospatial_summary"] = timed_step(run_log, "Geospatial summary", lambda: run_geospatial_summary(df, lat_col, lon_col, config, reference_lat=reference_lat, reference_lon=reference_lon))

    if selected_modules.get("domain_insights"):
        bump("Detecting domain-specific signals...")
        scan["domain_insights"] = timed_step(run_log, "Domain insight detector", lambda: detect_domain_insights(df, schema))

    if selected_modules.get("auto_insights"):
        bump("Detecting decision-grade insights...")
        scan["auto_insights"] = timed_step(run_log, "Auto insight detector", lambda: detect_auto_insights(df, schema, scan, config))

    if selected_modules.get("decision_recommendations"):
        bump("Creating decision recommendations...")
        scan["decision_engine"] = timed_step(run_log, "Decision recommendations", lambda: generate_decision_recommendations(scan))

    scan["narrative"] = create_narrative(scan)
    if selected_modules.get("report_builder"):
        scan["markdown_report"] = build_markdown_report(scan, config)
        scan["html_report"] = markdown_to_simple_html(scan["markdown_report"])
        run_log.append({"step": "Report builder", "status": "Completed", "seconds": 0.0, "reason": "Markdown and HTML reports generated"})
    scan["run_log"] = run_log
    progress.progress(100, text="Selected betterlytics modules completed.")
    return scan


def safe_json(scan: dict[str, Any], config: WorkbenchConfig) -> str:
    out: dict[str, Any] = {
        "profile": {
            "shape": scan.get("profile", {}).get("shape"),
            "duplicate_rows": scan.get("profile", {}).get("duplicate_rows"),
            "memory_mb": scan.get("profile", {}).get("memory_mb"),
        },
        "schema": scan.get("schema"),
        "health_flags": scan.get("health_flags", []),
        "selected_modules": scan.get("selected_modules", {}),
        "narrative": scan.get("narrative"),
        "run_log": scan.get("run_log", []),
    }
    if scan.get("data_quality"):
        out["data_quality"] = scan.get("data_quality")
    if scan.get("cleaning"):
        cleaning = scan["cleaning"]
        out["cleaning"] = {
            "steps": cleaning.get("steps", []),
            "before_shape": cleaning.get("before_shape"),
            "after_shape": cleaning.get("after_shape"),
            "quality_before": cleaning.get("quality_before"),
            "quality_after": cleaning.get("quality_after"),
        }
    if scan.get("feature_engineering"):
        out["feature_engineering"] = {"created_features": scan["feature_engineering"].get("created_features", [])}
    if isinstance(scan.get("distribution"), pd.DataFrame):
        out["distribution"] = records(scan["distribution"], config.json_table_rows)
    if isinstance(scan.get("pivot"), pd.DataFrame):
        out["pivot"] = records(scan["pivot"], config.json_table_rows)
    if scan.get("stat_tests"):
        out["stat_tests"] = records(scan["stat_tests"].get("results"), config.json_table_rows)
