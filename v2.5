def finalize_loaded_dataframe(df: pd.DataFrame) -> pd.DataFrame:
    df = df.copy()
    df.columns = dedupe_column_names([clean_column_name(c) for c in df.columns])
    for col in df.columns:
        if df[col].dtype == object:
            df[col] = df[col].astype(str).str.strip()
            df[col] = df[col].replace({"": np.nan, "nan": np.nan, "None": np.nan, "null": np.nan, "NaN": np.nan, "N/A": np.nan, "na": np.nan})
    return auto_parse_datetimes(df)


def _read_csv_bytes(raw_bytes: bytes) -> pd.DataFrame:
    attempts = [
        {"sep": None, "engine": "python", "encoding": "utf-8"},
        {"sep": ",", "engine": "python", "encoding": "utf-8"},
        {"sep": None, "engine": "python", "encoding": "latin-1"},
    ]
    last_exc: Exception | None = None
    for kwargs in attempts:
        try:
            df = pd.read_csv(io.BytesIO(raw_bytes), **kwargs)
            if df.shape[1] >= 1:
                return df
        except Exception as exc:
            last_exc = exc
    raise last_exc or ValueError("Could not read CSV")


def _read_json_bytes(raw_bytes: bytes) -> pd.DataFrame:
    text = raw_bytes.decode("utf-8", errors="replace")
    try:
        return pd.read_json(io.StringIO(text))
    except ValueError:
        data = json.loads(text)
        if isinstance(data, dict):
            # Try common wrappers first, then fall back to one-row dict.
            for key in ["data", "records", "rows", "items", "results"]:
                if isinstance(data.get(key), list):
                    return pd.DataFrame(data[key])
            return pd.json_normalize(data)
        return pd.DataFrame(data)


def _read_zip_bytes(raw_bytes: bytes) -> pd.DataFrame:
    supported = (".csv", ".xlsx", ".xls", ".json", ".parquet")
    with zipfile.ZipFile(io.BytesIO(raw_bytes)) as zf:
        names = [n for n in zf.namelist() if not n.endswith("/") and n.lower().endswith(supported)]
        if not names:
            raise ValueError("ZIP file does not contain a supported table file: CSV, Excel, JSON, or Parquet.")
        name = names[0]
        return load_tabular_data(zf.read(name), name)


@st.cache_data(show_spinner=False)
def load_tabular_data(raw_bytes: bytes, file_name: str = "uploaded.csv") -> pd.DataFrame:
    suffix = file_name.lower().split("?")[0]
    if suffix.endswith(".zip"):
        df = _read_zip_bytes(raw_bytes)
    elif suffix.endswith((".xlsx", ".xls")):
        df = pd.read_excel(io.BytesIO(raw_bytes), sheet_name=0)
    elif suffix.endswith(".parquet"):
        df = pd.read_parquet(io.BytesIO(raw_bytes))
    elif suffix.endswith(".json"):
        df = _read_json_bytes(raw_bytes)
    else:
        df = _read_csv_bytes(raw_bytes)
    return finalize_loaded_dataframe(df)


@st.cache_data(show_spinner=False)
def load_tabular_url(url: str) -> pd.DataFrame:
    if not url:
        raise ValueError("No URL provided")
    parsed = urlparse(url)
    if not parsed.scheme:
        raise ValueError("URL must include http:// or https://")
    # Google Sheets shared URLs usually need export?format=csv.
    if "docs.google.com" in parsed.netloc and "/spreadsheets/" in parsed.path and "export" not in url:
        match = re.search(r"/spreadsheets/d/([^/]+)", url)
        if match:
            url = f"https://docs.google.com/spreadsheets/d/{match.group(1)}/export?format=csv"
    df = pd.read_csv(url)
    return finalize_loaded_dataframe(df)


