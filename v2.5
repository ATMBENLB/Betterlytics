            "worst_errors": records(scan["model_diagnostics"].get("worst_errors"), config.json_table_rows),
        }
    elif isinstance(scan.get("model_diagnostics"), dict):
        out["model_diagnostics"] = {
            "best_model": scan["model_diagnostics"].get("best_model"),
            "problem_type": scan["model_diagnostics"].get("problem_type"),
            "class_balance": records(scan["model_diagnostics"].get("class_balance"), config.json_table_rows),
            "roc_auc": scan["model_diagnostics"].get("roc_auc"),
            "pr_auc": scan["model_diagnostics"].get("pr_auc"),
        }
    if isinstance(scan.get("permutation_importance"), pd.DataFrame):
        out["permutation_importance"] = records(scan["permutation_importance"], config.json_table_rows)
    if isinstance(scan.get("partial_dependence"), pd.DataFrame):
