def build_eda_summary(df: pd.DataFrame, schema: Schema, profile: dict[str, Any], flags: list[str]) -> dict[str, Any]:
    type_counts = pd.DataFrame([
        {"role": "numeric", "columns": len(schema.numeric)},
        {"role": "categorical", "columns": len(schema.categorical)},
        {"role": "text", "columns": len(schema.text)},
        {"role": "datetime", "columns": len(schema.datetime)},
        {"role": "boolean", "columns": len(schema.boolean)},
        {"role": "ID-like", "columns": len(schema.id_like)},
    ])
    constant_cols = [c for c in df.columns if df[c].nunique(dropna=True) <= 1]
    top_missing = pd.DataFrame({
        "column": profile["missing_pct"].index,
        "missing_pct": profile["missing_pct"].values,
    }).head(25)
    return {
        "type_counts": type_counts,
        "constant_columns": constant_cols,
        "top_missing": top_missing,
        "numeric_summary": profile.get("numeric_summary", pd.DataFrame()),
        "categorical_summary": profile.get("categorical_summary", pd.DataFrame()),
        "health_flags": flags,
    }


def make_missing_plot(df: pd.DataFrame):
    miss = (df.isna().mean() * 100).sort_values(ascending=False).head(30)
    fig, ax = plt.subplots(figsize=(9, 4.5))
    if miss.empty:
        ax.text(0.5, 0.5, "No columns found", ha="center", va="center")
        ax.axis("off")
        return fig
    miss.plot(kind="bar", ax=ax)
    ax.set_ylabel("Missing %")
    ax.set_title("Top missing-value columns")
    fig.tight_layout()
    return fig


def missingness_report(df: pd.DataFrame) -> pd.DataFrame:
    out = pd.DataFrame({
        "column": df.columns,
        "missing_count": [int(df[c].isna().sum()) for c in df.columns],
        "missing_pct": [round(float(df[c].isna().mean() * 100), 2) for c in df.columns],
        "non_missing_count": [int(df[c].notna().sum()) for c in df.columns],
    })
    return out.sort_values("missing_pct", ascending=False).reset_index(drop=True)


def strongest_correlations(df: pd.DataFrame, config: WorkbenchConfig, top_n: int = 20) -> pd.DataFrame:
    num_cols = choose_numeric_columns_by_variance(df, config.max_corr_cols)
    num = df[num_cols].copy() if num_cols else pd.DataFrame()
    if num.shape[1] < 2:
        return pd.DataFrame(columns=["feature_1", "feature_2", "correlation", "strength"])

    corr = num.corr(numeric_only=True)
    pairs: list[dict[str, Any]] = []
    cols = corr.columns.tolist()
    for i, c1 in enumerate(cols):
        for c2 in cols[i + 1:]:
            value = corr.loc[c1, c2]
            if pd.notna(value):
                strength = abs(float(value))
                pairs.append({
                    "feature_1": c1,
                    "feature_2": c2,
                    "correlation": round(float(value), 4),
                    "strength": round(strength, 4),
                })
    if not pairs:
        return pd.DataFrame(columns=["feature_1", "feature_2", "correlation", "strength"])
    return pd.DataFrame(pairs).sort_values("strength", ascending=False).head(top_n).reset_index(drop=True)


def make_corr_plot(df: pd.DataFrame, config: WorkbenchConfig):
    num_cols = choose_numeric_columns_by_variance(df, config.max_corr_cols)
    num = df[num_cols].copy() if num_cols else pd.DataFrame()
    fig, ax = plt.subplots(figsize=(8.5, 6))
    if num.shape[1] < 2:
        ax.text(0.5, 0.5, "Need at least 2 numeric columns", ha="center", va="center")
        ax.axis("off")
        return fig

    corr = num.corr(numeric_only=True)
    im = ax.imshow(corr, aspect="auto")
    ax.set_title("Correlation heatmap")
    ax.set_xticks(range(len(corr.columns)))
    ax.set_yticks(range(len(corr.index)))
    if len(corr.columns) <= 30:
        ax.set_xticklabels(corr.columns, rotation=90)
        ax.set_yticklabels(corr.index)
    else:
        ax.set_xticklabels([])
        ax.set_yticklabels([])
        ax.set_xlabel(f"{len(corr.columns)} numeric columns shown; labels hidden for readability")
    fig.colorbar(im, ax=ax)
    fig.tight_layout()
    return fig


def make_numeric_distribution_plot(df: pd.DataFrame, column: str):
    values = pd.to_numeric(df[column], errors="coerce").dropna()
    fig, ax = plt.subplots(figsize=(7, 4))
    if values.empty:
        ax.text(0.5, 0.5, "No numeric data", ha="center", va="center")
        ax.axis("off")
        return fig
    values = values.sample(min(len(values), 20000), random_state=42) if len(values) > 20000 else values
    ax.hist(values, bins=30)
    ax.set_title(f"Distribution of {column}")
    ax.set_xlabel(column)
    ax.set_ylabel("Count")
    fig.tight_layout()
    return fig


def make_correlation_network_plot(correlations: pd.DataFrame, min_strength: float = 0.45, max_edges: int = 30):
    if go is None or not isinstance(correlations, pd.DataFrame) or correlations.empty:
        return None
    edges = correlations[correlations["strength"] >= min_strength].head(max_edges).copy()
    if edges.empty:
        edges = correlations.head(min(max_edges, len(correlations))).copy()
    nodes = sorted(set(edges["feature_1"].astype(str)).union(set(edges["feature_2"].astype(str))))
    if len(nodes) < 2:
        return None
    angles = np.linspace(0, 2 * np.pi, len(nodes), endpoint=False)
    positions = {node: (float(np.cos(a)), float(np.sin(a))) for node, a in zip(nodes, angles)}

    edge_x: list[float | None] = []
    edge_y: list[float | None] = []
    edge_text: list[str] = []
    for _, row in edges.iterrows():
        x0, y0 = positions[str(row["feature_1"])]
        x1, y1 = positions[str(row["feature_2"])]
        edge_x += [x0, x1, None]
        edge_y += [y0, y1, None]
        edge_text.append(f"{row['feature_1']} to {row['feature_2']}: r={safe_float(row['correlation']):.2f}")

    node_x = [positions[n][0] for n in nodes]
    node_y = [positions[n][1] for n in nodes]
    degree = {n: int((edges["feature_1"].astype(str).eq(n) | edges["feature_2"].astype(str).eq(n)).sum()) for n in nodes}
    fig = go.Figure()
    fig.add_trace(go.Scatter(
        x=edge_x,
        y=edge_y,
        mode="lines",
        line={"width": 1.5, "color": "rgba(80, 80, 80, 0.35)"},
        hoverinfo="none",
        showlegend=False,
    ))
    fig.add_trace(go.Scatter(
        x=node_x,
        y=node_y,
        mode="markers+text",
        text=[prettify_feature_name(n)[:24] for n in nodes],
        textposition="top center",
        marker={"size": [12 + degree[n] * 4 for n in nodes], "color": [degree[n] for n in nodes], "colorscale": "Viridis", "showscale": True, "colorbar": {"title": "Links"}},
        hovertext=[f"{n}<br>{degree[n]} strong relationship(s)" for n in nodes],
        hoverinfo="text",
        showlegend=False,
    ))
    fig.update_layout(
        title="Correlation network map",
        height=560,
        xaxis={"visible": False},
        yaxis={"visible": False},
        margin={"l": 10, "r": 10, "t": 50, "b": 10},
    )
    return fig


def make_feature_importance_plotly(drivers: pd.DataFrame):
