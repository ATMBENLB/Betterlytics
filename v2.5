def priority_from_score(score: float) -> str:
    if score >= 8:
        return "High"
    if score >= 5:
        return "Medium"
    return "Low"


def confidence_label(conf: float) -> str:
    if conf >= 0.8:
        return "High"
    if conf >= 0.6:
        return "Moderate"
    return "Low"


def safe_float(value: Any, default: float = 0.0) -> float:
    try:
        if pd.isna(value):
            return default
        return float(value)
    except Exception:
        return default


def generate_decision_recommendations(scan: dict[str, Any]) -> dict[str, Any]:
    decisions: list[Decision] = []
    risks: list[str] = list(scan.get("health_flags", []))
    opportunities: list[str] = []

    modeling = scan.get("modeling")
    if modeling and isinstance(modeling.get("leaderboard"), pd.DataFrame) and not modeling["leaderboard"].empty:
        leader = modeling["leaderboard"].iloc[0]
        problem_type = modeling.get("problem_type")
        model_name = leader["model"]
        drivers = extract_model_drivers(modeling, top_n=5)
        top_driver = drivers.iloc[0]["feature"] if not drivers.empty and not drivers["importance"].isna().all() else None
        if problem_type == "classification":
            acc = safe_float(leader.get("Accuracy"))
            rationale = f"The best classifier was {model_name} with accuracy {acc:.2f}."
            if top_driver:
                rationale += f" The strongest modeled driver appears to be {top_driver}."
            decisions.append(Decision(
                title=f"Use {model_name} as a scoring layer after validation",
                category="Predictive modeling",
                priority=priority_from_score(acc * 10),
                confidence=min(0.95, max(0.3, acc)),
                estimated_impact="Can improve prioritization, routing, targeting, or risk flagging.",
                rationale=rationale,
                risk="Validate class balance, leakage, and false positive / false negative costs before automation.",
                action_steps=["Validate on fresh data", "Inspect misclassifications", "Use scores for ranking before full automation"],
            ))
            opportunities.append("A supervised classification signal is available for prioritization experiments.")
        else:
            r2 = safe_float(leader.get("R2"))
            rationale = f"The best regressor was {model_name} with R² {r2:.2f}."
            if top_driver:
                rationale += f" The strongest modeled driver appears to be {top_driver}."
            decisions.append(Decision(
                title=f"Use {model_name} for directional forecasting or what-if planning",
                category="Predictive modeling",
                priority=priority_from_score(max(0, r2) * 10),
                confidence=min(0.95, max(0.3, 0.5 + r2 * 0.5)),
                estimated_impact="Can support planning, estimation, pricing, staffing, or demand analysis.",
                rationale=rationale,
                risk="Treat as directional until performance is stable on later or external data.",
                action_steps=["Backtest on later data", "Stress-test edge cases", "Use drivers for scenario planning"],
            ))
            opportunities.append("A regression signal is available for forecasting or what-if experiments.")

    corr = scan.get("correlations")
    if isinstance(corr, pd.DataFrame) and not corr.empty:
        top_corr = corr.iloc[0]
        strength = safe_float(top_corr.get("strength"))
        if strength >= 0.55:
            decisions.append(Decision(
                title=f"Investigate the {top_corr['feature_1']} / {top_corr['feature_2']} relationship",
                category="Driver analysis",
                priority=priority_from_score(strength * 10),
                confidence=min(0.9, 0.45 + strength * 0.5),
                estimated_impact="Potentially high if one variable is controllable and the relationship is not leakage.",
                rationale=f"These variables have correlation {safe_float(top_corr.get('correlation')):.2f}, the strongest numeric relationship found.",
                risk="Correlation can reflect leakage, coincidence, or a shared third factor.",
                action_steps=["Check leakage", "Test subgroup stability", "Review whether either variable is actionable"],
            ))
            opportunities.append("A strong numeric relationship is available for deeper driver analysis.")

    clustering = scan.get("clustering")
    if clustering:
        silhouette = safe_float(clustering.get("silhouette"))
        k = clustering.get("k")
        if k and silhouette >= 0.2:
            decisions.append(Decision(
                title=f"Profile and name the {k} discovered segments",
                category="Segmentation",
                priority=priority_from_score(silhouette * 20),
                confidence=min(0.9, 0.4 + silhouette),
                estimated_impact="Can improve routing, targeting, retention, operations, or differentiated strategies.",
                rationale=f"KMeans found {k} groups with silhouette {silhouette:.2f}.",
                risk="Clusters are mathematical groups, not automatically business segments.",
                action_steps=["Profile each cluster", "Compare outcomes by cluster", "Test differentiated actions"],
            ))
            opportunities.append("The dataset appears segmentable enough to inspect cluster-specific strategies.")

    anomaly = scan.get("anomaly")
    if anomaly and int(anomaly.get("anomaly_count", 0)) > 0:
        count = int(anomaly.get("anomaly_count", 0))
        decisions.append(Decision(
            title="Review unusual records before relying on automated conclusions",
            category="Risk control",
            priority=priority_from_score(min(10, 4 + count / 5)),
            confidence=0.75,
            estimated_impact="Can prevent distorted models, bad reporting, and missed high-value edge cases.",
            rationale=f"The anomaly scan flagged {count:,} unusual records in the sampled analysis set.",
            risk="Anomalies may be errors, rare events, fraud, or valuable exceptions.",
            action_steps=["Inspect top anomalies", "Separate errors from true edge cases", "Decide whether to exclude, cap, or monitor separately"],
        ))
        risks.append(f"{count:,} anomalous records warrant manual review.")

    ts = scan.get("time_series")
    if ts:
        trend = ts.get("trend", "flat")
        decisions.append(Decision(
            title=f"Monitor the current {trend} trend in {ts.get('value_col', 'the metric')}",
            category="Forecasting",
            priority="High" if trend == "down" else "Medium",
            confidence=0.65,
            estimated_impact="Supports earlier reaction to movement in demand, costs, performance, delays, or output.",
            rationale=f"The time-series module shows the latest value at {safe_float(ts.get('latest')):.2f} versus a recent reference of {safe_float(ts.get('reference')):.2f}.",
            risk="Simple trend forecasts are not causal and can miss seasonality or external shocks.",
            action_steps=["Validate forecast with a later window", "Check subgroup drivers", "Set alert thresholds"],
        ))

    grouped = scan.get("grouped_insights")
    if isinstance(grouped, pd.DataFrame) and not grouped.empty:
        top = grouped.iloc[0]
        decisions.append(Decision(
            title=f"Investigate standout group: {top['category_column']} = {top['category_value']}",
            category="Grouped insights",
            priority="Medium",
            confidence=0.65,
            estimated_impact="Can reveal useful segments, bottlenecks, outperformance, or operational differences.",
            rationale=f"This group differs from the overall mean of {top['metric']} by {safe_float(top['difference_from_overall_mean']):+.2f}.",
            risk="Group differences can be noisy when sample sizes are small.",
            action_steps=["Check sample size", "Compare over time", "Look for operational reasons behind the gap"],
        ))

    auto_insights = scan.get("auto_insights")
    existing_titles = {d.title for d in decisions}
    if isinstance(auto_insights, pd.DataFrame) and not auto_insights.empty:
        for _, row in auto_insights.head(5).iterrows():
            finding = str(row.get("finding", "")).strip()
            if not finding or finding in existing_titles:
                continue
            action = str(row.get("recommended_action", "Review the evidence and validate the result before acting."))
            decisions.append(Decision(
                title=finding,
                category=str(row.get("insight_type", "Auto insight")),
                priority=str(row.get("priority", "Medium")),
                confidence=safe_float(row.get("confidence"), 0.6),
                estimated_impact=str(row.get("expected_impact", "Can improve decision quality if validated.")),
                rationale=str(row.get("evidence", "Auto insight detector surfaced this pattern.")),
                risk=str(row.get("risk", "Validate the result before operational use.")),
                action_steps=[action],
            ))
            existing_titles.add(finding)

    if not decisions:
        decisions.append(Decision(
            title="Improve data quality and define a clearer outcome variable",
            category="Foundation",
            priority="High",
            confidence=0.8,
            estimated_impact="Creates better conditions for stronger modeling and more reliable insights.",
            rationale="The selected modules did not surface a high-confidence decision signal yet.",
            risk="Acting too early can overfit noise or incomplete structure.",
            action_steps=["Reduce missingness", "Clarify target definitions", "Collect more relevant features"],
        ))

    decision_df = pd.DataFrame([{
        "finding": d.title,
        "evidence": d.rationale,
        "recommended_action": d.action_steps[0] if d.action_steps else "",
        "expected_impact": d.estimated_impact,
        "title": d.title,
        "category": d.category,
        "priority": d.priority,
        "confidence": round(d.confidence, 2),
        "confidence_label": confidence_label(d.confidence),
        "estimated_impact": d.estimated_impact,
        "rationale": d.rationale,
        "risk": d.risk,
        "action_steps": " | ".join(d.action_steps),
    } for d in decisions])
    order = {"High": 0, "Medium": 1, "Low": 2}
    decision_df["priority_rank"] = decision_df["priority"].map(order).fillna(9)
    decision_df = decision_df.sort_values(["priority_rank", "confidence"], ascending=[True, False]).drop(columns="priority_rank").reset_index(drop=True)

    summary_parts: list[str] = []
    if not decision_df.empty:
        top = decision_df.iloc[0]
        summary_parts.append(f"Highest-priority action: {top['title']} Confidence is {str(top['confidence_label']).lower()} ({top['confidence']:.2f}).")
    if opportunities:
        summary_parts.append("Biggest opportunities: " + "; ".join(opportunities[:3]) + ".")
    if risks:
        summary_parts.append("Main risks to manage: " + "; ".join(risks[:3]) + ".")

    return {
        "decision_df": decision_df,
        "opportunities": opportunities,
        "risks": risks,
        "summary": "\n\n".join(summary_parts),
    }



