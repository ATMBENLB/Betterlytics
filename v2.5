def prettify_feature_name(name: str) -> str:
    text = str(name)
    text = re.sub(r"^(num|cat|text_[^_]+)__", "", text)
    text = text.replace("_", " ")
    text = re.sub(r"\s+", " ", text).strip()
    return text


def extract_model_drivers(modeling: dict[str, Any] | None, top_n: int = 15, max_features: int = 10000) -> pd.DataFrame:
    if not modeling:
        return pd.DataFrame(columns=["feature", "importance"])
    best_name = modeling.get("best_model")
    best = modeling.get("details", {}).get(best_name)
    if not best:
        return pd.DataFrame(columns=["feature", "importance"])
    model = best.get("model_object")
    feature_names = best.get("feature_names", [])
    if not model or not feature_names:
        return pd.DataFrame(columns=["feature", "importance"])
    if len(feature_names) > max_features:
        return pd.DataFrame({"feature": ["Too many encoded features to display safely"], "importance": [np.nan]})

    values = None
    if hasattr(model, "feature_importances_"):
        values = np.asarray(model.feature_importances_)
    elif hasattr(model, "coef_"):
        coef = np.asarray(model.coef_)
        values = np.mean(np.abs(coef), axis=0) if coef.ndim > 1 else np.abs(coef)

    if values is None or len(values) != len(feature_names):
        return pd.DataFrame(columns=["feature", "importance"])

    out = pd.DataFrame({"feature": feature_names, "importance": values})
    out["abs_importance"] = out["importance"].abs()
    out = out.groupby("feature", as_index=False)[["importance", "abs_importance"]].sum()
    out = out.sort_values("abs_importance", ascending=False).head(top_n).drop(columns="abs_importance")
    return out.reset_index(drop=True)


def make_feature_importance_plot(drivers: pd.DataFrame):
    fig, ax = plt.subplots(figsize=(8, 5))
    if drivers.empty or "importance" not in drivers.columns or drivers["importance"].isna().all():
        ax.text(0.5, 0.5, "Feature importance is not available for this model", ha="center", va="center")
        ax.axis("off")
        return fig
    plot_df = drivers.sort_values("importance", key=lambda s: s.abs(), ascending=True).tail(15)
    ax.barh(plot_df["feature"], plot_df["importance"].abs())
    ax.set_title("Top model drivers")
    ax.set_xlabel("Importance / absolute coefficient")
    fig.tight_layout()
    return fig


def make_confusion_plot(cm: np.ndarray, labels: list[Any] | None = None):
    fig, ax = plt.subplots(figsize=(5.5, 4.5))
    im = ax.imshow(cm, aspect="auto")
    ax.set_title("Confusion matrix")
    ax.set_xlabel("Predicted")
    ax.set_ylabel("Actual")
    if labels and len(labels) <= 20:
        tick_labels = [str(x)[:20] for x in labels]
        ax.set_xticks(range(len(tick_labels)))
        ax.set_xticklabels(tick_labels, rotation=45, ha="right")
        ax.set_yticks(range(len(tick_labels)))
        ax.set_yticklabels(tick_labels)
    fig.colorbar(im, ax=ax)
    fig.tight_layout()
    return fig


def make_regression_pred_plot(y_test: pd.Series, preds: np.ndarray, config: WorkbenchConfig):
    y = pd.Series(y_test).reset_index(drop=True)
    p = pd.Series(preds).reset_index(drop=True)
    plot_df = pd.DataFrame({"actual": y, "predicted": p}).dropna()
    if len(plot_df) > config.max_plot_points:
        plot_df = plot_df.sample(config.max_plot_points, random_state=42)
    fig, ax = plt.subplots(figsize=(6.5, 5))
    if plot_df.empty:
        ax.text(0.5, 0.5, "No prediction data", ha="center", va="center")
        ax.axis("off")
        return fig
    ax.scatter(plot_df["actual"], plot_df["predicted"], alpha=0.55)
    min_val = float(min(plot_df["actual"].min(), plot_df["predicted"].min()))
    max_val = float(max(plot_df["actual"].max(), plot_df["predicted"].max()))
    ax.plot([min_val, max_val], [min_val, max_val])
    ax.set_title("Actual vs predicted")
    ax.set_xlabel("Actual")
    ax.set_ylabel("Predicted")
    fig.tight_layout()
    return fig


def scenario_simulator(modeling: dict[str, Any], base_row: pd.Series | dict[str, Any], adjustments: dict[str, Any]) -> dict[str, Any] | None:
    best_name = modeling.get("best_model")
    best = modeling.get("details", {}).get(best_name)
    if not best:
        return None
    model = best.get("model_object")
    preprocessor = best.get("preprocessor")
    requires_dense = bool(best.get("requires_dense"))
    target = modeling.get("target")
    if model is None or preprocessor is None:
        return None

    row = base_row.to_dict() if isinstance(base_row, pd.Series) else dict(base_row)
    original = row.copy()
    for key, value in adjustments.items():
        if key in row:
            row[key] = value

    try:
        original_df = make_feature_frame(pd.DataFrame([original]), target=target)
        adjusted_df = make_feature_frame(pd.DataFrame([row]), target=target)
        original_X = preprocessor.transform(original_df)
        adjusted_X = preprocessor.transform(adjusted_df)
        if requires_dense:
            original_X = to_dense_if_needed(original_X)
            adjusted_X = to_dense_if_needed(adjusted_X)
        original_pred = model.predict(original_X)[0]
        adjusted_pred = model.predict(adjusted_X)[0]
    except Exception:
        return None

    delta = None
    if isinstance(original_pred, (int, float, np.number)) and isinstance(adjusted_pred, (int, float, np.number)):
        delta = float(adjusted_pred) - float(original_pred)

    return {
        "model": best_name,
        "original_prediction": original_pred.item() if hasattr(original_pred, "item") else original_pred,
        "adjusted_prediction": adjusted_pred.item() if hasattr(adjusted_pred, "item") else adjusted_pred,
        "delta": delta,
        "adjustments": adjustments,
    }


