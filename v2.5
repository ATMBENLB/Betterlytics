def run_cluster_scan(
    df: pd.DataFrame,
    config: WorkbenchConfig,
    method: str = "KMeans",
    exclude: list[str] | None = None,
    auto_k: bool = True,
    selected_k: int = 3,
) -> dict[str, Any] | None:
    if method in {"KMeans", "MiniBatch KMeans"}:
        result = run_kmeans_scan(df, config, exclude=exclude, auto_k=auto_k, selected_k=selected_k)
        if result:
            result["method"] = method
        return result
    exclude = exclude or []
    numeric_cols = [c for c in choose_numeric_columns_by_variance(df.drop(columns=exclude, errors="ignore"), config.max_unsupervised_numeric_cols) if c not in exclude]
    if len(numeric_cols) < 2 or len(df) < 20:
        return None
    row_cap = min(config.max_cluster_rows, 10000 if method in {"Agglomerative", "DBSCAN"} else config.max_cluster_rows)
    sample = safe_sample_df(df[numeric_cols], row_cap).replace([np.inf, -np.inf], np.nan)
    sample = sample.fillna(sample.median(numeric_only=True)).dropna(axis=1, how="all")
    if sample.shape[1] < 2:
        return None
    X = StandardScaler().fit_transform(sample)
    k = min(max(2, selected_k), max(2, len(sample) - 1))
    if method == "Gaussian Mixture":
        model = GaussianMixture(n_components=k, random_state=42, covariance_type="diag")
        labels = model.fit_predict(X)
    elif method == "Agglomerative":
        model = AgglomerativeClustering(n_clusters=k)
        labels = model.fit_predict(X)
    elif method == "DBSCAN":
        model = DBSCAN(eps=0.8, min_samples=8)
        labels = model.fit_predict(X)
    else:
        return run_kmeans_scan(df, config, exclude=exclude, auto_k=auto_k, selected_k=selected_k)
    if len(set(labels)) < 2:
        return None
    score = silhouette_score(X, labels, sample_size=min(config.silhouette_rows, len(X)), random_state=42) if len(set(labels)) > 1 and len(set(labels)) < len(labels) else np.nan
    coords = PCA(n_components=2, random_state=42).fit_transform(X)
    pca_df = pd.DataFrame({"pc1": coords[:, 0], "pc2": coords[:, 1], "cluster": labels}, index=sample.index)
    clustered_df = df.loc[sample.index].copy()
    clustered_df["cluster"] = labels
    return {
        "method": method,
        "k": int(len(set(labels)) - (1 if -1 in set(labels) else 0)),
        "silhouette": float(score) if pd.notna(score) else np.nan,
        "pca_df": pca_df.reset_index(drop=True),
        "clustered_df": clustered_df.reset_index(drop=True),
        "numeric_columns_used": sample.columns.tolist(),
        "sampled_rows": len(sample),
        "sampled": len(sample) < len(df),
    }


def explain_anomalies(anomaly: dict[str, Any] | None, top_rows: int = 25, top_features: int = 5) -> pd.DataFrame:
    if not anomaly or not isinstance(anomaly.get("scored_df"), pd.DataFrame):
        return pd.DataFrame()
    df_anom = anomaly["scored_df"].copy()
    numeric_cols = [c for c in anomaly.get("numeric_columns_used", []) if c in df_anom.columns]
    flagged = df_anom[df_anom.get("anomaly_flag") == "Likely anomaly"].head(top_rows)
    if flagged.empty or not numeric_cols:
        return pd.DataFrame()
    normal = df_anom[df_anom.get("anomaly_flag") != "Likely anomaly"]
    med = normal[numeric_cols].median(numeric_only=True)
    std = normal[numeric_cols].std(numeric_only=True).replace(0, np.nan)
    rows: list[dict[str, Any]] = []
    for idx, row in flagged.iterrows():
        z = ((row[numeric_cols] - med) / std).abs().sort_values(ascending=False).head(top_features)
        rows.append({
            "record_rank": int(idx),
            "anomaly_score": row.get("anomaly_score"),
            "top_unusual_fields": ", ".join([f"{k} (z≈{safe_float(v):.1f})" for k, v in z.items() if pd.notna(v)]),
        })
    return pd.DataFrame(rows)


def run_time_series_anomaly_scan(ts_result: dict[str, Any] | None, z_threshold: float = 2.5) -> pd.DataFrame:
    if not ts_result:
        return pd.DataFrame()
    ts = ts_result.get("series")
    if not isinstance(ts, pd.DataFrame) or ts.empty:
        return pd.DataFrame()
    value_col = ts_result.get("value_col")
    date_col = ts_result.get("date_col")
    if value_col not in ts.columns:
        return pd.DataFrame()
    vals = pd.to_numeric(ts[value_col], errors="coerce")
    roll = vals.rolling(window=min(7, max(3, len(vals)//6)), min_periods=3).mean()
    resid = vals - roll
    std = resid.std()
    if not std or pd.isna(std):
        return pd.DataFrame()
    out = ts[[date_col, value_col]].copy()
    out["rolling_expected"] = roll
    out["residual"] = resid
    out["z_score"] = resid / std
    return out[out["z_score"].abs() >= z_threshold].sort_values("z_score", key=lambda s: s.abs(), ascending=False).reset_index(drop=True)


def run_nlp_topics(df: pd.DataFrame, text_col: str | None, config: WorkbenchConfig) -> dict[str, Any] | None:
    if not text_col or text_col not in df.columns:
        return None
    series = df[text_col].dropna().astype(str)
    if series.empty:
        return None
    if len(series) > config.text_rows:
        series = series.sample(config.text_rows, random_state=42)
    vectorizer = TfidfVectorizer(stop_words="english", max_features=1000, ngram_range=(1, 2), min_df=2)
    try:
        X = vectorizer.fit_transform(series)
        n_topics = min(6, max(2, X.shape[0] // 50))
        nmf = NMF(n_components=n_topics, random_state=42, init="nndsvda", max_iter=300)
        W = nmf.fit_transform(X)
        terms = np.array(vectorizer.get_feature_names_out())
        rows: list[dict[str, Any]] = []
        for topic_idx, comp in enumerate(nmf.components_):
            top_terms = terms[np.argsort(comp)[::-1][:config.max_topic_terms]]
            rows.append({"topic": f"Topic {topic_idx + 1}", "top_terms": ", ".join(top_terms), "estimated_share_pct": round(float((W.argmax(axis=1) == topic_idx).mean() * 100), 2)})
        complaint_words = ["bad", "late", "delay", "broken", "damage", "problem", "issue", "wrong", "refund", "cold", "dirty", "missing", "slow", "fail"]
        lower = series.str.lower()
        complaints = pd.DataFrame({"complaint_keyword": complaint_words, "mentions": [int(lower.str.contains(fr"\b{re.escape(w)}\b", regex=True).sum()) for w in complaint_words]}).sort_values("mentions", ascending=False)
        entities = extract_simple_entities(series)
        return {"topics": pd.DataFrame(rows), "complaints": complaints, "simple_entities": entities, "rows_scanned": len(series)}
    except Exception as exc:
        return {"topics": pd.DataFrame([{"topic": "Topic extraction failed", "top_terms": str(exc), "estimated_share_pct": np.nan}]), "complaints": pd.DataFrame(), "simple_entities": pd.DataFrame(), "rows_scanned": len(series)}


def extract_simple_entities(series: pd.Series) -> pd.DataFrame:
    counts: dict[str, int] = {}
    for text in series.head(5000):
        for phrase in re.findall(r"\b[A-Z][a-z]+(?:\s+[A-Z][a-z]+){0,2}\b", text):
            if len(phrase) > 2 and phrase.lower() not in {"The", "This", "That"}:
                counts[phrase] = counts.get(phrase, 0) + 1
    rows = [{"entity_like_phrase": k, "mentions": v} for k, v in counts.items() if v >= 2]
    return pd.DataFrame(rows).sort_values("mentions", ascending=False).head(50).reset_index(drop=True) if rows else pd.DataFrame()


def run_geospatial_summary(df: pd.DataFrame, lat_col: str | None, lon_col: str | None, config: WorkbenchConfig, reference_lat: float | None = None, reference_lon: float | None = None) -> dict[str, Any]:
    if not lat_col or not lon_col or lat_col not in df.columns or lon_col not in df.columns:
        return {"summary": pd.DataFrame(), "distance_table": pd.DataFrame()}
    data = build_map_data(df, lat_col, lon_col, config)
    if data.empty:
        return {"summary": pd.DataFrame(), "distance_table": pd.DataFrame()}
    summary = pd.DataFrame([{
        "points": len(data),
        "lat_min": float(data["lat"].min()),
        "lat_max": float(data["lat"].max()),
        "lon_min": float(data["lon"].min()),
        "lon_max": float(data["lon"].max()),
        "center_lat": float(data["lat"].mean()),
        "center_lon": float(data["lon"].mean()),
    }])
    distance_table = pd.DataFrame()
    if reference_lat is not None and reference_lon is not None:
        distance_table = data.copy()
        distance_table["distance_miles"] = haversine_miles(distance_table["lat"], distance_table["lon"], reference_lat, reference_lon)
        distance_table = distance_table.sort_values("distance_miles").head(100).reset_index(drop=True)
    return {"summary": summary, "distance_table": distance_table}


def haversine_miles(lat1: pd.Series, lon1: pd.Series, lat2: float, lon2: float) -> pd.Series:
    r = 3958.8
    phi1 = np.radians(lat1.astype(float))
    phi2 = math.radians(float(lat2))
    dphi = np.radians(float(lat2) - lat1.astype(float))
    dlambda = np.radians(float(lon2) - lon1.astype(float))
    a = np.sin(dphi / 2) ** 2 + np.cos(phi1) * math.cos(phi2) * np.sin(dlambda / 2) ** 2
    return pd.Series(2 * r * np.arctan2(np.sqrt(a), np.sqrt(1 - a)), index=lat1.index)


def recommend_modules_for_dataset(df: pd.DataFrame, schema: Schema) -> pd.DataFrame:
    rows: list[dict[str, Any]] = []
    def add(module: str, reason: str, priority: str = "Medium"):
        rows.append({"module": module, "priority": priority, "reason": reason})
    add("EDA summary", "Always useful for orientation", "High")
    if df.isna().any().any():
        add("Missingness report", "Dataset contains missing values", "High")
        add("Clean My Data", "Missingness and messy columns may reduce reliability", "High")
    if len(schema.numeric) >= 2:
        add("Correlation heatmap", "Multiple numeric fields are available", "Medium")
        add("Clustering", "Numeric fields can support segmentation", "Medium")
        add("Anomaly detection", "Numeric fields can support unusual-record detection", "Medium")
    if schema.target_candidates:
        add("Supervised modeling", "Potential target columns were detected", "High")
        add("Leakage checks", "Modeling needs target-leakage safeguards", "High")
    if schema.datetime and schema.numeric:
        add("Time-series + forecasting", "Date and numeric fields support trend analysis", "High")
    if schema.categorical and schema.numeric:
        add("Grouped insights / pivot", "Categorical and numeric fields support group comparisons", "High")
    if schema.text:
        add("Text analytics / NLP topics", "Text-heavy columns were detected", "Medium")
    lat, lon = detect_lat_lon(df)
    if lat and lon:
        add("Geospatial map", "Latitude/longitude columns were detected", "Medium")
    return pd.DataFrame(rows).drop_duplicates("module").reset_index(drop=True)


def _module_field_hints(module: str, df: pd.DataFrame, schema: Schema) -> list[str]:
    module_low = module.lower()
    if "supervised" in module_low:
        return schema.target_candidates[:8]
    if "leakage" in module_low:
        return schema.target_candidates[:5] + schema.id_like[:5]
    if "correlation" in module_low or "clustering" in module_low or "anomaly" in module_low:
        return schema.numeric[:12]
    if "grouped" in module_low or "pivot" in module_low:
        return list(dict.fromkeys((schema.categorical + schema.boolean)[:6] + schema.numeric[:6]))
    if "time" in module_low or "forecast" in module_low:
        return schema.datetime[:4] + schema.numeric[:6]
    if "text" in module_low or "nlp" in module_low:
        return schema.text[:8]
    if "geo" in module_low or "map" in module_low:
        lat, lon = detect_lat_lon(df)
        return [c for c in [lat, lon] if c]
    if "missing" in module_low or "clean" in module_low:
        missing = df.isna().mean().sort_values(ascending=False)
        return missing[missing > 0].head(10).index.tolist()
    return df.columns[:10].tolist()


