            leaderboard = leaderboard.drop(columns=[c for c in ["report", "confusion_matrix", "score_for_ranking", "labels"] if c in leaderboard.columns], errors="ignore")
        out["modeling"] = {
            "target": modeling.get("target"),
            "problem_type": modeling.get("problem_type"),
            "best_model": modeling.get("best_model"),
            "leaderboard": records(leaderboard, config.json_table_rows),
            "model_failures": modeling.get("model_failures", []),
            "dropped_features": modeling.get("dropped_features", []),
            "used_numeric_features": modeling.get("used_numeric_features", []),
