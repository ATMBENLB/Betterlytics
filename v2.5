                title=f"{selected_result.get('result_id')} PCA map",
                key_prefix="cluster_compare",
                max_rows=250,
            )
            connections = selected_result.get("connections", {})
            profile_table = selected_result.get("profiles")
            cluster_sizes = connections.get("cluster_sizes") if isinstance(connections, dict) else pd.DataFrame()
            numeric_connections = connections.get("numeric_connections") if isinstance(connections, dict) else pd.DataFrame()
            categorical_connections = connections.get("categorical_connections") if isinstance(connections, dict) else pd.DataFrame()
            target_by_cluster = connections.get("target_by_cluster") if isinstance(connections, dict) else pd.DataFrame()

            inner_tabs = st.tabs(["Profiles", "Fingerprints", "Numeric connections", "Categorical connections", "Target/outcome", "Rows / raw data"])
            with inner_tabs[0]:
                if isinstance(cluster_sizes, pd.DataFrame) and not cluster_sizes.empty:
                    st.write("**Cluster sizes**")
                    st.dataframe(cluster_sizes, use_container_width=True)
                if isinstance(profile_table, pd.DataFrame) and not profile_table.empty:
                    st.write("**Cluster profile summaries**")
                    st.dataframe(profile_table, use_container_width=True)
            with inner_tabs[1]:
                result_fingerprints = selected_result.get("fingerprints")
                if isinstance(result_fingerprints, dict):
                    render_cluster_fingerprint_cards(result_fingerprints, key_prefix="cluster_compare")
                else:
                    st.info("No fingerprint cards are available for this clustering result.")
            with inner_tabs[2]:
                if isinstance(numeric_connections, pd.DataFrame) and not numeric_connections.empty:
                    st.write("**Strongest numeric differences by cluster**")
                    st.dataframe(numeric_connections, use_container_width=True)
                    numeric_feature_options = numeric_connections["feature"].dropna().astype(str).unique().tolist()
                    selected_numeric_connection = st.selectbox("Plot numeric connection", numeric_feature_options, key="cluster_numeric_connection")
                    show_fig(make_cluster_numeric_connection_plot(clustered_sample, selected_numeric_connection))
                else:
                    st.info("No numeric cluster connections were strong enough to summarize.")
            with inner_tabs[3]:
                if isinstance(categorical_connections, pd.DataFrame) and not categorical_connections.empty:
                    st.write("**Categorical values that over-index inside clusters**")
                    st.dataframe(categorical_connections, use_container_width=True)
                    cat_feature_options = categorical_connections["feature"].dropna().astype(str).unique().tolist()
                    selected_cat_connection = st.selectbox("Plot categorical connection", cat_feature_options, key="cluster_cat_connection")
                    show_fig(make_cluster_category_connection_plot(clustered_sample, selected_cat_connection))
                else:
                    st.info("No low-cardinality categorical cluster connections were available.")
            with inner_tabs[4]:
                if isinstance(target_by_cluster, pd.DataFrame) and not target_by_cluster.empty:
                    st.write("**Selected target / outcome by cluster**")
                    st.dataframe(target_by_cluster, use_container_width=True)
                else:
                    st.info("Select a target before running the scan to compare outcomes by cluster.")
            with inner_tabs[5]:
                if isinstance(clustered_sample, pd.DataFrame) and not clustered_sample.empty:
                    st.write("**Full clustered sample preview**")
                    st.dataframe(clustered_sample.head(500), use_container_width=True)
                    csv_bytes = clustered_sample.to_csv(index=False).encode("utf-8")
                    st.download_button(
                        "Download clustered sample CSV",
                        data=csv_bytes,
                        file_name="clustered_sample.csv",
                        mime="text/csv",
                        key="clustered_sample_download",
                    )
                else:
                    st.info("No clustered sample rows are available for this response.")
    else:
        st.info("Clustering comparison explorer was not selected, skipped, or did not have enough numeric data.")

