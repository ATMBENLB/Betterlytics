def detect_domain_insights(df: pd.DataFrame, schema: Schema) -> dict[str, Any]:
    domain_keywords: dict[str, list[str]] = {
        "Logistics / supply chain": ["shipment", "shipping", "delivery", "route", "warehouse", "inventory", "order", "carrier", "freight", "distance", "delay", "late", "eta", "lead", "sku", "fulfillment", "transit"],
        "Sports / performance": ["team", "player", "game", "score", "opponent", "season", "win", "loss", "points", "rebounds", "assists", "goals", "shots", "minutes", "league", "home", "away"],
        "Weather / environment": ["temp", "temperature", "humidity", "precip", "rain", "snow", "wind", "pressure", "weather", "storm", "forecast", "degree", "climate"],
        "Food / beverage": ["menu", "item", "ingredient", "calories", "protein", "fat", "sugar", "drink", "beverage", "restaurant", "recipe", "serving", "flavor", "meal", "food"],
        "Sales / commerce": ["sales", "revenue", "profit", "cost", "price", "margin", "customer", "conversion", "churn", "purchase", "discount", "quantity", "invoice", "cart", "order"],
        "Marketing": ["campaign", "channel", "lead", "conversion", "impression", "click", "ctr", "cpc", "cac", "roas", "spend", "ad", "creative", "audience"],
        "Inventory": ["inventory", "stock", "sku", "warehouse", "reorder", "on_hand", "sell_through", "stockout", "shrink", "backorder", "supply"],
        "Customer churn": ["churn", "retention", "cancel", "tenure", "subscription", "renewal", "customer_value", "ltv", "plan", "engagement"],
        "Product analytics": ["product", "feature", "activation", "usage", "session", "event", "funnel", "retention", "adoption", "release", "feedback"],
        "Operations / quality": ["defect", "downtime", "failure", "machine", "inspection", "production", "yield", "quality", "ticket", "incident", "sla", "resolution", "queue"],
        "Finance / risk": ["return", "risk", "loan", "credit", "balance", "payment", "default", "rate", "portfolio", "asset", "liability", "debt"],
        "People / HR": ["employee", "salary", "department", "hire", "attrition", "performance", "manager", "tenure", "role", "job", "promotion"],
    }
    lower_cols = {c: c.lower() for c in df.columns}
    rows: list[dict[str, Any]] = []
    for domain, keywords in domain_keywords.items():
        matched = [c for c, low in lower_cols.items() if any(k in low for k in keywords)]
        if matched:
            rows.append({
                "domain": domain,
                "match_count": len(matched),
                "matched_columns": ", ".join(matched[:25]),
                "suggested_analysis": domain_questions(domain),
            })
    domain_table = pd.DataFrame(rows).sort_values("match_count", ascending=False).reset_index(drop=True) if rows else pd.DataFrame(columns=["domain", "match_count", "matched_columns", "suggested_analysis"])

    special_signals: list[str] = []
    if schema.datetime:
        special_signals.append("Date/time fields detected: forecasting, trend monitoring, seasonality checks, and period-over-period comparisons are useful.")
    if len(schema.numeric) >= 2:
        special_signals.append("Multiple numeric fields detected: correlations, regression, clustering, and anomaly detection are useful.")
    if schema.text:
        special_signals.append("Text-heavy fields detected: top terms, simple sentiment, and optional TF-IDF modeling are useful.")
    if schema.id_like:
        special_signals.append("ID-like fields detected: these are usually useful for grouping/counting but are excluded from most models by default.")
    lat_col, lon_col = detect_lat_lon(df)
    if lat_col and lon_col:
        special_signals.append("Latitude/longitude fields detected: the map module can visualize geographic concentration.")

    recommended_modules: list[str] = []
    if not domain_table.empty:
        top_domain = str(domain_table.iloc[0]["domain"])
        if top_domain in {"Logistics / supply chain", "Sales / commerce", "Operations / quality", "Food / beverage", "Marketing", "Inventory", "Product analytics"}:
            recommended_modules.extend(["Grouped insights", "Supervised modeling", "Anomaly detection", "Time-series + forecasting"])
        elif top_domain in {"Sports / performance", "Weather / environment"}:
            recommended_modules.extend(["Correlation heatmap", "Grouped insights", "Time-series + forecasting", "Supervised modeling"])
        elif top_domain in {"Finance / risk", "People / HR", "Customer churn"}:
            recommended_modules.extend(["Supervised modeling", "Feature importance", "Anomaly detection", "Grouped insights"])
    recommended_modules = list(dict.fromkeys(recommended_modules))

    return {
        "domain_table": domain_table,
        "special_signals": special_signals,
        "recommended_modules": recommended_modules,
    }

def create_narrative(scan: dict[str, Any]) -> str:
    lines: list[str] = []
    profile = scan.get("profile", {})
    shape = profile.get("shape")
    if shape:
        lines.append(f"This dataset has {shape[0]:,} rows and {shape[1]:,} columns.")
    flags = scan.get("health_flags", [])
    if flags:
        lines.append("Data quality watchouts: " + "; ".join(flags) + ".")
    corr = scan.get("correlations")
    if isinstance(corr, pd.DataFrame) and not corr.empty:
        top = corr.iloc[0]
        lines.append(f"The strongest numeric relationship is between {top['feature_1']} and {top['feature_2']} with correlation {safe_float(top['correlation']):.2f}.")
    modeling = scan.get("modeling")
    if modeling and isinstance(modeling.get("leaderboard"), pd.DataFrame) and not modeling["leaderboard"].empty:
        leader = modeling["leaderboard"].iloc[0]
        if modeling.get("problem_type") == "classification":
            lines.append(f"The strongest classifier was {leader['model']} with accuracy {safe_float(leader.get('Accuracy')):.2f}.")
        else:
            lines.append(f"The strongest regressor was {leader['model']} with R² {safe_float(leader.get('R2')):.2f}, RMSE {safe_float(leader.get('RMSE')):.2f}, and MAE {safe_float(leader.get('MAE')):.2f}.")
    clustering = scan.get("clustering")
    if clustering:
        lines.append(f"{clustering.get('method', 'KMeans')} found about {clustering['k']} groups with silhouette {safe_float(clustering.get('silhouette')):.2f}.")
    cluster_compare = scan.get("clustering_comparison")
    if cluster_compare and isinstance(cluster_compare.get("summary"), pd.DataFrame) and not cluster_compare["summary"].empty:
        best_cluster = cluster_compare["summary"].iloc[0]
        lines.append(f"The clustering comparison ranked {best_cluster['result_id']} highest, with {int(best_cluster['clusters']) if pd.notna(best_cluster.get('clusters')) else 'N/A'} clusters and silhouette {safe_float(best_cluster.get('silhouette')):.2f}.")
    anomaly = scan.get("anomaly")
    if anomaly:
        lines.append(f"The anomaly detector flagged {int(anomaly.get('anomaly_count', 0)):,} unusual records in the sampled analysis set.")
    text = scan.get("text")
    if text and isinstance(text.get("top_terms"), pd.DataFrame) and not text["top_terms"].empty:
        lines.append(f"The most repeated text pattern was '{text['top_terms'].iloc[0]['term']}'.")
    ts = scan.get("time_series")
    if ts:
        lines.append(f"The time-series module shows the tracked metric trending {ts.get('trend', 'flat')} lately.")
    grouped = scan.get("grouped_insights")
    if isinstance(grouped, pd.DataFrame) and not grouped.empty:
        top = grouped.iloc[0]
        lines.append(f"Grouped analysis found a standout group: {top['category_column']} = {top['category_value']} for metric {top['metric']}.")
    auto = scan.get("auto_insights")
    if isinstance(auto, pd.DataFrame) and not auto.empty:
        top_auto = auto.iloc[0]
        lines.append(f"Auto insight detector says: {top_auto['finding']} Evidence: {top_auto['evidence']}")
    domain = scan.get("domain_insights")
    if domain and isinstance(domain.get("domain_table"), pd.DataFrame) and not domain["domain_table"].empty:
        top_domain = domain["domain_table"].iloc[0]
        lines.append(f"Column names most strongly resemble a {top_domain['domain']} dataset. Suggested focus: {top_domain['suggested_analysis']}")
    if not lines:
        lines.append("Run selected modules to generate a plain-English interpretation.")
    lines.append("Overall, betterlytics is designed to let users run only the analytics they need while keeping expensive modules capped and explainable.")
    return "\n\n".join(lines)


