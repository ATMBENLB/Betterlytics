def run_grouped_insights(df: pd.DataFrame, schema: Schema, metric_col: str | None, config: WorkbenchConfig) -> pd.DataFrame:
    numeric_metric = metric_col if metric_col in df.columns and pd.api.types.is_numeric_dtype(df[metric_col]) else None
    if numeric_metric is None:
        numeric_metric = schema.numeric[0] if schema.numeric else None
    if numeric_metric is None:
        return pd.DataFrame()

    rows: list[dict[str, Any]] = []
    overall = float(pd.to_numeric(df[numeric_metric], errors="coerce").mean())
    candidate_cats = [c for c in schema.categorical + schema.boolean if c != numeric_metric]
    for cat in candidate_cats:
        nunique = int(df[cat].nunique(dropna=True))
        if nunique < 2 or nunique > config.grouped_max_categories:
            continue
        temp = df[[cat, numeric_metric]].copy()
        temp[numeric_metric] = pd.to_numeric(temp[numeric_metric], errors="coerce")
        grouped = temp.dropna().groupby(cat)[numeric_metric].agg(["count", "mean", "median"]).reset_index()
        grouped = grouped[grouped["count"] >= max(3, len(temp) * 0.01)]
        for _, row in grouped.iterrows():
            rows.append({
                "category_column": cat,
                "category_value": row[cat],
                "metric": numeric_metric,
                "count": int(row["count"]),
                "mean": float(row["mean"]),
                "median": float(row["median"]),
                "difference_from_overall_mean": float(row["mean"] - overall),
                "pct_difference_from_overall": float((row["mean"] - overall) / overall * 100) if overall else np.nan,
            })
    out = pd.DataFrame(rows)
    if out.empty:
        return out
    out["absolute_difference"] = out["difference_from_overall_mean"].abs()
    return out.sort_values("absolute_difference", ascending=False).drop(columns="absolute_difference").head(50).reset_index(drop=True)


def build_map_data(df: pd.DataFrame, lat_col: str, lon_col: str, config: WorkbenchConfig) -> pd.DataFrame:
    out = df[[lat_col, lon_col]].copy()
    out[lat_col] = pd.to_numeric(out[lat_col], errors="coerce")
    out[lon_col] = pd.to_numeric(out[lon_col], errors="coerce")
    out = out.dropna()
    out = out[out[lat_col].between(-90, 90) & out[lon_col].between(-180, 180)]
    if len(out) > config.max_plot_points:
        out = out.sample(config.max_plot_points, random_state=42)
    return out.rename(columns={lat_col: "lat", lon_col: "lon"})



