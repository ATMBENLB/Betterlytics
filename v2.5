def _selected_dataframe_row(event: Any) -> int | None:
    try:
        rows = event.selection.rows
    except Exception:
        try:
            rows = event.get("selection", {}).get("rows", [])
        except Exception:
            rows = []
    return int(rows[0]) if rows else None


def render_module_recommendations(recmods: pd.DataFrame, df: pd.DataFrame, schema: Schema, scan: dict[str, Any], config: WorkbenchConfig) -> None:
    st.write("**Recommended modules for this dataset**")
    st.caption("Click a row to see what betterlytics means by that recommendation, what it will show, and which fields it would use.")
    display_cols = [c for c in ["module", "priority", "reason"] if c in recmods.columns]
    display_df = recmods[display_cols].reset_index(drop=True)
    selected_idx = None
    try:
        event = st.dataframe(
            display_df,
            use_container_width=True,
            on_select="rerun",
            selection_mode="single-row",
            key="recommended_module_table",
        )
        selected_idx = _selected_dataframe_row(event)
    except TypeError:
        st.dataframe(display_df, use_container_width=True)

    if selected_idx is None:
        selected_module = st.selectbox("Open module explanation", display_df["module"].tolist(), key="recommended_module_select")
    else:
        selected_module = str(display_df.iloc[selected_idx]["module"])

    selected_row = display_df[display_df["module"] == selected_module].iloc[0]
    detail = module_recommendation_explanation(selected_module, df, schema, scan, config)
    st.markdown(f"#### {selected_module}")
    c1, c2 = st.columns([1, 2])
    c1.metric("Priority", selected_row.get("priority", "N/A"))
    c2.info(str(selected_row.get("reason", "")))
    st.write(f"**What it means:** {detail['means']}")
    st.write(f"**What it shows:** {detail['shows']}")
    st.write(f"**When to use it:** {detail['use']}")
    st.write(f"**Trust note:** {detail['trust']}")
    fields = detail.get("fields", [])
    if fields:
        st.write("**Likely fields used**")
        st.write(", ".join([str(x) for x in fields]))
    preview = detail.get("preview")
    if isinstance(preview, pd.DataFrame) and not preview.empty:
        st.write("**Preview / current evidence**")
        st.dataframe(preview, use_container_width=True)


def _insight_priority(confidence: float, impact: float = 1.0) -> str:
    score = confidence * impact
    if score >= 0.72:
        return "High"
    if score >= 0.45:
        return "Medium"
    return "Low"


def _insight_row(
    insight_type: str,
    finding: str,
    evidence: str,
    risk: str,
    action: str,
    confidence: float,
    impact: str,
    priority: str | None = None,
) -> dict[str, Any]:
    confidence = max(0.0, min(0.99, float(confidence)))
    return {
        "priority": priority or _insight_priority(confidence),
        "insight_type": insight_type,
        "finding": finding,
        "evidence": evidence,
        "risk": risk,
        "recommended_action": action,
        "expected_impact": impact,
        "confidence": round(confidence, 2),
        "confidence_label": confidence_label(confidence),
    }


def period_change_table(
    df: pd.DataFrame,
    schema: Schema,
    config: WorkbenchConfig,
    date_col: str | None = None,
    metric_col: str | None = None,
    category_col: str | None = None,
) -> pd.DataFrame:
    date_col = date_col if date_col in df.columns else (schema.datetime[0] if schema.datetime else None)
    metric_col = metric_col if metric_col in df.columns else (schema.numeric[0] if schema.numeric else None)
    category_col = category_col if category_col in df.columns else next(
        (c for c in schema.categorical + schema.boolean if c in df.columns and df[c].nunique(dropna=True) <= config.grouped_max_categories),
        None,
    )
    if not date_col or not metric_col or not category_col:
        return pd.DataFrame()
    temp = df[[date_col, metric_col, category_col]].copy()
    temp[date_col] = pd.to_datetime(temp[date_col], errors="coerce")
    temp[metric_col] = pd.to_numeric(temp[metric_col], errors="coerce")
    temp = temp.dropna().sort_values(date_col)
    if len(temp) < 20 or temp[category_col].nunique(dropna=True) < 2:
        return pd.DataFrame()
    cutoff = temp[date_col].quantile(0.5)
    temp["period"] = np.where(temp[date_col] > cutoff, "recent", "previous")
    grouped = temp.groupby(["period", category_col])[metric_col].mean().reset_index()
    pivot = grouped.pivot(index=category_col, columns="period", values=metric_col).dropna()
    if not {"previous", "recent"}.issubset(pivot.columns):
        return pd.DataFrame()
    counts = temp.groupby(["period", category_col]).size().unstack("period").fillna(0)
    pivot["previous_mean"] = pivot["previous"]
    pivot["recent_mean"] = pivot["recent"]
    pivot["absolute_change"] = pivot["recent_mean"] - pivot["previous_mean"]
    pivot["pct_change"] = np.where(pivot["previous_mean"].abs() > 0, pivot["absolute_change"] / pivot["previous_mean"].abs() * 100, np.nan)
    pivot["previous_rows"] = counts.get("previous", pd.Series(index=pivot.index, dtype=float))
    pivot["recent_rows"] = counts.get("recent", pd.Series(index=pivot.index, dtype=float))
    out = pivot.reset_index().rename(columns={category_col: "category_value"})
    out.insert(0, "category_column", category_col)
    out.insert(1, "metric", metric_col)
    return out.sort_values("absolute_change", key=lambda s: s.abs(), ascending=False).head(50).reset_index(drop=True)


def detect_auto_insights(df: pd.DataFrame, schema: Schema, scan: dict[str, Any], config: WorkbenchConfig) -> pd.DataFrame:
    rows: list[dict[str, Any]] = []

    missing = scan.get("missingness")
    if isinstance(missing, pd.DataFrame) and not missing.empty:
        top_missing = missing.sort_values("missing_pct", ascending=False).iloc[0]
        miss_pct = safe_float(top_missing.get("missing_pct"))
        if miss_pct > 0:
            rows.append(_insight_row(
                "Missing data risk",
                f"{top_missing['column']} has the most missing data.",
                f"{miss_pct:.1f}% of rows are missing this field.",
                "Models, group comparisons, and reports can be biased if the missingness is systematic.",
                "Check whether missingness is concentrated in a segment, then impute, exclude, or report the caveat.",
                min(0.95, 0.45 + miss_pct / 100),
                "More reliable analysis and fewer silent data-quality failures.",
                priority="High" if miss_pct >= 25 else None,
            ))

    grouped = scan.get("grouped_insights")
    if isinstance(grouped, pd.DataFrame) and not grouped.empty:
        top = grouped.iloc[0]
        pct = safe_float(top.get("pct_difference_from_overall"), np.nan)
        diff = safe_float(top.get("difference_from_overall_mean"))
        rows.append(_insight_row(
            "Segment performance gap",
            f"{top['category_column']} = {top['category_value']} stands out on {top['metric']}.",
            f"Mean is {diff:+.2f} versus the overall mean" + (f" ({pct:+.1f}%)." if pd.notna(pct) else "."),
            "The gap may be noisy if the group is small or if the category is a proxy for another driver.",
            "Inspect this segment over time and compare controllable drivers before taking action.",
            min(0.9, 0.55 + min(abs(diff), 100) / 250),
            "Can expose high-value segments, bottlenecks, or underperforming groups.",
        ))

    corr = scan.get("correlations")
    if isinstance(corr, pd.DataFrame) and not corr.empty:
        top_corr = corr.iloc[0]
        strength = safe_float(top_corr.get("strength"))
        if strength >= 0.45:
            rows.append(_insight_row(
                "Strong correlation",
                f"{top_corr['feature_1']} and {top_corr['feature_2']} move together.",
                f"Correlation is {safe_float(top_corr.get('correlation')):.2f}.",
                "Correlation is not causation and may reflect leakage or a hidden shared factor.",
                "Check whether either field is actionable, causal, or leaking future information.",
                min(0.9, 0.35 + strength * 0.6),
                "Can focus driver analysis and reduce exploratory guesswork.",
                priority="High" if strength >= 0.75 else None,
            ))

    fingerprints = scan.get("cluster_fingerprints")
    summary = fingerprints.get("summary") if isinstance(fingerprints, dict) else pd.DataFrame()
    if isinstance(summary, pd.DataFrame) and not summary.empty:
        top_cluster = summary.sort_values("share_pct", ascending=False).iloc[0]
        rows.append(_insight_row(
            "Cluster differentiator",
            f"{top_cluster['persona']} is the largest discovered segment.",
            f"It contains {int(top_cluster['size']):,} rows ({safe_float(top_cluster['share_pct']):.1f}% of clustered rows). Above-average features: {top_cluster.get('top_5_above_average', '')}",
            "Large clusters can dominate averages and hide smaller high-value or high-risk groups.",
            "Use cluster-specific views for forecasting, pricing, operations, or targeting decisions.",
            0.7,
            "Cleaner segmentation and more business-readable cluster strategy.",
        ))

    anomaly = scan.get("anomaly")
    if anomaly and int(anomaly.get("anomaly_count", 0)) > 0:
        rate = safe_float(anomaly.get("anomaly_rate_pct"))
        rows.append(_insight_row(
            "Outliers and anomalies",
            "The anomaly detector found unusual records.",
            f"{int(anomaly.get('anomaly_count', 0)):,} rows were flagged ({rate:.2f}% of the sampled analysis set).",
            "Anomalies may be data errors, fraud, exceptional wins, or legitimate rare cases.",
            "Review the anomaly explanation table before excluding records or automating decisions.",
            min(0.85, 0.55 + rate / 100),
            "Protects models and reports from distorted edge cases.",
        ))

    feature_importance = scan.get("feature_importance")
    if isinstance(feature_importance, pd.DataFrame) and not feature_importance.empty and "importance" in feature_importance.columns:
        usable = feature_importance.dropna(subset=["importance"]).copy()
        if not usable.empty:
            usable["abs_importance"] = usable["importance"].abs()
            top_driver = usable.sort_values("abs_importance", ascending=False).iloc[0]
            rows.append(_insight_row(
                "Model-driving variable",
                f"{top_driver['feature']} is the strongest model driver.",
                f"It has the largest absolute importance among the displayed model features ({safe_float(top_driver['importance']):.4f}).",
                "Model importance can be unstable when features are correlated or the model is overfit.",
                "Validate with permutation importance, holdout data, and business review before acting.",
                0.68,
                "Helps focus interventions and explanations on the most predictive fields.",
            ))

    changes = period_change_table(df, schema, config)
    if not changes.empty:
        top_change = changes.iloc[0]
        rows.append(_insight_row(
            "Biggest period change",
            f"{top_change['category_column']} = {top_change['category_value']} changed most on {top_change['metric']}.",
            f"Recent mean is {safe_float(top_change['recent_mean']):.2f} versus {safe_float(top_change['previous_mean']):.2f} previously ({safe_float(top_change['absolute_change']):+.2f}).",
            "Period splits can be affected by seasonality, holidays, campaigns, or uneven sample sizes.",
            "Compare this category against adjacent periods and known business events.",
            0.62,
            "Faster detection of growing, declining, or newly risky categories.",
        ))

    ts = scan.get("time_series")
    if ts:
        latest = safe_float(ts.get("latest"))
        reference = safe_float(ts.get("reference"))
        delta = latest - reference
        rows.append(_insight_row(
            "Time-series movement",
            f"{ts.get('value_col', 'The selected metric')} is trending {ts.get('trend', 'flat')}.",
            f"Latest value is {latest:.2f} versus a recent reference of {reference:.2f} ({delta:+.2f}).",
            "Forecasts are directional and can miss seasonality or external shocks.",
            "Use the forecast as an early warning, then validate with segment and calendar context.",
            0.62,
            "Supports earlier reaction to demand, cost, service, or performance movement.",
        ))

    if not rows:
        rows.append(_insight_row(
            "Analysis readiness",
            "No high-confidence automated insight was detected yet.",
            "The selected modules did not expose a strong enough relationship, segment, trend, or quality risk.",
            "A weak signal can mean the dataset needs more rows, a clearer target, or more relevant features.",
            "Enable grouped insights, correlations, modeling, clustering, and time-series modules where applicable.",
            0.55,
            "Improves the chance of surfacing decision-grade evidence.",
            priority="Medium",
        ))

    out = pd.DataFrame(rows)
    order = {"High": 0, "Medium": 1, "Low": 2}
    out["priority_rank"] = out["priority"].map(order).fillna(9)
    return out.sort_values(["priority_rank", "confidence"], ascending=[True, False]).drop(columns="priority_rank").reset_index(drop=True)


def compare_datasets(current_df: pd.DataFrame, comparison_df: pd.DataFrame, config: WorkbenchConfig) -> dict[str, pd.DataFrame]:
    current_schema = infer_schema(current_df)
    comparison_schema = infer_schema(comparison_df)
    shape = pd.DataFrame([
        {"dataset": "current", "rows": len(current_df), "columns": current_df.shape[1], "duplicate_rows": int(current_df.duplicated().sum()), "quality_score": data_quality_score(current_df, current_schema)["score"]},
        {"dataset": "comparison", "rows": len(comparison_df), "columns": comparison_df.shape[1], "duplicate_rows": int(comparison_df.duplicated().sum()), "quality_score": data_quality_score(comparison_df, comparison_schema)["score"]},
    ])

    current_cols = set(current_df.columns)
    comparison_cols = set(comparison_df.columns)
    columns = pd.DataFrame({
        "change_type": ["added_in_current"] * len(current_cols - comparison_cols) + ["missing_from_current"] * len(comparison_cols - current_cols),
        "column": sorted(current_cols - comparison_cols) + sorted(comparison_cols - current_cols),
    })

    numeric_rows: list[dict[str, Any]] = []
    for col in sorted(current_cols & comparison_cols):
        cur = pd.to_numeric(current_df[col], errors="coerce")
        comp = pd.to_numeric(comparison_df[col], errors="coerce")
        if cur.notna().sum() < 3 or comp.notna().sum() < 3:
            continue
        cur_mean = float(cur.mean())
        comp_mean = float(comp.mean())
        numeric_rows.append({
            "column": col,
            "current_mean": cur_mean,
            "comparison_mean": comp_mean,
            "mean_change": cur_mean - comp_mean,
            "pct_change": _pct_delta(cur_mean, comp_mean),
            "current_missing_pct": round(float(cur.isna().mean() * 100), 2),
            "comparison_missing_pct": round(float(comp.isna().mean() * 100), 2),
        })
    numeric = pd.DataFrame(numeric_rows)
    if not numeric.empty:
        numeric = numeric.sort_values("mean_change", key=lambda s: s.abs(), ascending=False).head(50).reset_index(drop=True)

    category_rows: list[dict[str, Any]] = []
    for col in sorted(current_cols & comparison_cols):
        if pd.api.types.is_numeric_dtype(current_df[col]) and pd.api.types.is_numeric_dtype(comparison_df[col]):
            continue
        cur_s = current_df[col].dropna().astype(str)
        comp_s = comparison_df[col].dropna().astype(str)
        if cur_s.empty or comp_s.empty or cur_s.nunique() > config.grouped_max_categories or comp_s.nunique() > config.grouped_max_categories:
            continue
        values = set(cur_s.value_counts().head(10).index).union(set(comp_s.value_counts().head(10).index))
        for value in values:
            cur_share = float((cur_s == value).mean())
            comp_share = float((comp_s == value).mean())
            category_rows.append({
                "column": col,
                "value": value,
                "current_share_pct": round(cur_share * 100, 2),
                "comparison_share_pct": round(comp_share * 100, 2),
                "share_point_change": round((cur_share - comp_share) * 100, 2),
            })
    categories = pd.DataFrame(category_rows)
    if not categories.empty:
        categories = categories.sort_values("share_point_change", key=lambda s: s.abs(), ascending=False).head(50).reset_index(drop=True)

    missing = pd.DataFrame({
        "column": sorted(current_cols & comparison_cols),
    })
    if not missing.empty:
        missing["current_missing_pct"] = [round(float(current_df[c].isna().mean() * 100), 2) for c in missing["column"]]
        missing["comparison_missing_pct"] = [round(float(comparison_df[c].isna().mean() * 100), 2) for c in missing["column"]]
        missing["missing_pct_change"] = missing["current_missing_pct"] - missing["comparison_missing_pct"]
        missing = missing.sort_values("missing_pct_change", key=lambda s: s.abs(), ascending=False).head(50).reset_index(drop=True)

    return {"shape": shape, "columns": columns, "numeric_changes": numeric, "category_mix_changes": categories, "missingness_changes": missing}


def answer_data_question(question: str, df: pd.DataFrame, schema: Schema, scan: dict[str, Any] | None = None) -> dict[str, Any]:
    q = question.strip()
    if not q:
        return {"answer": "Ask a question about the loaded data.", "table": pd.DataFrame()}
    scan = scan or {}
    qlow = q.lower()
    if qlow.startswith("select"):
        if duckdb is None:
            return {"answer": "SQL mode requires duckdb. Install duckdb or ask a natural-language summary question.", "table": pd.DataFrame()}
        try:
            con = duckdb.connect(database=":memory:")
            con.register("data", df)
            table = con.execute(q).fetchdf()
            return {"answer": "SQL query executed against table named data.", "table": table}
        except Exception as exc:
            return {"answer": f"SQL query failed: {exc}", "table": pd.DataFrame()}
    if "missing" in qlow:
        table = missingness_report(df).head(20)
        return {"answer": "Here are the columns with the most missing values.", "table": table}
    if "correlation" in qlow or "correlat" in qlow:
        cfg = WorkbenchConfig()
        table = strongest_correlations(df, cfg).head(20)
        return {"answer": "Here are the strongest numeric relationships.", "table": table}

    if "feature" in qlow and any(word in qlow for word in ["predict", "driver", "importance", "explain"]):
        drivers = scan.get("feature_importance")
        if not isinstance(drivers, pd.DataFrame) or drivers.empty:
            drivers = extract_model_drivers(scan.get("modeling"), top_n=20)
        if isinstance(drivers, pd.DataFrame) and not drivers.empty:
            return {"answer": "These features currently explain the model most strongly.", "table": drivers}
        return {"answer": "No model-driver table is available. Run supervised modeling and feature importance first.", "table": pd.DataFrame()}

    if "changed" in qlow or "change" in qlow or "month over month" in qlow or "period over period" in qlow:
        metric = next((c for c in schema.numeric if c.lower() in qlow), None)
        category = next((c for c in schema.categorical + schema.boolean if c.lower() in qlow), None)
        table = period_change_table(df, schema, WorkbenchConfig(), metric_col=metric, category_col=category)
        if not table.empty:
            return {"answer": "Here are the largest recent-versus-previous period changes I could detect.", "table": table}

    if "cluster" in qlow:
        clustered = pd.DataFrame()
        if scan.get("clustering") and isinstance(scan["clustering"].get("clustered_df"), pd.DataFrame):
            clustered = scan["clustering"]["clustered_df"]
        elif scan.get("clustering_comparison"):
            best = get_cluster_comparison_result(scan.get("clustering_comparison"), None)
            if best:
                clustered = clustered_sample_for_result(scan["clustering_comparison"], best)
        if isinstance(clustered, pd.DataFrame) and not clustered.empty and "cluster" in clustered.columns:
            metric = next((c for c in schema.numeric if c.lower() in qlow and c in clustered.columns), None)
            if metric and any(word in qlow for word in ["highest", "largest", "max", "average", "avg", "mean"]):
                table = clustered.groupby("cluster")[metric].agg(["count", "mean", "median", "min", "max"]).reset_index().sort_values("mean", ascending=False)
                top = table.iloc[0]
                return {"answer": f"Cluster {top['cluster']} has the highest average {metric} among clustered rows.", "table": table}
            m_cluster = re.search(r"cluster\s+(-?\d+)", qlow)
            if m_cluster:
                cluster_id = int(m_cluster.group(1))
                rows = clustered[clustered["cluster"] == cluster_id].head(200)
                return {"answer": f"Showing rows for cluster {cluster_id}.", "table": rows}
            fingerprints = scan.get("cluster_fingerprints")
            summary = fingerprints.get("summary") if isinstance(fingerprints, dict) else pd.DataFrame()
            if isinstance(summary, pd.DataFrame) and not summary.empty:
                return {"answer": "Here are the business-readable cluster personas and fingerprints.", "table": summary}
        return {"answer": "Cluster answers require clustering to be run first.", "table": pd.DataFrame()}

    if "anomaly" in qlow or "outlier" in qlow:
        explanations = scan.get("anomaly_explanations")
        anomaly = scan.get("anomaly")
        m_row = re.search(r"row\s+(\d+)", qlow)
        if m_row and anomaly and isinstance(anomaly.get("scored_df"), pd.DataFrame):
            row_idx = int(m_row.group(1))
            scored = anomaly["scored_df"]
            if 0 <= row_idx < len(scored):
                return {"answer": f"Here is anomaly scoring context for ranked anomaly row {row_idx}.", "table": scored.iloc[[row_idx]]}
        if isinstance(explanations, pd.DataFrame) and not explanations.empty:
            return {"answer": "These fields most explain the top flagged anomalies.", "table": explanations}
        if anomaly and isinstance(anomaly.get("scored_df"), pd.DataFrame):
            return {"answer": "Here are the most unusual records by anomaly score.", "table": anomaly["scored_df"].head(50)}
        return {"answer": "Anomaly answers require anomaly detection to be run first.", "table": pd.DataFrame()}

    if "insight" in qlow or "what matters" in qlow or "recommend" in qlow:
        insights = scan.get("auto_insights")
        if isinstance(insights, pd.DataFrame) and not insights.empty:
            return {"answer": "These are the highest-priority auto-detected insights.", "table": insights}
        de = scan.get("decision_engine")
        if de and isinstance(de.get("decision_df"), pd.DataFrame):
            return {"answer": "These are the current decision recommendations.", "table": de["decision_df"]}

    # Pattern: average/sum/count <metric> by <group>, plus "show <metric> by <group>".
    m = re.search(r"(?:show\s+)?(average|avg|mean|sum|total|count|median|max|min)?\s*([a-zA-Z0-9_ ]+?)\s+by\s+([a-zA-Z0-9_ ]+)", qlow)
    if m:
        agg_word, metric_text, group_text = m.groups()
        agg_word = agg_word or "mean"
        metric = find_column_like(metric_text, df.columns)
        group = find_column_like(group_text, df.columns)
        if group:
            agg = {"average": "mean", "avg": "mean", "mean": "mean", "total": "sum"}.get(agg_word, agg_word)
            try:
                if agg == "count" or metric is None:
                    table = df.groupby(group).size().reset_index(name="count").sort_values("count", ascending=False).head(50)
                else:
                    temp = df[[group, metric]].copy()
                    temp[metric] = pd.to_numeric(temp[metric], errors="coerce")
                    table = temp.dropna().groupby(group)[metric].agg(["count", agg]).reset_index().sort_values(agg, ascending=False).head(50)
                return {"answer": f"Grouped {agg} result by {group}.", "table": table}
            except Exception as exc:
                return {"answer": f"Could not compute grouped result: {exc}", "table": pd.DataFrame()}
    if "top" in qlow or "best" in qlow or "highest" in qlow:
        metric = next((c for c in schema.numeric if c.lower() in qlow), schema.numeric[0] if schema.numeric else None)
        if metric:
            table = df.sort_values(metric, ascending=False).head(20)
            return {"answer": f"Rows with the highest values of {metric}.", "table": table}
    if "worst" in qlow or "lowest" in qlow:
        metric = next((c for c in schema.numeric if c.lower() in qlow), schema.numeric[0] if schema.numeric else None)
        if metric:
            table = df.sort_values(metric, ascending=True).head(20)
            return {"answer": f"Rows with the lowest values of {metric}.", "table": table}
    if "shape" in qlow or "rows" in qlow or "columns" in qlow:
        return {"answer": f"The dataset has {len(df):,} rows and {df.shape[1]:,} columns.", "table": pd.DataFrame()}
    recs = recommend_modules_for_dataset(df, schema)
    return {"answer": "I could not parse a precise calculation, so here are recommended modules for this dataset. Try: 'average revenue by region', 'missing values', 'correlations', or a SQL SELECT query against table data.", "table": recs}


def find_column_like(text: str, columns: Any) -> str | None:
    clean = re.sub(r"[^a-zA-Z0-9]+", "_", text.strip().lower()).strip("_")
    cols = list(columns)
    low_map = {c.lower(): c for c in cols}
    if clean in low_map:
        return low_map[clean]
    for c in cols:
        if clean and clean in c.lower():
            return c
    words = [w for w in clean.split("_") if w]
    for c in cols:
        low = c.lower()
        if words and all(w in low for w in words):
            return c
    return None




def df_to_markdown_safe(df: pd.DataFrame, max_rows: int = 25) -> str:
    try:
        return df.head(max_rows).to_markdown(index=False)
    except Exception:
        return "```\n" + df.head(max_rows).to_string(index=False) + "\n```"

def build_markdown_report(scan: dict[str, Any], config: WorkbenchConfig) -> str:
    lines = ["# betterlytics report", "", "## Executive summary", "", scan.get("narrative", "No narrative available."), ""]
    profile = scan.get("profile", {})
    if profile:
        lines += ["## Dataset", "", f"- Rows: {profile.get('shape', ['?','?'])[0]:,}", f"- Columns: {profile.get('shape', ['?','?'])[1]:,}", f"- Duplicate rows: {profile.get('duplicate_rows', 0):,}", f"- Memory MB: {safe_float(profile.get('memory_mb')):.2f}", ""]
    if scan.get("health_flags"):
        lines += ["## Data quality watchouts", ""] + [f"- {x}" for x in scan.get("health_flags", [])] + [""]
    if isinstance(scan.get("auto_insights"), pd.DataFrame) and not scan["auto_insights"].empty:
        lines += ["## Auto-detected insights", "", df_to_markdown_safe(scan["auto_insights"], config.max_report_rows), ""]
    for key, title in [("correlations", "Strongest correlations"), ("feature_importance", "Feature importance"), ("grouped_insights", "Grouped insights")]:
        obj = scan.get(key)
        if isinstance(obj, pd.DataFrame) and not obj.empty:
            lines += [f"## {title}", "", df_to_markdown_safe(obj, config.max_report_rows), ""]
    fingerprints = scan.get("cluster_fingerprints")
    fp_summary = fingerprints.get("summary") if isinstance(fingerprints, dict) else pd.DataFrame()
    if isinstance(fp_summary, pd.DataFrame) and not fp_summary.empty:
        lines += ["## Cluster segmentation report", "", df_to_markdown_safe(fp_summary, config.max_report_rows), ""]
    cluster_compare = scan.get("clustering_comparison")
    if cluster_compare and isinstance(cluster_compare.get("summary"), pd.DataFrame):
        lines += ["## Clustering comparison", "", df_to_markdown_safe(cluster_compare["summary"], config.max_report_rows), ""]
    comparison = scan.get("dataset_comparison")
    if isinstance(comparison, dict):
        lines += ["## Dataset comparison", "", "### Shape and quality", "", df_to_markdown_safe(comparison.get("shape", pd.DataFrame()), config.max_report_rows), ""]
        numeric_changes = comparison.get("numeric_changes", pd.DataFrame())
        if isinstance(numeric_changes, pd.DataFrame) and not numeric_changes.empty:
            lines += ["### Largest numeric changes", "", df_to_markdown_safe(numeric_changes, config.max_report_rows), ""]
    modeling = scan.get("modeling")
    if modeling and isinstance(modeling.get("leaderboard"), pd.DataFrame):
        lb = modeling["leaderboard"].drop(columns=[c for c in ["report", "confusion_matrix", "score_for_ranking", "labels"] if c in modeling["leaderboard"].columns], errors="ignore")
        lines += ["## Modeling leaderboard", "", df_to_markdown_safe(lb, config.max_report_rows), ""]
    de = scan.get("decision_engine")
    if de and isinstance(de.get("decision_df"), pd.DataFrame):
        lines += ["## Recommended actions", "", df_to_markdown_safe(de["decision_df"], config.max_report_rows), ""]
    lines += ["## Caveats and methods", ""]
    if scan.get("run_log"):
        lines += ["Modules run:", "", df_to_markdown_safe(pd.DataFrame(scan.get("run_log", [])), config.max_report_rows), ""]
    lines += [
        "- Results are generated from the uploaded dataset and selected modules.",
        "- Sampling caps may apply to modeling, clustering, anomaly detection, plotting, and text scans.",
        "- Correlation, clustering, anomaly, and model-importance results are decision support, not causal proof.",
        "- Validate high-impact findings on fresh or holdout data before automation.",
        "",
    ]
    return "\n".join(lines)


