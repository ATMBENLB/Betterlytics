            "used_text_features": modeling.get("used_text_features", []),
            "trained_rows": modeling.get("trained_rows"),
        }
    clustering = scan.get("clustering")
    if clustering:
        out["clustering"] = {
            "k": clustering.get("k"),
            "silhouette": clustering.get("silhouette"),
            "sampled_rows": clustering.get("sampled_rows"),
            "sampled": clustering.get("sampled"),
            "numeric_columns_used": clustering.get("numeric_columns_used"),
            "clustered_sample": records(clustering.get("clustered_df"), config.json_table_rows),
        }
    cluster_compare = scan.get("clustering_comparison")
    if cluster_compare:
        best = get_cluster_comparison_result(cluster_compare, cluster_compare.get("best_result_id"))
        best_payload: dict[str, Any] = {}
        if best:
            connections = best.get("connections", {})
            best_payload = {
                "result_id": best.get("result_id"),
                "method": best.get("method"),
                "parameter": best.get("parameter"),
                "clusters": best.get("clusters"),
                "silhouette": best.get("silhouette"),
                "profiles": records(best.get("profiles"), config.json_table_rows),
                "fingerprints": records(best.get("fingerprints", {}).get("summary") if isinstance(best.get("fingerprints"), dict) else None, config.json_table_rows),
                "cluster_sizes": records(connections.get("cluster_sizes") if isinstance(connections, dict) else None, config.json_table_rows),
                "numeric_connections": records(connections.get("numeric_connections") if isinstance(connections, dict) else None, config.json_table_rows),
                "categorical_connections": records(connections.get("categorical_connections") if isinstance(connections, dict) else None, config.json_table_rows),
                "target_by_cluster": records(connections.get("target_by_cluster") if isinstance(connections, dict) else None, config.json_table_rows),
            }
        out["clustering_comparison"] = {
            "summary": records(cluster_compare.get("summary"), config.json_table_rows),
            "pairwise_similarity": records(cluster_compare.get("pairwise_similarity"), config.json_table_rows),
            "best_result_id": cluster_compare.get("best_result_id"),
            "sampled_rows": cluster_compare.get("sampled_rows"),
            "sampled": cluster_compare.get("sampled"),
            "numeric_columns_used": cluster_compare.get("numeric_columns_used", []),
            "best_result": best_payload,
        }
    if isinstance(scan.get("anomaly_explanations"), pd.DataFrame):
        out["anomaly_explanations"] = records(scan["anomaly_explanations"], config.json_table_rows)
    anomaly = scan.get("anomaly")
    if anomaly:
        out["anomaly"] = {
            "anomaly_count": anomaly.get("anomaly_count"),
            "anomaly_rate_pct": anomaly.get("anomaly_rate_pct"),
            "sampled_rows": anomaly.get("sampled_rows"),
            "sampled": anomaly.get("sampled"),
            "top_anomalies": records(anomaly.get("scored_df"), config.json_table_rows),
        }
    if scan.get("nlp_topics"):
        out["nlp_topics"] = {
            "topics": records(scan["nlp_topics"].get("topics"), config.json_table_rows),
            "complaints": records(scan["nlp_topics"].get("complaints"), config.json_table_rows),
            "simple_entities": records(scan["nlp_topics"].get("simple_entities"), config.json_table_rows),
        }
    text = scan.get("text")
    if text:
        out["text"] = {
            "text_col": scan.get("text_col"),
            "top_terms": records(text.get("top_terms"), config.json_table_rows),
            "sentiment": records(text.get("sentiment"), config.json_table_rows),
            "rows_scanned": text.get("rows_scanned"),
        }
    ts = scan.get("time_series")
    if ts:
        out["time_series"] = {
            "date_col": ts.get("date_col"),
            "value_col": ts.get("value_col"),
            "frequency": ts.get("frequency"),
            "aggregation": ts.get("aggregation"),
            "model_used": ts.get("model_used"),
            "seasonality": ts.get("seasonality"),
            "trend": ts.get("trend"),
            "latest": ts.get("latest"),
            "reference": ts.get("reference"),
            "backtest_metrics": ts.get("backtest_metrics"),
            "series_tail": records(ts.get("series"), config.json_table_rows),
            "forecast": records(ts.get("forecast"), config.json_table_rows),
        }
    if isinstance(scan.get("time_anomalies"), pd.DataFrame):
        out["time_anomalies"] = records(scan["time_anomalies"], config.json_table_rows)
    if scan.get("geospatial_summary"):
        out["geospatial_summary"] = {
            "summary": records(scan["geospatial_summary"].get("summary"), config.json_table_rows),
            "nearest_to_reference": records(scan["geospatial_summary"].get("distance_table"), config.json_table_rows),
        }
    domain = scan.get("domain_insights")
    if domain:
        out["domain_insights"] = {
            "domain_table": records(domain.get("domain_table"), config.json_table_rows),
            "special_signals": domain.get("special_signals", []),
            "recommended_modules": domain.get("recommended_modules", []),
        }
    de = scan.get("decision_engine")
    if de:
        out["decision_engine"] = {
            "decision_df": records(de.get("decision_df"), config.json_table_rows),
            "opportunities": de.get("opportunities", []),
            "risks": de.get("risks", []),
            "summary": de.get("summary"),
        }
    return json.dumps(out, default=str, indent=2)


