def markdown_to_simple_html(markdown_text: str) -> str:
    # Lightweight rendering without extra dependencies.
    html_lines = ["<html><head><meta charset='utf-8'><title>betterlytics report</title><style>body{font-family:Arial,sans-serif;max-width:1100px;margin:40px auto;line-height:1.5}table{border-collapse:collapse;width:100%;margin:16px 0}td,th{border:1px solid #ddd;padding:6px}th{background:#f5f5f5}code,pre{background:#f7f7f7}</style></head><body>"]
    in_table = False
    for line in markdown_text.splitlines():
        if line.startswith("# "):
            html_lines.append(f"<h1>{line[2:]}</h1>")
        elif line.startswith("## "):
            html_lines.append(f"<h2>{line[3:]}</h2>")
        elif line.startswith("- "):
            html_lines.append(f"<p>&bull; {line[2:]}</p>")
        elif "|" in line and set(line.replace("|", "").replace(":", "").replace("-", "").strip()) == set():
            continue
        elif line.startswith("|") and line.endswith("|"):
            cells = [c.strip() for c in line.strip("|").split("|")]
            tag = "th" if not in_table else "td"
            if not in_table:
                html_lines.append("<table>")
                in_table = True
            html_lines.append("<tr>" + "".join([f"<{tag}>{c}</{tag}>" for c in cells]) + "</tr>")
        else:
            if in_table:
                html_lines.append("</table>")
                in_table = False
            if line.strip():
                html_lines.append(f"<p>{line}</p>")
    if in_table:
        html_lines.append("</table>")
    html_lines.append("</body></html>")
    return "\n".join(html_lines)


def build_enriched_exports(df: pd.DataFrame, scan: dict[str, Any], config: WorkbenchConfig) -> dict[str, pd.DataFrame]:
    exports: dict[str, pd.DataFrame] = {}
    modeling = scan.get("modeling")
    if modeling:
        best_name, detail = _best_model_bundle(modeling)
        if detail:
            try:
                sample = safe_sample_df(df, min(config.max_model_rows, 50000))
                target = modeling.get("target")
                X_raw = make_feature_frame(sample, target=target)
                enc = detail["preprocessor"].transform(X_raw)
                if detail.get("requires_dense"):
                    enc = to_dense_if_needed(enc)
                pred = detail["model_object"].predict(enc)
                pred_df = sample.copy()
                pred_df[f"betterlytics_prediction_{target}"] = pred
                exports["predictions"] = pred_df
            except Exception:
                pass
    if scan.get("clustering") and isinstance(scan["clustering"].get("clustered_df"), pd.DataFrame):
        exports["clustered_sample"] = scan["clustering"]["clustered_df"]
    if scan.get("anomaly") and isinstance(scan["anomaly"].get("scored_df"), pd.DataFrame):
        exports["anomaly_sample"] = scan["anomaly"]["scored_df"]
    if scan.get("cleaning") and isinstance(scan["cleaning"].get("cleaned_df"), pd.DataFrame):
        exports["cleaned_data"] = scan["cleaning"]["cleaned_df"]
    return exports


def run_optimizer(modeling: dict[str, Any] | None, base_row: pd.Series, variable: str, goal: str = "maximize") -> pd.DataFrame:
    best_name, detail = _best_model_bundle(modeling)
    if not modeling or not detail or variable not in base_row.index:
        return pd.DataFrame()
    if not pd.api.types.is_numeric_dtype(pd.Series([base_row[variable]])):
        return pd.DataFrame()
    target = modeling.get("target")
    model = detail.get("model_object")
    prep = detail.get("preprocessor")
    if model is None or prep is None:
        return pd.DataFrame()
    base_val = safe_float(base_row[variable])
    if base_val == 0:
        grid = np.linspace(-10, 10, 41)
    else:
        grid = np.linspace(base_val * 0.5, base_val * 1.5, 41)
    rows: list[dict[str, Any]] = []
    for val in grid:
        row = base_row.copy()
        row[variable] = val
        try:
            X = make_feature_frame(pd.DataFrame([row]), target=target)
            enc = prep.transform(X)
            if detail.get("requires_dense"):
                enc = to_dense_if_needed(enc)
            pred = model.predict(enc)[0]
            score = safe_float(pred, np.nan)
            rows.append({"variable": variable, "value": float(val), "prediction": pred, "numeric_score": score})
        except Exception:
            continue
    out = pd.DataFrame(rows)
    if out.empty:
        return out
    return out.sort_values("numeric_score", ascending=(goal == "minimize")).reset_index(drop=True)


