def template_default(template: str, module_key: str, fallback: bool = False) -> bool:
    return module_key in DOMAIN_TEMPLATES.get(template, DOMAIN_TEMPLATES["General analytics"])["modules"] or fallback


def data_quality_score(df: pd.DataFrame, schema: Schema) -> dict[str, Any]:
    missing_penalty = min(30, float(df.isna().mean().mean()) * 100)
    duplicate_penalty = min(15, float(df.duplicated().mean()) * 100)
    constant_cols = [c for c in df.columns if df[c].nunique(dropna=True) <= 1]
    constant_penalty = min(15, len(constant_cols) / max(1, df.shape[1]) * 100)
    id_penalty = min(10, len(schema.id_like) / max(1, df.shape[1]) * 50)
    type_penalty = 0.0
    for c in df.columns:
        if df[c].dtype == object:
            non_null = df[c].dropna().astype(str)
            if len(non_null) and pd.to_numeric(non_null.sample(min(len(non_null), 200), random_state=42), errors="coerce").notna().mean() > 0.9:
                type_penalty += 1.0
    type_penalty = min(10, type_penalty)
    row_penalty = 10 if len(df) < 50 else 5 if len(df) < 200 else 0
    score = max(0.0, 100.0 - missing_penalty - duplicate_penalty - constant_penalty - id_penalty - type_penalty - row_penalty)
    return {
        "score": round(score, 1),
        "grade": "A" if score >= 90 else "B" if score >= 80 else "C" if score >= 70 else "D" if score >= 60 else "F",
        "penalties": {
            "missingness": round(missing_penalty, 2),
            "duplicates": round(duplicate_penalty, 2),
            "constant_columns": round(constant_penalty, 2),
            "id_like_columns": round(id_penalty, 2),
            "type_inconsistency": round(type_penalty, 2),
            "sample_size": row_penalty,
        },
        "constant_columns": constant_cols,
    }


def clean_dataset(
    df: pd.DataFrame,
    schema: Schema,
    config: WorkbenchConfig,
    remove_duplicates: bool = True,
    drop_empty_cols: bool = True,
    convert_numeric_text: bool = True,
    normalize_categories: bool = True,
    impute_missing: bool = False,
    winsorize_outliers: bool = False,
) -> dict[str, Any]:
    out = df.copy()
    steps: list[str] = []

    if remove_duplicates:
        before = len(out)
        out = out.drop_duplicates().copy()
        steps.append(f"Removed {before - len(out):,} duplicate rows")

    if drop_empty_cols:
        before_cols = out.shape[1]
        out = out.dropna(axis=1, how="all")
        constant_empty = [c for c in out.columns if out[c].nunique(dropna=True) <= 1 and out[c].isna().mean() > 0.95]
        out = out.drop(columns=constant_empty, errors="ignore")
        steps.append(f"Dropped {before_cols - out.shape[1]:,} empty or near-empty columns")

    if convert_numeric_text:
        converted: list[str] = []
        for c in out.columns:
            if out[c].dtype == object:
                cleaned = out[c].astype(str).str.replace(r"[$,%]", "", regex=True).str.replace(",", "", regex=False)
                numeric = pd.to_numeric(cleaned, errors="coerce")
                if numeric.notna().mean() >= 0.9 and numeric.notna().sum() >= 5:
                    out[c] = numeric
                    converted.append(c)
        if converted:
            steps.append("Converted numeric-looking text columns: " + ", ".join(converted[:25]))

    if normalize_categories:
        normed: list[str] = []
        for c in out.select_dtypes(include=[object]).columns:
            nunique = out[c].nunique(dropna=True)
            if 1 < nunique <= max(config.max_onehot_unique, 100):
                out[c] = out[c].astype(str).str.strip().str.replace(r"\s+", " ", regex=True)
                normed.append(c)
        if normed:
            steps.append("Standardized whitespace for category/text columns: " + ", ".join(normed[:25]))

    if winsorize_outliers:
        numeric_cols = out.select_dtypes(include=[np.number]).columns.tolist()
        capped: list[str] = []
        q = config.winsorize_quantile
        for c in numeric_cols:
            vals = pd.to_numeric(out[c], errors="coerce")
            if vals.notna().sum() < 20:
                continue
            lo, hi = vals.quantile([q, 1 - q])
            if pd.notna(lo) and pd.notna(hi) and lo < hi:
                changed = ((vals < lo) | (vals > hi)).sum()
                if changed:
                    out[c] = vals.clip(lo, hi)
                    capped.append(c)
        if capped:
            steps.append("Winsorized extreme numeric values: " + ", ".join(capped[:25]))

    if impute_missing:
        num_cols = out.select_dtypes(include=[np.number]).columns.tolist()
        cat_cols = [c for c in out.columns if c not in num_cols and not pd.api.types.is_datetime64_any_dtype(out[c])]
        for c in num_cols:
            out[c] = out[c].fillna(out[c].median())
        for c in cat_cols:
            mode = out[c].mode(dropna=True)
            if not mode.empty:
                out[c] = out[c].fillna(mode.iloc[0])
        steps.append(f"Imputed missing values in {len(num_cols)} numeric and {len(cat_cols)} categorical/text columns")

    new_schema = infer_schema(out)
    return {
        "cleaned_df": out,
        "steps": steps or ["No cleaning changes were applied"],
        "before_shape": df.shape,
        "after_shape": out.shape,
        "quality_before": data_quality_score(df, schema),
        "quality_after": data_quality_score(out, new_schema),
    }


def create_engineered_features(df: pd.DataFrame, schema: Schema, config: WorkbenchConfig) -> dict[str, Any]:
    out = df.copy()
    created: list[str] = []
    # Datetime features.
    for c in schema.datetime:
        if c not in out.columns:
            continue
        out[f"{c}_year"] = out[c].dt.year
        out[f"{c}_month"] = out[c].dt.month
        out[f"{c}_dayofweek"] = out[c].dt.dayofweek
        out[f"{c}_is_weekend"] = out[c].dt.dayofweek.isin([5, 6]).astype(int)
        out[f"{c}_quarter"] = out[c].dt.quarter
        created.extend([f"{c}_year", f"{c}_month", f"{c}_dayofweek", f"{c}_is_weekend", f"{c}_quarter"])
    # Numeric z-scores and simple ratios for the highest-variance columns.
    numeric_cols = choose_numeric_columns_by_variance(out, min(12, config.max_unsupervised_numeric_cols))
    for c in numeric_cols[:10]:
        vals = pd.to_numeric(out[c], errors="coerce")
        std = vals.std()
        if pd.notna(std) and std > 0:
            out[f"{c}_zscore"] = (vals - vals.mean()) / std
            created.append(f"{c}_zscore")
    ratio_count = 0
    for i, a in enumerate(numeric_cols[:8]):
        for b in numeric_cols[i + 1:8]:
            denom = pd.to_numeric(out[b], errors="coerce").replace(0, np.nan)
            num = pd.to_numeric(out[a], errors="coerce")
            col = f"{a}_per_{b}"
            out[col] = num / denom
            created.append(col)
            ratio_count += 1
            if ratio_count >= 12:
                break
        if ratio_count >= 12:
            break
    # Category frequencies.
    for c in (schema.categorical + schema.boolean)[:12]:
        if c in out.columns and out[c].nunique(dropna=True) <= config.max_pivot_categories:
            freq = out[c].map(out[c].value_counts(dropna=False))
            out[f"{c}_frequency"] = freq
            created.append(f"{c}_frequency")
    return {"engineered_df": out, "created_features": created, "preview": out[created].head(100) if created else pd.DataFrame()}


def run_distribution_analysis(df: pd.DataFrame, schema: Schema, config: WorkbenchConfig) -> pd.DataFrame:
    rows: list[dict[str, Any]] = []
    for c in schema.numeric:
        vals = pd.to_numeric(df[c], errors="coerce").replace([np.inf, -np.inf], np.nan).dropna()
        if vals.empty:
            continue
        q1, q3 = vals.quantile([0.25, 0.75])
        iqr = q3 - q1
        outliers_iqr = int(((vals < q1 - 1.5 * iqr) | (vals > q3 + 1.5 * iqr)).sum()) if iqr > 0 else 0
        std = vals.std()
        z_outliers = int((((vals - vals.mean()).abs() / std) > config.outlier_z_threshold).sum()) if std and std > 0 else 0
        rows.append({
            "column": c,
            "count": int(vals.count()),
            "mean": float(vals.mean()),
            "median": float(vals.median()),
            "std": float(std) if pd.notna(std) else np.nan,
            "min": float(vals.min()),
            "p05": float(vals.quantile(0.05)),
            "p25": float(q1),
            "p75": float(q3),
            "p95": float(vals.quantile(0.95)),
            "max": float(vals.max()),
            "skew": float(vals.skew()) if len(vals) >= 3 else np.nan,
            "kurtosis": float(vals.kurtosis()) if len(vals) >= 4 else np.nan,
            "iqr_outliers": outliers_iqr,
            "z_outliers": z_outliers,
        })
    return pd.DataFrame(rows).sort_values("z_outliers", ascending=False).reset_index(drop=True) if rows else pd.DataFrame()


def make_box_plot(df: pd.DataFrame, column: str):
    values = pd.to_numeric(df[column], errors="coerce").dropna()
    fig, ax = plt.subplots(figsize=(7, 3.5))
    if values.empty:
        ax.text(0.5, 0.5, "No numeric data", ha="center", va="center")
        ax.axis("off")
        return fig
    values = values.sample(min(len(values), 20000), random_state=42) if len(values) > 20000 else values
    ax.boxplot(values, vert=False)
    ax.set_title(f"Box plot of {column}")
    ax.set_xlabel(column)
    fig.tight_layout()
    return fig


def build_pivot_table(df: pd.DataFrame, row_col: str | None, col_col: str | None, value_col: str | None, agg: str, config: WorkbenchConfig) -> pd.DataFrame:
    if not row_col or row_col not in df.columns:
        return pd.DataFrame()
    if value_col and value_col in df.columns:
        values = value_col
    else:
        values = None
    if df[row_col].nunique(dropna=True) > config.max_pivot_categories:
        top_values = df[row_col].value_counts().head(config.max_pivot_categories).index
        temp = df[df[row_col].isin(top_values)].copy()
    else:
        temp = df.copy()
    if col_col and col_col in temp.columns and temp[col_col].nunique(dropna=True) > config.max_pivot_categories:
        top_cols = temp[col_col].value_counts().head(config.max_pivot_categories).index
        temp = temp[temp[col_col].isin(top_cols)].copy()
    aggfunc = {"mean": "mean", "sum": "sum", "count": "count", "median": "median", "min": "min", "max": "max"}.get(agg, "mean")
    try:
        pivot = pd.pivot_table(temp, index=row_col, columns=col_col if col_col else None, values=values, aggfunc=aggfunc, fill_value=0, margins=True)
        return pivot.reset_index()
    except Exception:
        return pd.DataFrame()


def run_statistical_tests(df: pd.DataFrame, schema: Schema, metric_col: str | None, group_col: str | None, target_col: str | None, config: WorkbenchConfig) -> dict[str, Any]:
    results: list[dict[str, Any]] = []
    sample = safe_sample_df(df, config.max_stat_test_rows)
    metric = metric_col if metric_col in sample.columns and pd.api.types.is_numeric_dtype(sample[metric_col]) else (schema.numeric[0] if schema.numeric else None)
    group = group_col if group_col in sample.columns else (schema.categorical[0] if schema.categorical else None)

    if stats is None:
        return {"results": pd.DataFrame([{"test": "Unavailable", "note": "scipy is not installed"}])}

    if metric:
        vals = pd.to_numeric(sample[metric], errors="coerce").dropna()
        if len(vals) >= 8:
            try:
                stat, p = stats.normaltest(vals.sample(min(len(vals), 5000), random_state=42) if len(vals) > 5000 else vals)
                results.append({"test": "Normality", "columns": metric, "statistic": float(stat), "p_value": float(p), "interpretation": "Likely non-normal" if p < 0.05 else "No strong evidence against normality"})
            except Exception:
                pass
    if metric and group:
        temp = sample[[metric, group]].dropna().copy()
        temp[metric] = pd.to_numeric(temp[metric], errors="coerce")
        temp = temp.dropna()
        groups = [g[metric].values for _, g in temp.groupby(group) if len(g) >= 3]
        group_count = len(groups)
        if group_count == 2:
            stat, p = stats.ttest_ind(groups[0], groups[1], equal_var=False, nan_policy="omit")
            results.append({"test": "Welch t-test", "columns": f"{metric} by {group}", "groups": group_count, "statistic": float(stat), "p_value": float(p), "interpretation": "Group means likely differ" if p < 0.05 else "No strong evidence of different means"})
        elif group_count > 2 and group_count <= 25:
            stat, p = stats.f_oneway(*groups)
            results.append({"test": "ANOVA", "columns": f"{metric} by {group}", "groups": group_count, "statistic": float(stat), "p_value": float(p), "interpretation": "At least one group mean likely differs" if p < 0.05 else "No strong evidence of mean differences"})
    cat_candidates = [c for c in schema.categorical + schema.boolean if c in sample.columns and sample[c].nunique(dropna=True) <= 30]
    if len(cat_candidates) >= 2:
        c1 = target_col if target_col in cat_candidates else cat_candidates[0]
        c2 = next((c for c in cat_candidates if c != c1), None)
        if c2:
            table = pd.crosstab(sample[c1], sample[c2])
            if table.shape[0] >= 2 and table.shape[1] >= 2:
                chi2, p, dof, _ = stats.chi2_contingency(table)
                results.append({"test": "Chi-square independence", "columns": f"{c1} vs {c2}", "degrees_of_freedom": int(dof), "statistic": float(chi2), "p_value": float(p), "interpretation": "Categorical association likely" if p < 0.05 else "No strong categorical association"})
    return {"results": pd.DataFrame(results) if results else pd.DataFrame([{"test": "No suitable tests", "note": "Need numeric/group or two categorical columns with enough data."}])}


def detect_kpis(df: pd.DataFrame, schema: Schema) -> dict[str, Any]:
    kpi_keywords = {
        "revenue": ["revenue", "sales", "gmv", "income"],
        "cost": ["cost", "expense", "spend", "cogs"],
        "profit": ["profit", "margin", "gross"],
        "orders": ["order", "orders", "transactions", "bookings"],
        "quantity": ["quantity", "qty", "units", "volume"],
        "conversion": ["conversion", "convert", "signup", "lead"],
        "retention/churn": ["retention", "churn", "cancel"],
        "delay/service": ["delay", "late", "sla", "resolution", "duration", "lead_time"],
        "rating/quality": ["rating", "score", "quality", "defect", "return"],
        "weather": ["temperature", "temp", "humidity", "rain", "precip", "wind", "pressure"],
        "sports": ["points", "score", "goals", "assists", "rebounds", "shots", "minutes", "wins"],
    }
    rows: list[dict[str, Any]] = []
    for c in df.columns:
        low = c.lower()
        for family, keys in kpi_keywords.items():
            if any(k in low for k in keys):
                vals = pd.to_numeric(df[c], errors="coerce") if c in schema.numeric else None
                rows.append({
                    "column": c,
                    "kpi_family": family,
                    "role": "numeric" if c in schema.numeric else "categorical/text/date",
                    "non_missing": int(df[c].notna().sum()),
                    "missing_pct": round(float(df[c].isna().mean() * 100), 2),
                    "mean": float(vals.mean()) if vals is not None and vals.notna().any() else np.nan,
                    "latest": df[c].dropna().iloc[-1] if df[c].dropna().shape[0] else np.nan,
                })
                break
    kpi_df = pd.DataFrame(rows).sort_values(["kpi_family", "column"]).reset_index(drop=True) if rows else pd.DataFrame()
    cards: list[dict[str, Any]] = []
    for _, row in kpi_df[kpi_df["role"] == "numeric"].head(12).iterrows() if not kpi_df.empty else []:
        col = row["column"]
        vals = pd.to_numeric(df[col], errors="coerce").dropna()
        if vals.empty:
            continue
        cards.append({"KPI": col, "mean": float(vals.mean()), "median": float(vals.median()), "min": float(vals.min()), "max": float(vals.max()), "non_missing": int(vals.count())})
    return {"kpi_table": kpi_df, "kpi_cards": pd.DataFrame(cards)}


def run_leakage_checks(df: pd.DataFrame, schema: Schema, target: str | None) -> pd.DataFrame:
    rows: list[dict[str, Any]] = []
    if not target or target not in df.columns:
        return pd.DataFrame([{"severity": "Info", "issue": "No target selected", "feature": "", "details": "Leakage checks require a supervised target."}])
    target_low = target.lower()
    y = df[target]
    suspicious_words = ["target", "label", "outcome", "final", "result", "post", "after", "future", "actual", "prediction", target_low]
    for c in df.columns:
        if c == target:
            continue
        low = c.lower()
        name_hits = [w for w in suspicious_words if w and w in low]
        if name_hits:
            rows.append({"severity": "Medium", "issue": "Suspicious feature name", "feature": c, "details": f"Contains target/outcome-like word(s): {', '.join(name_hits[:5])}"})
        if c in schema.id_like:
            rows.append({"severity": "Low", "issue": "ID-like feature", "feature": c, "details": "IDs can memorize rows and usually should not be used as predictors."})
        try:
            if pd.api.types.is_numeric_dtype(df[c]) and pd.api.types.is_numeric_dtype(y):
                temp = pd.concat([pd.to_numeric(df[c], errors="coerce"), pd.to_numeric(y, errors="coerce")], axis=1).dropna()
                if len(temp) >= 20:
                    corr = temp.iloc[:, 0].corr(temp.iloc[:, 1])
                    if pd.notna(corr) and abs(corr) >= 0.98:
                        rows.append({"severity": "High", "issue": "Near-perfect correlation with target", "feature": c, "details": f"Correlation with target is {corr:.3f}; check for leakage or duplicate target information."})
            else:
                overlap = (df[c].astype(str) == y.astype(str)).mean()
                if overlap >= 0.98:
                    rows.append({"severity": "High", "issue": "Nearly identical to target", "feature": c, "details": f"Matches target in {overlap:.1%} of rows."})
        except Exception:
            pass
    return pd.DataFrame(rows) if rows else pd.DataFrame([{"severity": "OK", "issue": "No obvious leakage", "feature": "", "details": "No high-confidence leakage signals were detected."}])


def _best_model_bundle(modeling: dict[str, Any] | None) -> tuple[str | None, dict[str, Any] | None]:
    if not modeling:
        return None, None
    name = modeling.get("best_model")
    detail = modeling.get("details", {}).get(name)
    return name, detail


def run_permutation_importance_scan(modeling: dict[str, Any] | None, config: WorkbenchConfig) -> pd.DataFrame:
    name, detail = _best_model_bundle(modeling)
    if not detail:
        return pd.DataFrame()
    model = detail.get("model_object")
    X_test = detail.get("X_test_encoded")
    y_test = detail.get("y_test")
    feature_names = detail.get("feature_names", [])
    if model is None or X_test is None or y_test is None:
        return pd.DataFrame()
    if len(feature_names) > config.max_permutation_features:
        return pd.DataFrame([{"feature": "Too many encoded features for safe permutation importance", "importance_mean": np.nan, "importance_std": np.nan}])
    X_eval = X_test
    # sklearn's permutation_importance is most reliable on dense arrays.
    # Keep the guard so a wide one-hot matrix cannot explode memory.
    if hasattr(X_eval, "toarray"):
        dense_cells = X_eval.shape[0] * X_eval.shape[1]
        if dense_cells > config.max_dense_cells:
            return pd.DataFrame([{"feature": "Permutation importance skipped", "importance_mean": np.nan, "importance_std": np.nan, "reason": f"Encoded matrix is too large to densify safely: {X_eval.shape[0]:,} x {X_eval.shape[1]:,}."}])
        X_eval = X_eval.toarray()
    elif detail.get("requires_dense"):
        X_eval = to_dense_if_needed(X_eval)
    if X_eval.shape[0] > 2000:
        rng = np.random.default_rng(42)
        idx = rng.choice(X_eval.shape[0], size=2000, replace=False)
        X_eval = X_eval[idx]
        y_eval = y_test.iloc[idx] if hasattr(y_test, "iloc") else np.asarray(y_test)[idx]
    else:
        y_eval = y_test
    try:
        result = permutation_importance(model, X_eval, y_eval, n_repeats=config.permutation_repeats, random_state=42, n_jobs=1)
        out = pd.DataFrame({"feature": feature_names, "importance_mean": result.importances_mean, "importance_std": result.importances_std})
        out = out.sort_values("importance_mean", ascending=False).head(30).reset_index(drop=True)
        return out
    except Exception as exc:
        return pd.DataFrame([{"feature": "Permutation importance failed", "importance_mean": np.nan, "importance_std": np.nan, "reason": str(exc)}])


def run_partial_dependence_lite(modeling: dict[str, Any] | None, df: pd.DataFrame, config: WorkbenchConfig, max_features: int = 4) -> pd.DataFrame:
    name, detail = _best_model_bundle(modeling)
    if not modeling or not detail:
        return pd.DataFrame()
    model = detail.get("model_object")
    preprocessor = detail.get("preprocessor")
    target = modeling.get("target")
    requires_dense = bool(detail.get("requires_dense"))
    if model is None or preprocessor is None:
        return pd.DataFrame()
    base = df.drop(columns=[target], errors="ignore").copy()
    numeric_cols = [c for c in base.columns if pd.api.types.is_numeric_dtype(base[c])]
    if not numeric_cols:
        return pd.DataFrame()
    sample = safe_sample_df(base, config.max_partial_dependence_rows)
    rows: list[dict[str, Any]] = []
    for c in numeric_cols[:max_features]:
        vals = pd.to_numeric(sample[c], errors="coerce").dropna()
        if vals.nunique() < 5:
            continue
        grid = np.unique(vals.quantile(np.linspace(0.05, 0.95, 9)).values)
        for value in grid:
            modified = sample.copy()
            modified[c] = value
            try:
                X_mod = make_feature_frame(modified, target=None)
                enc = preprocessor.transform(X_mod)
                if requires_dense:
                    enc = to_dense_if_needed(enc)
                preds = model.predict(enc)
                pred_numeric = pd.to_numeric(pd.Series(preds), errors="coerce")
                avg_pred = float(pred_numeric.mean()) if pred_numeric.notna().any() else np.nan
                rows.append({"feature": c, "value": float(value), "average_prediction": avg_pred})
            except Exception:
                continue
    return pd.DataFrame(rows)


def make_partial_dependence_plot(pd_df: pd.DataFrame):
    fig, ax = plt.subplots(figsize=(8, 5))
    if pd_df.empty:
        ax.text(0.5, 0.5, "No partial-dependence-style data", ha="center", va="center")
        ax.axis("off")
        return fig
    for feature, subset in pd_df.groupby("feature"):
        ax.plot(subset["value"], subset["average_prediction"], marker="o", label=str(feature)[:25])
    ax.set_title("What-if response curves")
    ax.set_xlabel("Feature value")
    ax.set_ylabel("Average prediction")
    ax.legend()
    fig.tight_layout()
    return fig


def run_model_diagnostics(modeling: dict[str, Any] | None, df: pd.DataFrame, schema: Schema, group_col: str | None = None) -> dict[str, Any]:
    if not modeling:
        return {}
    best_name, detail = _best_model_bundle(modeling)
    if not detail:
        return {}
    y_test = pd.Series(detail.get("y_test"))
    preds = pd.Series(detail.get("preds"))
    out: dict[str, Any] = {"best_model": best_name, "problem_type": modeling.get("problem_type")}
    if modeling.get("problem_type") == "regression":
        diag = pd.DataFrame({"actual": pd.to_numeric(y_test, errors="coerce"), "predicted": pd.to_numeric(preds, errors="coerce")}).dropna()
        if not diag.empty:
            diag["residual"] = diag["actual"] - diag["predicted"]
            diag["absolute_error"] = diag["residual"].abs()
            out["residual_summary"] = diag["residual"].describe().to_frame("residual").reset_index()
            out["worst_errors"] = diag.sort_values("absolute_error", ascending=False).head(50).reset_index(drop=True)
    else:
        labels = detail.get("labels") or sorted(pd.concat([y_test, preds]).dropna().unique().tolist(), key=lambda x: str(x))
        class_balance = y_test.value_counts(dropna=False).reset_index()
        class_balance.columns = ["class", "test_count"]
        out["class_balance"] = class_balance
        scores = detail.get("score_values")
        if scores is not None and len(labels) == 2:
            try:
                y_binary = (y_test.astype(str) == str(labels[1])).astype(int)
                score_arr = np.asarray(scores)
                if score_arr.ndim == 2:
                    score_arr = score_arr[:, -1]
                fpr, tpr, _ = roc_curve(y_binary, score_arr)
                precision, recall, _ = precision_recall_curve(y_binary, score_arr)
                out["roc_curve"] = pd.DataFrame({"fpr": fpr, "tpr": tpr})
                out["pr_curve"] = pd.DataFrame({"precision": precision, "recall": recall})
                out["roc_auc"] = float(roc_auc_score(y_binary, score_arr))
                out["pr_auc"] = float(auc(recall, precision))
            except Exception:
                pass
    return out


def make_residual_plot(diag: dict[str, Any]):
    fig, ax = plt.subplots(figsize=(7, 4.5))
    worst = diag.get("worst_errors")
    if not isinstance(worst, pd.DataFrame) or worst.empty:
        ax.text(0.5, 0.5, "No residual data", ha="center", va="center")
        ax.axis("off")
        return fig
    plot_df = worst.copy()
    ax.scatter(plot_df["predicted"], plot_df["residual"], alpha=0.7)
    ax.axhline(0)
    ax.set_title("Largest residuals")
    ax.set_xlabel("Predicted")
    ax.set_ylabel("Residual")
    fig.tight_layout()
    return fig


def make_roc_plot(diag: dict[str, Any]):
    fig, ax = plt.subplots(figsize=(6, 4.5))
    roc = diag.get("roc_curve")
    if not isinstance(roc, pd.DataFrame) or roc.empty:
        ax.text(0.5, 0.5, "ROC requires a binary classifier with scores", ha="center", va="center")
        ax.axis("off")
        return fig
    ax.plot(roc["fpr"], roc["tpr"], label=f"AUC {diag.get('roc_auc', np.nan):.3f}")
    ax.plot([0, 1], [0, 1])
    ax.set_title("ROC curve")
    ax.set_xlabel("False positive rate")
    ax.set_ylabel("True positive rate")
    ax.legend()
    fig.tight_layout()
    return fig


def make_pr_plot(diag: dict[str, Any]):
