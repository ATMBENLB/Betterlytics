def make_time_forecast_plotly(ts_result: dict[str, Any]):
    if go is None or not ts_result:
        return None
    ts = ts_result.get("series")
    forecast = ts_result.get("forecast")
    date_col = ts_result.get("date_col")
    value_col = ts_result.get("value_col")
    if not isinstance(ts, pd.DataFrame) or not isinstance(forecast, pd.DataFrame) or date_col not in ts.columns or value_col not in ts.columns:
        return None
    fig = go.Figure()
    fig.add_trace(go.Scatter(x=ts[date_col], y=ts[value_col], name="Actual", mode="lines+markers"))
    if "rolling_mean" in ts.columns:
        fig.add_trace(go.Scatter(x=ts[date_col], y=ts["rolling_mean"], name="Smoothed trend", mode="lines"))
    if "forecast_upper" in forecast.columns and "forecast_lower" in forecast.columns:
        fig.add_trace(go.Scatter(x=forecast[date_col], y=forecast["forecast_upper"], name="Upper confidence", mode="lines", line={"width": 0}, showlegend=False))
        fig.add_trace(go.Scatter(x=forecast[date_col], y=forecast["forecast_lower"], name="Approx. confidence interval", mode="lines", fill="tonexty", line={"width": 0}, fillcolor="rgba(20, 184, 166, 0.18)"))
    fig.add_trace(go.Scatter(x=forecast[date_col], y=forecast["forecast"], name="Forecast", mode="lines+markers"))
    fig.update_layout(title=f"Forecast with confidence interval ({ts_result.get('model_used', 'model')})", height=540, xaxis_title=date_col, yaxis_title=value_col)
    return fig


def render_interactive_visual_explorer(df: pd.DataFrame, schema: Schema, config: WorkbenchConfig, scan: dict[str, Any]) -> None:
    st.subheader("Interactive visual explorer")
    if px is None:
        st.info("Install plotly to enable hoverable interactive charts: pip install plotly")
        return
    sample = safe_sample_df(df, config.max_plot_points)
    chart_type = st.selectbox(
        "Chart type",
        ["Scatter", "Distribution", "Box by category", "Grouped bar", "Correlation network"],
        key="interactive_chart_type",
    )
    numeric_options = [c for c in schema.numeric if c in sample.columns]
    categorical_options = [None] + [c for c in list(dict.fromkeys(schema.categorical + schema.boolean)) if c in sample.columns]
    all_options = [None] + sample.columns.tolist()

    if chart_type == "Correlation network":
        corr = scan.get("correlations")
        if not isinstance(corr, pd.DataFrame) or corr.empty:
            corr = strongest_correlations(sample, config, top_n=40)
        threshold = st.slider("Minimum relationship strength", 0.1, 0.95, 0.45, 0.05)
        fig = make_correlation_network_plot(corr, min_strength=threshold)
        if fig is not None:
            st.plotly_chart(fig, use_container_width=True, key="interactive_corr_network_plot")
            st.dataframe(corr[corr["strength"] >= threshold].head(50), use_container_width=True)
        else:
            st.info("No correlation network is available for this dataset.")
        return

    if not numeric_options:
        st.info("Interactive charts need at least one numeric column.")
        return

    if chart_type == "Scatter":
        left, mid, right = st.columns(3)
        with left:
            x_col = st.selectbox("X", numeric_options, key="scatter_x")
        with mid:
            y_default = 1 if len(numeric_options) > 1 else 0
            y_col = st.selectbox("Y", numeric_options, index=y_default, key="scatter_y")
        with right:
            color_col = st.selectbox("Color", all_options, key="scatter_color")
        size_col = st.selectbox("Size", [None] + numeric_options, key="scatter_size")
        fig = px.scatter(
            sample,
            x=x_col,
            y=y_col,
            color=color_col,
            size=size_col,
            hover_data=sample.columns[: min(15, sample.shape[1])],
            opacity=0.75,
            title=f"{y_col} by {x_col}",
        )
        fig.update_layout(height=580)
        st.plotly_chart(fig, use_container_width=True, key="interactive_scatter_plot")
        filter_col = color_col if color_col else None
    elif chart_type == "Distribution":
        x_col = st.selectbox("Metric", numeric_options, key="dist_metric")
        color_col = st.selectbox("Split by", categorical_options, key="dist_color")
        fig = px.histogram(sample, x=x_col, color=color_col, marginal="box", nbins=40, title=f"Distribution of {x_col}")
        fig.update_layout(height=540)
        st.plotly_chart(fig, use_container_width=True, key="interactive_distribution_plot")
        filter_col = color_col
    elif chart_type == "Box by category":
        x_col = st.selectbox("Category", categorical_options[1:] or sample.columns.tolist(), key="box_category")
        y_col = st.selectbox("Metric", numeric_options, key="box_metric")
        fig = px.box(sample, x=x_col, y=y_col, points="outliers", title=f"{y_col} distribution by {x_col}")
        fig.update_layout(height=560)
        st.plotly_chart(fig, use_container_width=True, key="interactive_box_plot")
        filter_col = x_col
    else:
        cat_col = st.selectbox("Category", categorical_options[1:] or sample.columns.tolist(), key="bar_category")
        metric_col = st.selectbox("Metric", [None] + numeric_options, key="bar_metric", format_func=lambda x: "Row count" if x is None else str(x))
        agg = st.selectbox("Aggregation", ["mean", "sum", "median", "count"], key="bar_agg")
        if metric_col is None or agg == "count":
            grouped = sample.groupby(cat_col).size().reset_index(name="count").sort_values("count", ascending=False).head(config.grouped_max_categories)
            y_col = "count"
        else:
            temp = sample[[cat_col, metric_col]].copy()
            temp[metric_col] = pd.to_numeric(temp[metric_col], errors="coerce")
            grouped = temp.dropna().groupby(cat_col)[metric_col].agg(agg).reset_index().sort_values(metric_col, ascending=False).head(config.grouped_max_categories)
            y_col = metric_col
        fig = px.bar(grouped, x=cat_col, y=y_col, hover_data=grouped.columns, title=f"{agg} {metric_col or 'rows'} by {cat_col}")
        fig.update_layout(height=540)
        st.plotly_chart(fig, use_container_width=True, key="interactive_grouped_bar_plot")
        filter_col = cat_col

    if filter_col and filter_col in sample.columns and sample[filter_col].nunique(dropna=True) <= config.grouped_max_categories:
        values = sample[filter_col].dropna().astype(str).value_counts().index.tolist()
        chosen = st.multiselect("Inspect underlying rows for selected values", values, default=values[:1], key=f"rows_for_{chart_type}_{filter_col}")
        if chosen:
            row_mask = sample[filter_col].astype(str).isin(chosen)
            st.dataframe(sample.loc[row_mask].head(500), use_container_width=True)
    else:
        st.dataframe(sample.head(200), use_container_width=True)


# -----------------------------------------------------------------------------
# Modeling preparation
# -----------------------------------------------------------------------------


def detect_problem_type(series: pd.Series, override: str = "Auto") -> str:
    if override == "Classification":
        return "classification"
    if override == "Regression":
        return "regression"
    if pd.api.types.is_numeric_dtype(series):
        unique_count = int(series.nunique(dropna=True))
        return "classification" if unique_count <= 10 else "regression"
    return "classification"


def make_feature_frame(df: pd.DataFrame, target: str | None = None) -> pd.DataFrame:
    X = df.drop(columns=[target], errors="ignore").copy()
    datetime_features = [c for c in X.columns if pd.api.types.is_datetime64_any_dtype(X[c])]
    for c in datetime_features:
        X[c + "_year"] = X[c].dt.year
        X[c + "_month"] = X[c].dt.month
        X[c + "_day"] = X[c].dt.day
        X[c + "_dow"] = X[c].dt.dayofweek
        X[c + "_quarter"] = X[c].dt.quarter
    X = X.drop(columns=datetime_features, errors="ignore")
    for c in X.columns:
        if pd.api.types.is_bool_dtype(X[c]):
            X[c] = X[c].astype("Int64")
    return X


def make_onehot_encoder(config: WorkbenchConfig) -> OneHotEncoder:
    try:
        return OneHotEncoder(handle_unknown="ignore", max_categories=config.max_onehot_unique, sparse_output=True)
    except TypeError:
        try:
            return OneHotEncoder(handle_unknown="ignore", max_categories=config.max_onehot_unique, sparse=True)
        except TypeError:
            return OneHotEncoder(handle_unknown="ignore")


def make_model_preprocessor(
    X: pd.DataFrame,
    config: WorkbenchConfig,
    include_text_feature: bool = False,
    text_feature: str | None = None,
) -> tuple[ColumnTransformer, list[str], list[str], list[str], list[str]]:
    numeric_features = [c for c in X.columns if pd.api.types.is_numeric_dtype(X[c])]
    categorical_features: list[str] = []
    text_features: list[str] = []
    dropped_features: list[str] = []

    selected_text = text_feature if include_text_feature and text_feature in X.columns else None

    for c in X.columns:
        if c in numeric_features:
            continue
        non_null = X[c].dropna().astype(str)
        nunique = int(non_null.nunique(dropna=True)) if len(non_null) else 0
        avg_len = float(non_null.str.len().mean()) if len(non_null) else 0.0
        high_cardinality = nunique > config.max_onehot_unique
        long_text = avg_len > config.max_onehot_avg_len
        id_like = is_probably_id(c, X[c])

        if selected_text and c == selected_text:
            text_features.append(c)
        elif high_cardinality or long_text or id_like:
            dropped_features.append(c)
        else:
            categorical_features.append(c)

    transformers: list[tuple[str, Any, Any]] = []
    if numeric_features:
        transformers.append((
            "num",
            Pipeline([
                ("imputer", SimpleImputer(strategy="median")),
                ("scaler", StandardScaler()),
            ]),
            numeric_features,
        ))
    if categorical_features:
        transformers.append((
            "cat",
            Pipeline([
                ("imputer", SimpleImputer(strategy="most_frequent")),
                ("onehot", make_onehot_encoder(config)),
            ]),
            categorical_features,
        ))
    for text_col in text_features:
        X[text_col] = X[text_col].fillna("").astype(str)
        transformers.append((
            f"text_{text_col}",
            TfidfVectorizer(stop_words="english", max_features=config.max_text_model_features, ngram_range=(1, 2)),
            text_col,
        ))

    if not transformers:
        raise ValueError("No usable modeling features after dropping empty, text, ID, and high-cardinality columns.")

    preprocessor = ColumnTransformer(transformers=transformers, remainder="drop", sparse_threshold=1.0)
    return preprocessor, numeric_features, categorical_features, text_features, dropped_features


def model_library(problem_type: str, config: WorkbenchConfig) -> dict[str, Any]:
    if problem_type == "regression":
        return {
            "Linear Regression": LinearRegression(),
            "Regression Tree": DecisionTreeRegressor(random_state=42, max_depth=8),
            "Random Forest": RandomForestRegressor(
                random_state=42,
                n_estimators=config.rf_estimators,
                max_depth=12,
                n_jobs=-1,
            ),
            "Boosting": GradientBoostingRegressor(
                random_state=42,
                n_estimators=config.gb_estimators,
                max_depth=3,
            ),
            "SVM": SVR(kernel="rbf", C=1.0, epsilon=0.1),
            "Neural Network": MLPRegressor(
                hidden_layer_sizes=(64, 32),
                max_iter=config.nn_max_iter,
                early_stopping=True,
                random_state=42,
            ),
        }
    return {
        "Logistic Regression": LogisticRegression(max_iter=1500, n_jobs=None),
        "Classification Tree": DecisionTreeClassifier(random_state=42, max_depth=8),
        "Random Forest": RandomForestClassifier(
            random_state=42,
            n_estimators=config.rf_estimators,
            max_depth=12,
            n_jobs=-1,
        ),
        "Boosting": GradientBoostingClassifier(
            random_state=42,
            n_estimators=config.gb_estimators,
            max_depth=3,
        ),
        "SVM": SVC(kernel="rbf", C=1.0, probability=False, random_state=42),
        "Neural Network": MLPClassifier(
            hidden_layer_sizes=(64, 32),
            max_iter=config.nn_max_iter,
            early_stopping=True,
            random_state=42,
        ),
    }


def default_models_for_problem(problem_type: str) -> list[str]:
    if problem_type == "regression":
        return ["Linear Regression", "Regression Tree", "Random Forest", "Boosting"]
    return ["Logistic Regression", "Classification Tree", "Random Forest", "Boosting"]


def model_requires_dense(name: str) -> bool:
    return name in {"Boosting", "Neural Network"}


def model_training_cap(name: str, config: WorkbenchConfig) -> int | None:
    if name == "SVM":
        return config.max_svm_rows
    if name == "Neural Network":
        return config.max_nn_rows
    return None


def safe_stratify(y: pd.Series, test_size: float) -> pd.Series | None:
    if y.nunique(dropna=True) <= 1:
        return None
    counts = y.value_counts(dropna=True)
    if counts.empty or counts.min() < 2:
        return None
    n_classes = int(y.nunique(dropna=True))
    n_test = int(math.ceil(len(y) * test_size))
    n_train = len(y) - n_test
    if n_test < n_classes or n_train < n_classes:
        return None
    return y


def train_supervised_models(
    df: pd.DataFrame,
    target: str,
    selected_models: list[str],
    config: WorkbenchConfig,
    test_size: float = 0.2,
    include_text_feature: bool = False,
    text_feature: str | None = None,
    problem_override: str = "Auto",
) -> dict[str, Any]:
    clean = df.dropna(subset=[target]).copy()
    if clean.empty:
        raise ValueError("No rows remain after dropping missing target values.")

    original_rows = len(clean)
    if len(clean) > config.max_model_rows:
        clean = clean.sample(config.max_model_rows, random_state=42).copy()

    y = clean[target]
    problem_type = detect_problem_type(y, problem_override)

    if y.nunique(dropna=True) < 2:
        raise ValueError("The selected target has fewer than 2 unique non-missing values.")

    X = make_feature_frame(clean, target)
    preprocessor, numeric_features, categorical_features, text_features, dropped_features = make_model_preprocessor(
        X,
        config,
        include_text_feature=include_text_feature,
        text_feature=text_feature,
    )

    if problem_type == "classification":
        stratify = safe_stratify(y, test_size)
        X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=test_size, random_state=42, stratify=stratify)
    else:
        X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=test_size, random_state=42)

    # Fit preprocessing once and reuse it across model families.
    X_train_enc = preprocessor.fit_transform(X_train)
    X_test_enc = preprocessor.transform(X_test)

    try:
        feature_names = [prettify_feature_name(x) for x in preprocessor.get_feature_names_out()]
    except Exception:
        feature_names = [f"feature_{i}" for i in range(X_train_enc.shape[1])]

    library = model_library(problem_type, config)
    results: list[dict[str, Any]] = []
    details: dict[str, Any] = {}
    failures: list[dict[str, Any]] = []

    for name in selected_models:
        if name not in library:
            failures.append({"model": name, "reason": "Model is not available for this problem type."})
            continue

        model = library[name]
        row_cap = model_training_cap(name, config)
        train_matrix = X_train_enc
        train_target = y_train

        if row_cap is not None and X_train_enc.shape[0] > row_cap:
            rng = np.random.default_rng(42)
            idx = rng.choice(X_train_enc.shape[0], size=row_cap, replace=False)
            train_matrix = X_train_enc[idx]
            train_target = y_train.iloc[idx] if hasattr(y_train, "iloc") else y_train[idx]

        test_matrix = X_test_enc
        train_rows = int(train_matrix.shape[0])
        test_rows = int(test_matrix.shape[0])
        feature_count = int(train_matrix.shape[1])

        if model_requires_dense(name):
            dense_train_cells = train_rows * feature_count
            dense_test_cells = test_rows * feature_count
            if dense_train_cells > config.max_dense_cells or dense_test_cells > config.max_dense_cells:
                failures.append({
                    "model": name,
                    "reason": f"Skipped to avoid dense matrix blowup: {train_rows:,} train rows x {feature_count:,} features.",
                })
                continue
            train_matrix = to_dense_if_needed(train_matrix)
            test_matrix = to_dense_if_needed(test_matrix)

        start = time.perf_counter()
        try:
            model.fit(train_matrix, train_target)
            preds = model.predict(test_matrix)
        except Exception as exc:
            failures.append({"model": name, "reason": str(exc)})
            continue

        score_values = None
        if problem_type == "classification":
            try:
                if hasattr(model, "predict_proba"):
                    score_values = model.predict_proba(test_matrix)
                elif hasattr(model, "decision_function"):
                    score_values = model.decision_function(test_matrix)
            except Exception:
                score_values = None

        elapsed = round(time.perf_counter() - start, 2)
        record: dict[str, Any] = {"model": name, "train_seconds": elapsed, "train_rows": train_rows, "encoded_features": feature_count}

        if problem_type == "regression":
            record["R2"] = float(r2_score(y_test, preds))
            record["RMSE"] = float(math.sqrt(mean_squared_error(y_test, preds)))
            record["MAE"] = float(mean_absolute_error(y_test, preds))
            record["score_for_ranking"] = record["R2"]
        else:
            label_values = sorted(
                pd.concat([pd.Series(y_test), pd.Series(preds)]).dropna().unique().tolist(),
                key=lambda x: str(x),
            )
            record["Accuracy"] = float(accuracy_score(y_test, preds))
            record["score_for_ranking"] = record["Accuracy"]
            record["report"] = classification_report(y_test, preds, labels=label_values, output_dict=True, zero_division=0)
            record["confusion_matrix"] = confusion_matrix(y_test, preds, labels=label_values)
            record["labels"] = label_values

        results.append(record)
        details[name] = {
            "model_object": model,
            "preprocessor": preprocessor,
            "y_test": y_test,
            "preds": preds,
            "score_values": score_values,
            "labels": record.get("labels"),
            "X_test_encoded": test_matrix,
            "X_test_raw": X_test,
            "feature_names": feature_names,
            "feature_frame_columns": X.columns.tolist(),
            "requires_dense": model_requires_dense(name),
            "problem_type": problem_type,
        }

    if not results:
        raise ValueError(f"All selected models failed or were skipped: {failures}")

    leaderboard = pd.DataFrame(results).sort_values("score_for_ranking", ascending=False).reset_index(drop=True)
    best_model = str(leaderboard.iloc[0]["model"])

    return {
        "problem_type": problem_type,
        "target": target,
        "leaderboard": leaderboard,
        "best_model": best_model,
        "details": details,
        "model_failures": failures,
        "dropped_features": dropped_features,
        "used_numeric_features": numeric_features,
        "used_categorical_features": categorical_features,
        "used_text_features": text_features,
        "trained_rows": len(clean),
        "original_rows_with_target": original_rows,
        "test_size": test_size,
    }


