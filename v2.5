def clean_column_name(name: Any) -> str:
    text = str(name).strip()
    text = re.sub(r"\s+", "_", text)
    text = re.sub(r"[^0-9a-zA-Z_]+", "", text)
    return text or "unnamed_column"


def dedupe_column_names(columns: list[str]) -> list[str]:
    seen: dict[str, int] = {}
    out: list[str] = []
    for col in columns:
        base = col or "unnamed_column"
        count = seen.get(base, 0)
        if count == 0:
            out.append(base)
        else:
            out.append(f"{base}_{count + 1}")
        seen[base] = count + 1
    return out


def safe_sample_df(df: pd.DataFrame, max_rows: int, random_state: int = 42) -> pd.DataFrame:
    if max_rows <= 0 or len(df) <= max_rows:
        return df.copy()
    return df.sample(max_rows, random_state=random_state).copy()


def choose_numeric_columns_by_variance(df: pd.DataFrame, max_cols: int) -> list[str]:
    numeric_cols = df.select_dtypes(include=[np.number]).columns.tolist()
    if len(numeric_cols) <= max_cols:
        return numeric_cols
    variances = df[numeric_cols].var(numeric_only=True).replace([np.inf, -np.inf], np.nan).dropna()
    if variances.empty:
        return numeric_cols[:max_cols]
    return variances.sort_values(ascending=False).head(max_cols).index.tolist()


def is_probably_id(name: str, series: pd.Series | None = None) -> bool:
    low = str(name).lower()
    patterns = [
        "id", "uuid", "guid", "email", "phone", "ssn", "url", "link", "address",
        "zipcode", "zip_code", "postal", "hash", "token", "key", "account", "acct",
    ]
    name_hit = any(low == p or low.endswith("_" + p) or low.startswith(p + "_") or p in low for p in patterns)
    if series is None:
        return name_hit
    non_null = series.dropna()
    if non_null.empty:
        return name_hit
    unique_ratio = non_null.nunique(dropna=True) / max(1, len(non_null))
    return bool(name_hit and unique_ratio > 0.6)


def is_latitude_col(name: str, series: pd.Series) -> bool:
    low = str(name).lower()
    if not any(x in low for x in ["lat", "latitude"]):
        return False
    vals = pd.to_numeric(series, errors="coerce").dropna()
    return not vals.empty and vals.between(-90, 90).mean() > 0.95


def is_longitude_col(name: str, series: pd.Series) -> bool:
    low = str(name).lower()
    if not any(x in low for x in ["lon", "lng", "longitude"]):
        return False
    vals = pd.to_numeric(series, errors="coerce").dropna()
    return not vals.empty and vals.between(-180, 180).mean() > 0.95


def detect_lat_lon(df: pd.DataFrame) -> tuple[str | None, str | None]:
    lat_cols = [c for c in df.columns if is_latitude_col(c, df[c])]
    lon_cols = [c for c in df.columns if is_longitude_col(c, df[c])]
    return (lat_cols[0] if lat_cols else None, lon_cols[0] if lon_cols else None)


def numeric_mean_or_zero(df: pd.DataFrame, col: str | None) -> float:
    if not col or col not in df.columns:
        return 0.0
    vals = pd.to_numeric(df[col], errors="coerce").dropna()
    return float(vals.mean()) if not vals.empty else 0.0


def format_seconds(seconds: float | int | None) -> str:
    if seconds is None:
        return "N/A"
    seconds = float(seconds)
    if seconds < 60:
        return f"{seconds:.2f}s"
    minutes = int(seconds // 60)
    rest = seconds % 60
    return f"{minutes}m {rest:.1f}s"


